-------------------------------------------------------------------------------
-- DICTIONARY, HARDNESS & CACHE LOGIC
-------------------------------------------------------------------------------

-- Safe 20k common words list (No more 400k bloat)
local DICTIONARY_URLS = {
    "https://raw.githubusercontent.com/first20hours/google-10000-english/master/20k.txt"
}

local allWords = {}
local customWordsSet = {}
local uniqueWordsSet = {}

local fileSystemSupported = type(readfile) == "function" and type(writefile) == "function"
-- Brand new folder to prevent interference with your old script
local CACHE_DIR = "WordGuesser_Cache_V4_Safe"
local ALL_WORDS_FILE = CACHE_DIR .. "/AllWords.txt"
local CUSTOM_WORDS_FILE = CACHE_DIR .. "/CustomWords.txt"

local letterHardness = {
    X = 100, Z = 99, Q = 98, J = 97, V = 96, Y = 95, K = 94, W = 93, U = 92,
    F = 80, H = 79, M = 78, P = 77, B = 76, G = 75, C = 74,
    L = 60, D = 59, R = 58, T = 57, N = 56, S = 55,
    A = 40, I = 39, O = 38, E = 37
}

local function getWordScore(word)
    local lastChar = string.sub(word, -1)
    local lastTwo = string.sub(word, -2)
    
    if lastTwo == "OX" then return 99.5
    elseif lastChar == "X" then return 100
    else return letterHardness[lastChar] or 0 end
end

local function downloadAndCache()
    allWords = {}
    customWordsSet = {}
    uniqueWordsSet = {}
    
    wordList.Text = "Fetching Custom Words..."
    local successJSON, responseJSON = pcall(function()
        return game:HttpGet("https://raw.githubusercontent.com/ScpGuest666/Last-impossible-letters/refs/heads/main/Last%20letter%201")
    end)
    
    if successJSON and responseJSON then
        for word in responseJSON:gmatch('"([^"]+)"') do
            local cleanWord = word:gsub("[%p%s%d]", "")
            if string.len(cleanWord) >= 2 then
                local upperWord = string.upper(cleanWord)
                customWordsSet[upperWord] = true
                uniqueWordsSet[upperWord] = true
            end
        end
    end

    for i, url in ipairs(DICTIONARY_URLS) do
        wordList.Text = "Fetching Safe Dict " .. i .. "...\n(Merging lists)"
        task.wait(0.1)
        local successDict, responseDict = pcall(function() return game:HttpGet(url) end)
        
        if successDict and responseDict then
            local count = 0
            for word in responseDict:gmatch("[^\r\n]+") do
                local cleanWord = word:gsub("[%p%s%d]", "")
                if string.len(cleanWord) >= 2 then uniqueWordsSet[string.upper(cleanWord)] = true end
                count = count + 1
                if count % 5000 == 0 then task.wait() end
            end
        end
    end

    wordList.Text = "Sorting Words..."
    task.wait(0.1)
    for word, _ in pairs(uniqueWordsSet) do table.insert(allWords, word) end

    table.sort(allWords, function(a, b)
        local isCustomA = customWordsSet[a] or false
        local isCustomB = customWordsSet[b] or false
        if isCustomA ~= isCustomB then return isCustomA end
        
        local scoreA = getWordScore(a)
        local scoreB = getWordScore(b)
        if scoreA == scoreB then return string.len(a) < string.len(b) end
        return scoreA > scoreB
    end)
    
    if fileSystemSupported then
        wordList.Text = "Saving to Workspace Cache..."
        task.wait(0.1)
        pcall(function()
            if type(makefolder) == "function" and type(isfolder) == "function" then
                if not isfolder(CACHE_DIR) then makefolder(CACHE_DIR) end
            end
            local customArray = {}
            for w, _ in pairs(customWordsSet) do table.insert(customArray, w) end
            writefile(CUSTOM_WORDS_FILE, table.concat(customArray, "\n"))
            writefile(ALL_WORDS_FILE, table.concat(allWords, "\n"))
        end)
    end
    
    wordList.Text = "<font color=\"#00FF00\">Ready!</font>\nWaiting for game prompt..."
end

local function loadFromCache()
    wordList.Text = "Loading from Workspace Cache...\n(Lightning Fast)"
    task.wait(0.1)
    local success = pcall(function()
        local customData = readfile(CUSTOM_WORDS_FILE)
        for w in customData:gmatch("[^\r\n]+") do customWordsSet[w] = true end
        local allData = readfile(ALL_WORDS_FILE)
        for w in allData:gmatch("[^\r\n]+") do table.insert(allWords, w) end
    end)
    
    if success and #allWords > 0 then
        wordList.Text = "<font color=\"#00FF00\">Ready!</font>\nWaiting for game prompt..."
    else
        downloadAndCache()
    end
end

task.spawn(function()
    if fileSystemSupported and type(isfile) == "function" and isfile(ALL_WORDS_FILE) and isfile(CUSTOM_WORDS_FILE) then
        loadFromCache()
    else
        downloadAndCache()
    end
end)

-------------------------------------------------------------------------------
-- ADVANCED AUTO-DETECT LOGIC (BULLETPROOF VERSION)
-------------------------------------------------------------------------------

local autoDetectEnabled = true
local lastDetectedPrompt = ""

autoDetectBtn.MouseButton1Click:Connect(function()
    autoDetectEnabled = not autoDetectEnabled
    if autoDetectEnabled then
        autoDetectBtn.Text = "Auto-Detect: ON"
        autoDetectBtn.BackgroundColor3 = Color3.fromRGB(0, 150, 0)
    else
        autoDetectBtn.Text = "Auto-Detect: OFF"
        autoDetectBtn.BackgroundColor3 = Color3.fromRGB(150, 100, 0)
        lastDetectedPrompt = ""
    end
end)

task.spawn(function()
    while task.wait(0.1) do
        if not autoDetectEnabled then continue end
        
        local detected = ""
        local promptFound = false
        local promptLabel = nil
        
        -- 1. Find the prompt text
        for _, gui in ipairs(player.PlayerGui:GetChildren()) do
            if not gui:IsA("ScreenGui") then continue end
            if gui.Name == "WordGuesser_Pro_Auto" then continue end
            
            for _, desc in ipairs(gui:GetDescendants()) do
                -- Ignore invisible or highly transparent elements
                if desc:IsA("TextLabel") and desc.Visible and desc.TextTransparency < 0.9 then
                    local textLower = desc.Text:lower()
                    if textLower:find("type a word starting with") or textLower:find("type a word containing") then
                        promptFound = true
                        promptLabel = desc
                        break
                    end
                end
            end
            if promptFound then break end
        end
        
        if promptFound and promptLabel then
            local letters = {}
            local viewportWidth = workspace.CurrentCamera.ViewportSize.X
            local screenCenter = viewportWidth / 2
            local promptY = promptLabel.AbsolutePosition.Y
            
            local activeGui = promptLabel:FindFirstAncestorOfClass("ScreenGui")
            if activeGui then
                for _, desc in ipairs(activeGui:GetDescendants()) do
                    if desc:IsA("TextLabel") and desc.Visible and desc.TextTransparency < 0.9 then
                        if desc == promptLabel then continue end
                        -- Ignore tiny UI artifacts
                        if desc.AbsoluteSize.X < 10 or desc.AbsoluteSize.Y < 10 then continue end
                        
                        local t = desc.Text:gsub("<[^>]+>", ""):gsub("[%s%p]", "")
                        if #t == 1 and t:match("^%a+$") then
                            table.insert(letters, {
                                text = string.upper(t),
                                x = desc.AbsolutePosition.X,
                                y = desc.AbsolutePosition.Y,
                                width = desc.AbsoluteSize.X
                            })
                        end
                    end
                end
            end
            
            -- 2. Group by Y position (STRICT tolerance to prevent keyboard row drift)
            local groups = {}
            for _, l in ipairs(letters) do
                local added = false
                for _, g in ipairs(groups) do
                    -- Must be within 10 pixels of the FIRST letter in the group
                    if math.abs(g.startY - l.y) <= 10 then
                        table.insert(g.letters, l)
                        added = true
                        break
                    end
                end
                if not added then
                    table.insert(groups, {startY = l.y, letters = {l}})
                end
            end
            
            -- 3. Find the best group using Center-Screen Heuristic
            local bestGroup = nil
            local bestScore = math.huge
            
            for _, g in ipairs(groups) do
                if #g.letters > 6 then continue end -- Ignore full keyboard rows
                if g.startY < promptY - 30 then continue end -- Must be below or near prompt
                if g.startY > promptY + 300 then continue end -- Don't go too far down
                
                table.sort(g.letters, function(a, b) return a.x < b.x end)
                
                local first = g.letters[1]
                local last = g.letters[#g.letters]
                local groupCenterX = (first.x + last.x + last.width) / 2
                
                local distanceFromCenter = math.abs(groupCenterX - screenCenter)
                local distanceFromPromptY = math.abs(g.startY - promptY)
                
                -- Score: heavily penalize being off-center (ignores side UI)
                local score = distanceFromCenter + (distanceFromPromptY * 0.2)
                
                if score < bestScore then
                    bestScore = score
                    bestGroup = g.letters
                end
            end
            
            -- 4. Construct the word
            if bestGroup then
                for _, l in ipairs(bestGroup) do
                    detected = detected .. l.text
                end
            end
        end
        
        -- 5. Update the Input Box safely
        if promptFound and detected ~= "" then
            if detected ~= lastDetectedPrompt then
                lastDetectedPrompt = detected
                if not inputBox:IsFocused() then
                    inputBox.Text = detected
                end
            end
        end
    end
end)

inputBox.FocusLost:Connect(function()
    if inputBox.Text == "" and autoDetectEnabled then
        inputBox.Text = lastDetectedPrompt
    end
end)

-------------------------------------------------------------------------------
-- TEXT BOX INPUT LOGIC
-------------------------------------------------------------------------------

local function findWords(prompt)
    local results = {}
    local promptLen = string.len(prompt)
    
    for i = 1, #allWords do
        local word = allWords[i]
        if string.sub(word, 1, promptLen) == prompt then
            table.insert(results, word)
            if #results >= 50 then break end
        end
    end
    return results
end

inputBox:GetPropertyChangedSignal("Text"):Connect(function()
    local text = string.upper(inputBox.Text:gsub("[%s%p]", ""))
    
    if text ~= "" then
        local words = findWords(text)
        
        if #words > 0 then
            local displayText = ""
            for i, word in ipairs(words) do
                local lowerWord = string.lower(word)
                local displayWord
                
                if string.sub(word, -2) == "OX" then
                    displayWord = string.sub(lowerWord, 1, -3) .. "OX"
                else
                    displayWord = string.sub(lowerWord, 1, -2) .. string.upper(string.sub(lowerWord, -1))
                end
                
                if customWordsSet[word] then
                    displayText = displayText .. i .. ". <font color=\"#FFFF00\">" .. displayWord .. "</font>\n"
                else
                    displayText = displayText .. i .. ". <font color=\"#FFFFFF\">" .. displayWord .. "</font>\n"
                end
            end
            wordList.Text = " " .. displayText
        else
            wordList.Text = " <font color=\"#FFA500\">No words found starting with:\n " .. text .. "</font>"
        end
    else
        wordList.Text = " <font color=\"#969696\">Waiting for game prompt...</font>"
    end
end)


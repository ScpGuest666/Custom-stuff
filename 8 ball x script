-- Helper function to identify if a part is a pool ball
local function isBall(obj)
    if not obj:IsA("BasePart") then return false end
    if obj.Size.Magnitude > 5 then return false end
    
    local name = obj.Name:lower()
    if name:find("ball") or name == "cue" or name == "white" then return true end
    
    local num = tonumber(obj.Name)
    if num and num >= 1 and num <= 15 then return true end
    if obj:IsA("Part") and obj.Shape == Enum.PartType.Ball then return true end
    
    return false
end

-- Helper function to identify the cue stick
local function isCueStick(obj)
    if not obj:IsA("BasePart") then return false end
    if obj.Size.Magnitude <= 2.5 then return false end
    
    local name = obj.Name:lower()
    local parentName = obj.Parent and obj.Parent.Name:lower() or ""
    
    local isNamedCue = (name:find("cue") or name:find("stick") or name:find("aim") or parentName:find("cue") or parentName:find("stick"))
    if not isNamedCue then return false end
    
    local isNotBall = not (name:find("ball") or parentName:find("ball"))
    if not isNotBall then return false end
    
    local parent = obj.Parent
    while parent and parent ~= workspace do
        if parent:FindFirstChildOfClass("Humanoid") then return false end
        parent = parent.Parent
    end
    
    return true
end

-- Helper function to determine ball type and assign a color
local function getBallInfo(ball)
    local name = ball.Name:lower()
    local num = tonumber(ball.Name)
    
    if name:find("cue") or name == "white" or name == "0" then return Color3.fromRGB(255, 255, 255) end
    if num then
        if num == 8 then 
            local pulseAlpha = (math.sin(os.clock() * 6) + 1) / 2
            return Color3.fromRGB(255, 0, 0):Lerp(Color3.fromRGB(255, 255, 0), pulseAlpha)
        elseif num >= 1 and num <= 7 then return Color3.fromRGB(255, 50, 50)
        elseif num >= 9 and num <= 15 then return Color3.fromRGB(255, 255, 50)
        end
    end
    return Color3.fromRGB(0, 255, 255)
end

local function isCueBall(ball)
    return getBallInfo(ball) == Color3.fromRGB(255, 255, 255)
end

-- Anti-Smoke/Cloud Effects
local function removeSmokeEffects()
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("ParticleEmitter") or obj:IsA("Smoke") or obj:IsA("Cloud") or obj:IsA("Fire") then
            obj.Enabled = false
        end
    end
end

-- Refresh cache (Optimized to prevent freezing)
local function refreshCache()
    local tempBalls = {}
    local tempSticks = {}
    local count = 0
    
    local descendants = workspace:GetDescendants()
    for i = 1, #descendants do
        local obj = descendants[i]
        if isBall(obj) then 
            table.insert(tempBalls, obj)
        elseif isCueStick(obj) then 
            table.insert(tempSticks, obj) 
        end
        
        count = count + 1
        if count >= 1500 then
            count = 0
            task.wait()
        end
    end
    
    cachedBalls = tempBalls
    cachedSticks = tempSticks
    
    removeSmokeEffects()
end

-- Anti-Blur & Anti-Invisible Balls
local function enforceVisuals()
    for _, effect in ipairs(Lighting:GetChildren()) do
        if effect:IsA("BlurEffect") or effect:IsA("DepthOfFieldEffect") then
            effect.Enabled = false
        end
    end
    if workspace.CurrentCamera then
        for _, effect in ipairs(workspace.CurrentCamera:GetChildren()) do
            if effect:IsA("BlurEffect") or effect:IsA("DepthOfFieldEffect") then
                effect.Enabled = false
            end
        end
    end
    
    for _, ball in ipairs(cachedBalls) do
        if ball and ball.Parent then
            if ball.Transparency > 0 then
                ball.Transparency = 0
                ball.LocalTransparencyModifier = 0
            end
        end
    end
end

-- Highlight management
local function getOrCreateHighlight(part)
    if highlights[part] then return highlights[part] end
    local highlight = Instance.new("Highlight")
    highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
    highlight.FillTransparency = 0.4
    highlight.OutlineTransparency = 0.1
    highlight.Parent = part
    highlights[part] = highlight
    return highlight
end

local function clearHighlights()
    for _, highlight in pairs(highlights) do
        if highlight then highlight:Destroy() end
    end
    table.clear(highlights)
end

-- Trajectory Line Management
local function getTrajectoryPart(index)
    if not trajectoryParts[index] then
        local p = Instance.new("Part")
        p.Anchored = true
        p.CanCollide = false
        p.Material = Enum.Material.SmoothPlastic
        p.Parent = workspace
        trajectoryParts[index] = p
    end
    return trajectoryParts[index]
end

local function hideTrajectories()
    for _, p in pairs(trajectoryParts) do p.Transparency = 1 end
end

local function drawLine(index, startPos, endPos, color, tableY)
    local p = getTrajectoryPart(index)
    local flatStart = Vector3.new(startPos.X, tableY + 0.1, startPos.Z)
    local flatEnd = Vector3.new(endPos.X, tableY + 0.1, endPos.Z)
    
    local dist = (flatEnd - flatStart).Magnitude
    if dist < 0.01 then p.Transparency = 1 return end
    
    p.Size = Vector3.new(0.15, 0.15, dist)
    p.CFrame = CFrame.lookAt(flatStart + (flatEnd - flatStart)/2, flatEnd)
    p.Color = color
    p.Transparency = 0.5
end

-- Ghost ball (flat disc) and direction line
local function clearGhostVisuals()
    for _, g in pairs(ghostBalls) do g:Destroy() end
    for _, l in pairs(ghostLines) do l:Destroy() end
    table.clear(ghostBalls)
    table.clear(ghostLines)
end

local function drawGhostBall(position, color, tableY, radius)
    local flatPos = Vector3.new(position.X, tableY + 0.05, position.Z)
    local ballPart = Instance.new("Part")
    ballPart.Shape = Enum.PartType.Cylinder
    local diameter = radius and (radius * 2) or 0.7
    ballPart.Size = Vector3.new(0.05, diameter, diameter)
    ballPart.CFrame = CFrame.new(flatPos) * CFrame.Angles(0, 0, math.rad(90))
    ballPart.Anchored = true
    ballPart.CanCollide = false
    ballPart.Color = color
    ballPart.Material = Enum.Material.SmoothPlastic
    ballPart.Transparency = 0.15
    ballPart.Parent = workspace
    table.insert(ghostBalls, ballPart)
end

local function drawGhostLine(startPos, direction, length, color, tableY)
    local flatStart = Vector3.new(startPos.X, tableY + 0.1, startPos.Z)
    local flatEnd = flatStart + direction * length
    local dist = length
    if dist < 0.01 then return end
    local linePart = Instance.new("Part")
    linePart.Anchored = true
    linePart.CanCollide = false
    linePart.Material = Enum.Material.SmoothPlastic
    linePart.Size = Vector3.new(0.12, 0.12, dist)
    linePart.CFrame = CFrame.lookAt(flatStart + (flatEnd - flatStart)/2, flatEnd)
    linePart.Color = color
    linePart.Transparency = 0.2
    linePart.Parent = workspace
    table.insert(ghostLines, linePart)
end

-- Mathematical Ray-Sphere Intersection for precise ball collision
local function getBallIntersection(rayOrigin, rayDir, ballRadius, tableY, ignoreBall)
    local closestDist = math.huge
    local closestBall = nil
    local flatOrigin = rayOrigin * Vector3.new(1, 0, 1)
    
    for _, ball in ipairs(cachedBalls) do
        if ball ~= ignoreBall and ball.Parent then
            if math.abs(ball.Position.Y - tableY) < 0.8 then
                local flatBallPos = ball.Position * Vector3.new(1, 0, 1)
                local L = flatBallPos - flatOrigin
                local tca = L:Dot(rayDir)
                if tca > 0 then
                    local d2 = L:Dot(L) - tca * tca
                    local radius2 = (ballRadius * 2) ^ 2
                    if d2 <= radius2 then
                        local thc = math.sqrt(radius2 - d2)
                        local t0 = tca - thc
                        if t0 > 0 and t0 < closestDist then
                            closestDist = t0
                            closestBall = ball
                        end
                    end
                end
            end
        end
    end
    return closestBall, closestDist
end

-- Main Update Loop
local function updateHighlights()
    if not isHighlighting then return end
    
    enforceVisuals()
    
    local character = player.Character
    local rootPart = character and character:FindFirstChild("HumanoidRootPart")
    if not rootPart then return end
    
    local rootPos = rootPart.Position
    local partsToHighlight = {}
    
    local activeCueBall = nil
    local activeStick = nil
    local minStickPlayerDist = math.huge
    
    for _, stick in ipairs(cachedSticks) do
        if stick and stick.Parent then
            local stickPlayerDist = (stick.Position - rootPos).Magnitude
            if stickPlayerDist < minStickPlayerDist then
                
                local closestBall = nil
                local minBallDist = 15
                for _, ball in ipairs(cachedBalls) do
                    if isCueBall(ball) and ball.Parent then
                        local ballDist = (stick.Position - ball.Position).Magnitude
                        if ballDist < minBallDist then
                            minBallDist = ballDist
                            closestBall = ball
                        end
                    end
                end
                
                if closestBall then
                    minStickPlayerDist = stickPlayerDist
                    activeStick = stick
                    activeCueBall = closestBall
                end
            end
        end
    end
    
    if activeStick then
        partsToHighlight[activeStick] = true
        local highlight = getOrCreateHighlight(activeStick)
        highlight.FillColor = Color3.fromRGB(170, 0, 255)
    end
    
    hideTrajectories()
    clearGhostVisuals()
    
    local currentStatusText = "Status: Online"
    
    if activeCueBall and activeStick then
        local tableY = activeCueBall.Position.Y
        local ballRadius = activeCueBall.Size.X / 2
        
        local stickLength = math.max(activeStick.Size.X, activeStick.Size.Y, activeStick.Size.Z)
        local restingDist = (stickLength / 2) + ballRadius
        local currentDist = (activeCueBall.Position - activeStick.Position).Magnitude
        local pullback = math.max(0, currentDist - restingDist)
        
        -- Calculate total distance using the POWER_SCALE variable
        local totalDistance = 5 + (pullback * POWER_SCALE)
        totalDistance = math.clamp(totalDistance, 2, 150) 
        
        local aimDir = (activeCueBall.Position - activeStick.Position) * Vector3.new(1, 0, 1)
        if aimDir.Magnitude > 0 then
            aimDir = aimDir.Unit
            
            local lineIndex = 1
            local maxLinesAllowed = 30
            local totalCueDistance = 0 
            local kissPowerCalculated = false
            
            local function simulatePath(startPos, direction, isCue, ignoreBall, maxBounces, color, remainingDist)
                local currentPos = startPos
                local currentDir = direction
                local currentDistLeft = remainingDist
                
                for bounce = 1, maxBounces do
                    if lineIndex > maxLinesAllowed or currentDistLeft <= 0.1 then return end
                    
                    local hitBall, ballDist = getBallIntersection(currentPos, currentDir, ballRadius, tableY, ignoreBall)
                    if hitBall and ballDist > currentDistLeft then
                        hitBall = nil 
                    end
                    
                    local wallHitPos, wallNormal, wallDist = nil, nil, math.huge
                    local rayOrigin = Vector3.new(currentPos.X, tableY, currentPos.Z)
                    
                    local ignoreList = {player.Character, activeStick}
                    for _, b in ipairs(cachedBalls) do table.insert(ignoreList, b) end
                    
                    local searchDist = hitBall and ballDist or currentDistLeft
                    local currentRayOrigin = rayOrigin
                    local safety = 0
                    
                    while searchDist > 0 and safety < 20 do
                        safety = safety + 1
                        local rayParams = RaycastParams.new()
                        rayParams.FilterType = Enum.RaycastFilterType.Exclude
                        rayParams.FilterDescendantsInstances = ignoreList
                        
                        local result = workspace:Raycast(currentRayOrigin, currentDir * searchDist, rayParams)
                        if result then
                            local inst = result.Instance
                            if inst.CanCollide and inst.Transparency < 0.9 then
                                wallHitPos = result.Position
                                wallNormal = result.Normal * Vector3.new(1, 0, 1)
                                if wallNormal.Magnitude > 0.001 then
                                    wallNormal = wallNormal.Unit
                                else
                                    wallNormal = -currentDir
                                end
                                
                                local rawDist = (Vector3.new(wallHitPos.X, tableY, wallHitPos.Z) - rayOrigin).Magnitude
                                local dot = currentDir:Dot(wallNormal)
                                local offset = ballRadius
                                if dot < -0.001 then
                                    offset = math.min(ballRadius / math.abs(dot), ballRadius * 10)
                                end
                                
                                wallDist = math.max(0, rawDist - offset)
                                break
                            else
                                table.insert(ignoreList, inst)
                            end
                        else
                            break
                        end
                    end
                    
                    if hitBall and ballDist <= wallDist then
                        local impactPos = currentPos + currentDir * ballDist
                        drawLine(lineIndex, currentPos, impactPos, color, tableY)
                        lineIndex = lineIndex + 1
                        
                        drawGhostBall(impactPos, color, tableY, ballRadius)
                        local collisionNormal = (hitBall.Position * Vector3.new(1,0,1) - impactPos * Vector3.new(1,0,1)).Unit
                        drawGhostLine(impactPos, collisionNormal, 1.5, getBallInfo(hitBall), tableY)
                        
                        currentDistLeft = currentDistLeft - ballDist
                        
                        if isCue then
                            if not kissPowerCalculated then
                                totalCueDistance = totalCueDistance + ballDist
                                local kissPower = math.clamp(math.ceil(totalCueDistance * KISS_MULTIPLIER), 1, 100)
                                currentStatusText = "Online | Kiss: ~" .. kissPower .. "%"
                                kissPowerCalculated = true
                            end
                            
                            -- PHYSICS MATH: Calculate how power splits based on the angle of the hit
                            local impactDot = math.clamp(currentDir:Dot(collisionNormal), 0, 1)
                            
                            -- Target ball gets power based on how direct the hit is
                            local targetDist = currentDistLeft * impactDot * 0.85 
                            -- Cue ball keeps the remaining power and deflects
                            local cueDist = currentDistLeft * math.sqrt(1 - (impactDot * impactDot)) * 0.6 
                            
                            -- Target ball path
                            simulatePath(hitBall.Position, collisionNormal, false, hitBall, 3, getBallInfo(hitBall), targetDist)
                            
                            -- Cue ball deflection
                            local tangent = currentDir - currentDir:Dot(collisionNormal) * collisionNormal
                            if tangent.Magnitude > 0.01 then
                                simulatePath(impactPos + tangent.Unit * 0.05, tangent.Unit, false, hitBall, 1, Color3.fromRGB(150, 150, 255), cueDist)
                            end
                        else
                            -- Target ball hitting another ball
                            local impactDot = math.clamp(currentDir:Dot(collisionNormal), 0, 1)
                            local targetDist = currentDistLeft * impactDot * 0.85
                            simulatePath(hitBall.Position, collisionNormal, false, hitBall, 2, getBallInfo(hitBall), targetDist)
                        end
                        break
                        
                    elseif wallHitPos and wallDist < math.huge then
                        local impactPos = currentPos + currentDir * wallDist
                        drawLine(lineIndex, currentPos, impactPos, color, tableY)
                        lineIndex = lineIndex + 1
                        
                        drawGhostBall(impactPos, color, tableY, ballRadius)
                        
                        currentDistLeft = currentDistLeft - wallDist
                        
                        if isCue and not kissPowerCalculated then
                            totalCueDistance = totalCueDistance + wallDist
                        end
                        
                        local dot = currentDir:Dot(wallNormal)
                        local newDir = currentDir - 2 * dot * wallNormal
                        newDir = newDir.Unit
                        
                        currentDir = newDir
                        currentPos = impactPos + wallNormal * 0.02 + newDir * 0.05
                        ignoreBall = nil
                        
                    else
                        local endPos = currentPos + currentDir * currentDistLeft
                        drawLine(lineIndex, currentPos, endPos, color, tableY)
                        drawGhostBall(endPos, color, tableY, ballRadius) 
                        lineIndex = lineIndex + 1
                        break
                    end
                end
            end
            
            simulatePath(activeCueBall.Position, aimDir, true, activeCueBall, 4, Color3.fromRGB(255, 255, 255), totalDistance)
        end
    end
    
    if statusLabel.Text ~= currentStatusText then
        statusLabel.Text = currentStatusText
    end
    
    for part, highlight in pairs(highlights) do
        if not partsToHighlight[part] then
            highlight:Destroy()
            highlights[part] = nil
        end
    end
end

local function setStatusOnline()
    if isHighlighting then return end
    isHighlighting = true
    
    currentSessionId = currentSessionId + 1
    local thisSession = currentSessionId
    
    statusLabel.Text = "Status: Online"
    statusLabel.TextColor3 = Color3.fromRGB(0, 255, 0)
    
    task.spawn(function()
        refreshCache()
        while isHighlighting and currentSessionId == thisSession do
            task.wait(2)
            if isHighlighting and currentSessionId == thisSession then 
                refreshCache() 
            end
        end
    end)
    
    local renderConnection = RunService.RenderStepped:Connect(updateHighlights)
    table.insert(activeConnections, renderConnection)
end

local function setStatusOffline()
    isHighlighting = false
    currentSessionId = currentSessionId + 1
    
    statusLabel.Text = "Status: Offline"
    statusLabel.TextColor3 = Color3.fromRGB(255, 0, 0)
    
    clearHighlights()
    hideTrajectories()
    clearGhostVisuals()
    
    for _, connection in pairs(activeConnections) do
        if connection and connection.Disconnect then connection:Disconnect() end
    end
    activeConnections = {}
end

local function cleanup()
    setStatusOffline()
    for _, p in pairs(trajectoryParts) do p:Destroy() end
    clearGhostVisuals()
    screenGui:Destroy()
end

onButton.MouseButton1Click:Connect(setStatusOnline)
offButton.MouseButton1Click:Connect(setStatusOffline)
destroyButton.MouseButton1Click:Connect(cleanup)

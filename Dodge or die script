local function applyPush(hrp, humanoid, direction, useForceY, yVelocity, speed, lookDir)
    local attachment = hrp:FindFirstChild("AutoDodgeAttachment")
    local linVel = hrp:FindFirstChild("AutoDodgeVelocity")
    local alignOri = hrp:FindFirstChild("AutoDodgeOrientation")
    
    if not attachment then
        attachment = Instance.new("Attachment")
        attachment.Name = "AutoDodgeAttachment"
        attachment.Parent = hrp
    end
    if not linVel then
        linVel = Instance.new("LinearVelocity")
        linVel.Name = "AutoDodgeVelocity"
        linVel.Attachment0 = attachment
        linVel.ForceLimitMode = Enum.ForceLimitMode.PerAxis
        linVel.VelocityConstraintMode = Enum.VelocityConstraintMode.Vector
        linVel.RelativeTo = Enum.ActuatorRelativeTo.World
        linVel.Parent = hrp
    end
    if not alignOri then
        alignOri = Instance.new("AlignOrientation")
        alignOri.Name = "AutoDodgeOrientation"
        alignOri.Mode = Enum.OrientationAlignmentMode.OneAttachment
        alignOri.Attachment0 = attachment
        alignOri.MaxTorque = 1000000
        alignOri.MaxAngularVelocity = 50
        alignOri.Responsiveness = 40
        alignOri.Parent = hrp
    end
    
    local HORIZONTAL_FORCE = 5e5
    local VERTICAL_FORCE = 9e9
    
    if useForceY and yVelocity > 0 then
        linVel.MaxAxesForce = Vector3.new(HORIZONTAL_FORCE, VERTICAL_FORCE, HORIZONTAL_FORCE)
    else
        linVel.MaxAxesForce = Vector3.new(HORIZONTAL_FORCE, 0, HORIZONTAL_FORCE)
    end
    
    if direction == Vector3.zero and not useForceY then
        local moveDir = humanoid.MoveDirection
        if moveDir.Magnitude > 0 then
            linVel.VectorVelocity = moveDir * humanoid.WalkSpeed
        else
            linVel.VectorVelocity = Vector3.zero 
        end
        linVel.Enabled = true
        alignOri.Enabled = false
    else
        local flatDir = Vector3.new(direction.X, 0, direction.Z).Unit
        if flatDir.Magnitude ~= flatDir.Magnitude then flatDir = Vector3.zero end 
        
        local targetVel = flatDir * speed
        if useForceY then targetVel = Vector3.new(targetVel.X, yVelocity, targetVel.Z)
        else targetVel = Vector3.new(targetVel.X, 0, targetVel.Z) end
        
        linVel.VectorVelocity = targetVel
        linVel.Enabled = true
        
        if lookDir and lookDir.Magnitude > 0.1 then
            alignOri.CFrame = CFrame.lookAt(Vector3.zero, lookDir)
            alignOri.Enabled = true
        elseif flatDir.Magnitude > 0.1 then
            alignOri.CFrame = CFrame.lookAt(Vector3.zero, flatDir)
            alignOri.Enabled = true
        else
            alignOri.Enabled = false
        end
    end
end

-------------------------------------------------------------------------------
-- DYNAMIC BURST DISTANCE CALCULATOR
-------------------------------------------------------------------------------
local function getSafeBurstDistance(hrpPos, dir, threats, wallRayParams, pitRayParams)
    local maxDist = MAX_BURST_DIST
    local right = dir:Cross(Vector3.new(0, 1, 0)).Unit
    
    local hits = {}
    table.insert(hits, workspace:Raycast(hrpPos, dir * maxDist, wallRayParams))
    table.insert(hits, workspace:Raycast(hrpPos + right * 1.5, dir * maxDist, wallRayParams))
    table.insert(hits, workspace:Raycast(hrpPos - right * 1.5, dir * maxDist, wallRayParams))
    table.insert(hits, workspace:Raycast(hrpPos + Vector3.new(0, 1.5, 0), dir * maxDist, wallRayParams))
    
    for _, hit in ipairs(hits) do
        if hit and hit.Distance - 3 < maxDist then
            maxDist = hit.Distance - 3
        end
    end
    
    for step = 5, math.floor(maxDist), 5 do
        local checkPos = hrpPos + (dir * step) + Vector3.new(0, 2, 0)
        if not workspace:Raycast(checkPos, Vector3.new(0, -500, 0), pitRayParams) then
            maxDist = math.max(0, step - 5) 
            break
        end
    end
    
    for _, t in ipairs(threats) do
        local bPos = Vector3.new(t.pos.X, hrpPos.Y, t.pos.Z)
        local toBall = bPos - hrpPos
        local dot = toBall:Dot(dir)
        
        if dot > 0 and dot < maxDist + t.threatRadius then
            local proj = hrpPos + (dir * dot)
            local distToLine = (bPos - proj).Magnitude
            local requiredClearance = t.threatRadius + PLAYER_RADIUS
            
            if distToLine < requiredClearance then
                local stopDist = dot - math.sqrt(requiredClearance^2 - distToLine^2) - 2
                if stopDist < maxDist then
                    maxDist = stopDist
                end
            end
        end
    end
    
    return math.max(0, maxDist)
end

-------------------------------------------------------------------------------
-- GAP DETECTION (for squeezing between threats)
-------------------------------------------------------------------------------
local function getMinimumGap(hrpPos, dir, threats, maxDist)
    -- Returns the smallest gap (in studs) between threats along the path direction
    local minGap = math.huge
    local playerDiameter = PLAYER_RADIUS * 2 + 1  -- plus margin
    
    -- We'll project threats onto a line perpendicular to the direction at various steps
    local right = dir:Cross(Vector3.new(0, 1, 0)).Unit
    local steps = 10
    for i = 0, steps do
        local t = i / steps * maxDist
        local pos = hrpPos + dir * t
        -- Collect lateral distances to all threats
        local lateralDists = {}
        for _, threat in ipairs(threats) do
            local toThreat = threat.pos - pos
            local lateral = toThreat:Dot(right)
            table.insert(lateralDists, lateral)
        end
        table.sort(lateralDists)
        -- Find largest gap between sorted laterals
        local largestGap = 0
        for i = 2, #lateralDists do
            local gap = lateralDists[i] - lateralDists[i-1]
            if gap > largestGap then largestGap = gap end
        end
        if largestGap < minGap then minGap = largestGap end
    end
    return minGap
end

-------------------------------------------------------------------------------
-- HIGH-PERFORMANCE 3D PREDICTION & HERDING (with gap awareness)
-------------------------------------------------------------------------------
local dodgeDirections = {}
for i = 1, 36 do
    local angle = (i / 36) * math.pi * 2
    table.insert(dodgeDirections, Vector3.new(math.cos(angle), 0, math.sin(angle)))
end

local function getBestDirection(hrpPos, playerVelY, threats, isRoaming, currentDir, wallRayParams, pitRayParams)
    local bestDir = Vector3.zero
    local lowestCost = math.huge
    local highestDangerEncountered = 0
    
    local speedToUse = isRoaming and ROAM_SPEED or DODGE_SPEED
    local timeSteps = {0.1, 0.3, 0.6, 0.9, 1.2, 1.5} 

    local threatVector = Vector3.zero
    local threatCenter = Vector3.zero
    local threatCount = 0
    local validThreats = {}
    
    for _, t in ipairs(threats) do
        local toBall = t.pos - hrpPos
        local dist = toBall.Magnitude
        if dist < MAX_THREAT_EVAL_DIST then
            table.insert(validThreats, t)
            threatCenter = threatCenter + t.pos
            threatCount = threatCount + 1
            if dist > 0.1 then
                threatVector = threatVector + (toBall.Unit / (dist * dist))
            end
        end
    end
    
    if threatVector.Magnitude > 0 then
        threatVector = threatVector.Unit
    end

    local futureThreatPositions = {}
    for _, tStep in ipairs(timeSteps) do
        futureThreatPositions[tStep] = {}
        for i, t in ipairs(validThreats) do
            if t.isStatic then
                futureThreatPositions[tStep][i] = t.pos
            else
                futureThreatPositions[tStep][i] = t.pos + (t.vel * tStep)
            end
        end
    end

    for _, dir in ipairs(dodgeDirections) do
        local availableDist = WALL_CHECK_DIST
        local right = dir:Cross(Vector3.new(0, 1, 0)).Unit
        
        local hits = {}
        table.insert(hits, workspace:Raycast(hrpPos, dir * WALL_CHECK_DIST, wallRayParams))
        table.insert(hits, workspace:Raycast(hrpPos + right * 1.5, dir * WALL_CHECK_DIST, wallRayParams))
        table.insert(hits, workspace:Raycast(hrpPos - right * 1.5, dir * WALL_CHECK_DIST, wallRayParams))
        table.insert(hits, workspace:Raycast(hrpPos + Vector3.new(0, 1.5, 0), dir * WALL_CHECK_DIST, wallRayParams))
        
        for _, hit in ipairs(hits) do
            if hit and hit.Distance < availableDist then 
                availableDist = hit.Distance 
            end
        end
        
        for step = 5, math.floor(availableDist), 5 do
            local checkPos = hrpPos + dir * step + Vector3.new(0, 2, 0)
            if not workspace:Raycast(checkPos, Vector3.new(0, -500, 0), pitRayParams) then
                availableDist = step - 5 
                break
            end
        end
        
        if availableDist < 2.5 then continue end 
        
        -- GAP EVALUATION
        local gap = getMinimumGap(hrpPos, dir, validThreats, math.min(availableDist, 30))
        local gapBonus = 0
        if gap > PLAYER_RADIUS * 2 + 1 then
            -- This direction is viable for squeezing
            gapBonus = -5000  -- large bonus to encourage squeezing
        end
        
        local dangerScore = 0
        local maxTestDist = math.min(20, availableDist - 1)
        
        for _, tStep in ipairs(timeSteps) do
            local expectedTravel = math.min(speedToUse * tStep, maxTestDist)
            local futurePlayerPos = hrpPos + (dir * expectedTravel) + Vector3.new(0, playerVelY * tStep, 0)
            
            for i, t in ipairs(validThreats) do
                local futureThreatPos = futureThreatPositions[tStep][i]
                local rawDist = (futurePlayerPos - futureThreatPos).Magnitude
                local effectiveDist = math.max(0.1, rawDist - PLAYER_RADIUS)
                
                if effectiveDist < t.threatRadius then
                    dangerScore = dangerScore + (50000 / effectiveDist) 
                elseif effectiveDist < t.threatRadius + 5 then
                    dangerScore = dangerScore + (10000 / effectiveDist) 
                else
                    dangerScore = dangerScore + (500 / (effectiveDist * effectiveDist))
                end
            end
        end
        
        local spaceScore
        if availableDist < 40 then
            spaceScore = ((40 - availableDist) ^ 3) * 50
        else
            spaceScore = -availableDist * 10
        end
        
        local cachePenalty = 0
        if #wallCache > 0 then
            local testPos = hrpPos + dir * 15
            for _, entry in ipairs(wallCache) do
                local distToWall = (testPos - entry.pos).Magnitude
                if distToWall < 10 then
                    cachePenalty = cachePenalty + (10 - distToWall) * 500
                end
            end
        end
        
        local momentumScore = 0
        if currentDir and currentDir.Magnitude > 0.1 then
            momentumScore = - (dir:Dot(currentDir) * 800) 
        end
        
        local clusterScore = 0
        if threatVector.Magnitude > 0 then
            clusterScore = (dir:Dot(threatVector) * 1000) 
        end
        
        local herdScore = 0
        if threatCount > 0 then
            local centerOfMass = threatCenter / threatCount
            local toCenter = (centerOfMass - hrpPos)
            local toCenter2D = Vector3.new(toCenter.X, 0, toCenter.Z)
            
            if toCenter2D.Magnitude > 15 then
                toCenter2D = toCenter2D.Unit
                local tangent1 = Vector3.new(-toCenter2D.Z, 0, toCenter2D.X)
                local tangent2 = Vector3.new(toCenter2D.Z, 0, -toCenter2D.X)
                local bestTangent = tangent1
                if currentDir and currentDir:Dot(tangent2) > currentDir:Dot(tangent1) then
                    bestTangent = tangent2
                end
                herdScore = - (dir:Dot(bestTangent) * 2000) 
            else
                herdScore = (dir:Dot(toCenter2D.Unit) * 1500) 
            end
        end
        
        local totalCost = dangerScore + spaceScore + cachePenalty + momentumScore + clusterScore + herdScore + gapBonus
        
        if dangerScore > highestDangerEncountered then
            highestDangerEncountered = dangerScore
        end
        
        if totalCost < lowestCost then
            lowestCost = totalCost
            bestDir = dir
        end
    end
    
    return bestDir, lowestCost, highestDangerEncountered
end


local function getHRP()
    local char = player.Character
    if char then
        return char:FindFirstChild("HumanoidRootPart"), char:FindFirstChild("Humanoid")
    end
    return nil, nil
end

local function distToSegment(p, a, b)
    local ab = b - a
    local ap = p - a
    if ab:Dot(ab) == 0 then return ap.Magnitude end
    local t = math.clamp(ap:Dot(ab) / ab:Dot(ab), 0, 1)
    local c = a + t * ab
    return (p - c).Magnitude
end

local function applyPush(hrp, direction, useForceY, yVelocity, speed, lookDir)
    local attachment = hrp:FindFirstChild("AutoDodgeAttachment")
    local linVel = hrp:FindFirstChild("AutoDodgeVelocity")
    local alignOri = hrp:FindFirstChild("AutoDodgeOrientation")
    
    if not attachment then
        attachment = Instance.new("Attachment")
        attachment.Name = "AutoDodgeAttachment"
        attachment.Parent = hrp
    end
    if not linVel then
        linVel = Instance.new("LinearVelocity")
        linVel.Name = "AutoDodgeVelocity"
        linVel.Attachment0 = attachment
        linVel.ForceLimitMode = Enum.ForceLimitMode.PerAxis
        linVel.VelocityConstraintMode = Enum.VelocityConstraintMode.Vector
        linVel.RelativeTo = Enum.ActuatorRelativeTo.World
        linVel.Parent = hrp
    end
    if not alignOri then
        alignOri = Instance.new("AlignOrientation")
        alignOri.Name = "AutoDodgeOrientation"
        alignOri.Mode = Enum.OrientationAlignmentMode.OneAttachment
        alignOri.Attachment0 = attachment
        alignOri.MaxTorque = 1000000
        alignOri.MaxAngularVelocity = 50
        alignOri.Responsiveness = 40
        alignOri.Parent = hrp
    end
    
    if useForceY then
        linVel.MaxAxesForce = Vector3.new(500000, 500000, 500000) 
    else
        linVel.MaxAxesForce = Vector3.new(500000, 0, 500000) 
    end
    
    if direction == Vector3.zero and not useForceY then
        linVel.Enabled = false
        if lookDir and lookDir.Magnitude > 0.1 then
            alignOri.CFrame = CFrame.lookAt(Vector3.zero, lookDir)
        else
            alignOri.CFrame = CFrame.lookAt(Vector3.zero, Vector3.new(hrp.CFrame.LookVector.X, 0, hrp.CFrame.LookVector.Z))
        end
    else
        local flatDir = Vector3.new(direction.X, 0, direction.Z).Unit
        if flatDir.Magnitude ~= flatDir.Magnitude then flatDir = Vector3.zero end 
        
        local targetVel = flatDir * speed
        
        if useForceY then
            targetVel = Vector3.new(targetVel.X, yVelocity, targetVel.Z)
        else
            targetVel = Vector3.new(targetVel.X, 0, targetVel.Z)
        end
        
        linVel.VectorVelocity = targetVel
        linVel.Enabled = true
        
        -- Prioritize looking at the threat, otherwise look where we are going
        if lookDir and lookDir.Magnitude > 0.1 then
            alignOri.CFrame = CFrame.lookAt(Vector3.zero, lookDir)
        elseif flatDir.Magnitude > 0.1 then
            alignOri.CFrame = CFrame.lookAt(Vector3.zero, flatDir)
        end
    end
end

local dodgeDirections = {}
for i = 1, 24 do
    local angle = (i / 24) * math.pi * 2
    table.insert(dodgeDirections, Vector3.new(math.cos(angle), 0, math.sin(angle)))
end

local function getBestDirection(hrpPos, threats, isRoaming)
    local bestDir = Vector3.zero
    local lowestDanger = math.huge
    
    local hrpPos2D = Vector3.new(hrpPos.X, 0, hrpPos.Z)
    
    local raycastParams = RaycastParams.new()
    raycastParams.FilterType = Enum.RaycastFilterType.Exclude
    local ignoreList = {player.Character, espFolder}
    for _, t in ipairs(threats) do table.insert(ignoreList, t.instance) end
    raycastParams.FilterDescendantsInstances = ignoreList
    
    for _, dir in ipairs(dodgeDirections) do
        local availableDist = WALL_CHECK_DIST
        local right = Vector3.new(0, 1, 0):Cross(dir).Unit
        
        local hits = {}
        table.insert(hits, workspace:Raycast(hrpPos, dir * WALL_CHECK_DIST, raycastParams))
        table.insert(hits, workspace:Raycast(hrpPos + right * 1.5, dir * WALL_CHECK_DIST, raycastParams))
        table.insert(hits, workspace:Raycast(hrpPos - right * 1.5, dir * WALL_CHECK_DIST, raycastParams))
        
        for _, hit in ipairs(hits) do
            if hit then
                local dist = (hit.Position - hrpPos).Magnitude
                if dist < availableDist then availableDist = dist end
            end
        end
        
        for step = 4, math.floor(availableDist), 4 do
            local checkPos = hrpPos + dir * step + Vector3.new(0, 2, 0)
            local floorHit = workspace:Raycast(checkPos, Vector3.new(0, -15, 0), raycastParams)
            if not floorHit then
                availableDist = step - 2 
                break
            end
        end
        
        if availableDist < 2 then continue end 
        
        local dangerScore = 0
        
        if availableDist < 3.5 then
            dangerScore = dangerScore + 1000000 
        else
            dangerScore = dangerScore + (2000 / availableDist) 
        end
        
        local maxTestDist = math.min(12, availableDist - 1)
        local timeSteps = isRoaming and {0.5, 1.0} or {0.2, 0.5, 0.9}
        local speedToUse = isRoaming and ROAM_SPEED or DODGE_SPEED
        
        for _, tStep in ipairs(timeSteps) do
            local expectedTravel = math.min(speedToUse * tStep, maxTestDist)
            local futurePlayerPos = hrpPos2D + (dir * expectedTravel)
            
            for _, t in ipairs(threats) do
                local futureThreatPos
                if t.isStatic then
                    futureThreatPos = Vector3.new(t.pos.X, 0, t.pos.Z)
                else
                    local bPos2D = Vector3.new(t.pos.X, 0, t.pos.Z)
                    local bVel2D = Vector3.new(t.vel.X, 0, t.vel.Z)
                    futureThreatPos = bPos2D + (bVel2D * tStep)
                end
                
                local rawDist = (futurePlayerPos - futureThreatPos).Magnitude
                local effectiveDist = math.max(0.1, rawDist - PLAYER_RADIUS)
                
                if isRoaming then
                    dangerScore = dangerScore + (100 / effectiveDist)
                else
                    if effectiveDist < t.threatRadius then
                        dangerScore = dangerScore + (5000 / effectiveDist)
                    else
                        dangerScore = dangerScore + (100 / (effectiveDist * effectiveDist))
                    end
                end
            end
        end
        
        if dangerScore < lowestDanger then
            lowestDanger = dangerScore
            bestDir = dir
        end
    end
    
    return bestDir, lowestDanger
end


-------------------------------------------------------------------------------
-- WALL CACHE (for remembering obstacle positions)
-------------------------------------------------------------------------------
local wallCache = {}
local WALL_CACHE_MAX = 30
local WALL_CACHE_LIFETIME = 30 -- seconds

local function addWallToCache(position)
    local now = tick()
    for i = #wallCache, 1, -1 do
        if now - wallCache[i].time > WALL_CACHE_LIFETIME then
            table.remove(wallCache, i)
        end
    end
    for _, entry in ipairs(wallCache) do
        if (entry.pos - position).Magnitude < 5 then
            entry.time = now
            return
        end
    end
    table.insert(wallCache, { pos = position, time = now })
    if #wallCache > WALL_CACHE_MAX then
        table.remove(wallCache, 1)
    end
end


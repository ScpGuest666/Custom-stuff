local function createESP(hazard, hType, isExtreme)
    local esp = {}
    local billboard = Instance.new("BillboardGui")
    billboard.Name = "HazardESP"
    billboard.Adornee = hazard
    billboard.Size = UDim2.new(3.5, 0, 3.5, 0) 
    billboard.AlwaysOnTop = true
    
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(1, 0, 1, 0)
    
    local espColor = hazard.Color
    if hType == "Banana" then espColor = Color3.new(1, 1, 0) end
    if isExtreme then espColor = Color3.new(1, 0, 0) end 
    
    frame.BackgroundColor3 = espColor
    frame.BackgroundTransparency = 0.2
    
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(1, 0)
    corner.Parent = frame
    
    local stroke = Instance.new("UIStroke")
    stroke.Color = Color3.new(1, 1, 1)
    stroke.Thickness = 2
    stroke.Parent = frame
    
    frame.Parent = billboard
    billboard.Parent = espFolder
    esp.billboard = billboard
    esp.frame = frame
    
    local hl = Instance.new("Highlight")
    hl.Adornee = hazard
    hl.FillColor = espColor
    hl.OutlineColor = Color3.new(1, 1, 1)
    hl.FillTransparency = 0.5
    hl.Parent = espFolder
    esp.highlight = hl
    
    return esp
end

-------------------------------------------------------------------------------
-- AUTO-DODGE & ENDGAME PREDICTION MATH
-------------------------------------------------------------------------------
local function getHRP()
    local char = player.Character
    if char then
        return char:FindFirstChild("HumanoidRootPart"), char:FindFirstChild("Humanoid")
    end
    return nil, nil
end

local function applyPush(hrp, direction, useForceY, yVelocity)
    local attachment = hrp:FindFirstChild("AutoDodgeAttachment")
    local linVel = hrp:FindFirstChild("AutoDodgeVelocity")
    
    if not attachment then
        attachment = Instance.new("Attachment")
        attachment.Name = "AutoDodgeAttachment"
        attachment.Parent = hrp
    end
    if not linVel then
        linVel = Instance.new("LinearVelocity")
        linVel.Name = "AutoDodgeVelocity"
        linVel.Attachment0 = attachment
        linVel.ForceLimitMode = Enum.ForceLimitMode.PerAxis
        linVel.VelocityConstraintMode = Enum.VelocityConstraintMode.Vector
        linVel.RelativeTo = Enum.ActuatorRelativeTo.World
        linVel.Parent = hrp
    end
    
    if useForceY then
        linVel.MaxAxesForce = Vector3.new(500000, 500000, 500000) 
    else
        linVel.MaxAxesForce = Vector3.new(500000, 0, 500000) 
    end
    
    if direction == Vector3.zero and not useForceY then
        linVel.Enabled = false
    else
        local flatDir = Vector3.new(direction.X, 0, direction.Z).Unit
        if flatDir.Magnitude ~= flatDir.Magnitude then flatDir = Vector3.zero end 
        
        local targetVel = flatDir * DODGE_SPEED
        
        if useForceY then
            targetVel = Vector3.new(targetVel.X, yVelocity, targetVel.Z)
        else
            targetVel = Vector3.new(targetVel.X, 0, targetVel.Z)
        end
        
        linVel.VectorVelocity = targetVel
        linVel.Enabled = true
    end
end

local dodgeDirections = {}
for i = 1, 24 do
    local angle = (i / 24) * math.pi * 2
    table.insert(dodgeDirections, Vector3.new(math.cos(angle), 0, math.sin(angle)))
end

local function getBestDodgeDirection(hrpPos, threats)
    local bestDir = Vector3.zero
    local lowestDanger = math.huge
    
    local hrpPos2D = Vector3.new(hrpPos.X, 0, hrpPos.Z)
    
    local raycastParams = RaycastParams.new()
    raycastParams.FilterType = Enum.RaycastFilterType.Exclude
    local ignoreList = {player.Character, espFolder}
    for _, t in ipairs(threats) do table.insert(ignoreList, t.instance) end
    raycastParams.FilterDescendantsInstances = ignoreList
    
    for _, dir in ipairs(dodgeDirections) do
        local availableDist = WALL_CHECK_DIST
        local right = Vector3.new(0, 1, 0):Cross(dir).Unit
        
        -- 360-DEGREE WIDE RAYCAST
        local hits = {}
        table.insert(hits, workspace:Raycast(hrpPos, dir * WALL_CHECK_DIST, raycastParams))
        table.insert(hits, workspace:Raycast(hrpPos + right * 1.5, dir * WALL_CHECK_DIST, raycastParams))
        table.insert(hits, workspace:Raycast(hrpPos - right * 1.5, dir * WALL_CHECK_DIST, raycastParams))
        
        for _, hit in ipairs(hits) do
            if hit then
                local dist = (hit.Position - hrpPos).Magnitude
                if dist < availableDist then availableDist = dist end
            end
        end
        
        -- FLOOR CHECK
        for step = 4, math.floor(availableDist), 4 do
            local checkPos = hrpPos + dir * step + Vector3.new(0, 2, 0)
            local floorHit = workspace:Raycast(checkPos, Vector3.new(0, -15, 0), raycastParams)
            if not floorHit then
                availableDist = step - 2 
                break
            end
        end
        
        if availableDist < 2 then continue end 
        
        local dangerScore = 0
        local maxTestDist = math.min(12, availableDist - 1)
        
        -- SIMULATE THE FUTURE: Check 0.2s, 0.5s, and 0.9s ahead
        local timeSteps = {0.2, 0.5, 0.9}
        
        for _, tStep in ipairs(timeSteps) do
            local expectedTravel = math.min(DODGE_SPEED * tStep, maxTestDist)
            local futurePlayerPos = hrpPos2D + (dir * expectedTravel)
            
            for _, t in ipairs(threats) do
                local futureThreatPos
                if t.isStatic then
                    futureThreatPos = Vector3.new(t.pos.X, 0, t.pos.Z)
                else
                    local bPos2D = Vector3.new(t.pos.X, 0, t.pos.Z)
                    local bVel2D = Vector3.new(t.vel.X, 0, t.vel.Z)
                    futureThreatPos = bPos2D + (bVel2D * tStep)
                end
                
                local dist = (futurePlayerPos - futureThreatPos).Magnitude
                
                if dist < t.threatRadius then
                    dangerScore = dangerScore + (5000 / math.max(0.1, dist))
                else
                    dangerScore = dangerScore + (100 / (dist * dist))
                end
            end
        end
        
        dangerScore = dangerScore + (50 / math.max(0.1, availableDist))
        
        if dangerScore < lowestDanger then
            lowestDanger = dangerScore
            bestDir = dir
        end
    end
    
    return bestDir, lowestDanger
end

-------------------------------------------------------------------------------
-- MAIN LOOP
-------------------------------------------------------------------------------
local function setOnline()
    if mainLoopConnection then return end
    status.Text = "Status: Online"
    status.TextColor3 = Color3.fromRGB(0, 255, 0)
    
    mainLoopConnection = RunService.Heartbeat:Connect(function(dt)
        local hrp, humanoid = getHRP()
        local hrpPos = hrp and hrp.Position or Vector3.zero
        local hrpPos2D = Vector3.new(hrpPos.X, 0, hrpPos.Z)
        
        local activeThreats = {}
        local currentTracked = {}
        
        for hazard, hType in pairs(activeHazards) do
            if hazard.Parent and not hazard:FindFirstAncestorWhichIsA("Tool") then
                local currentPos = hazard.Position
                local data = hazardData[hazard] or { lastPos = currentPos, velocity = Vector3.zero, lastVel = Vector3.zero }
                
                local vel = (currentPos - data.lastPos) / dt
                if vel.Magnitude > 1000 then vel = Vector3.zero end
                
                local speed = vel.Magnitude
                local lastVel = data.lastVel
                
                local isTurning = false
                if speed > 30 and lastVel.Magnitude > 30 then
                    if vel.Unit:Dot(lastVel.Unit) < 0.9 then isTurning = true end
                end
                
                data.lastVel = vel
                data.velocity = vel
                data.lastPos = currentPos
                hazardData[hazard] = data
                
                local distToPlayer = (hrpPos - currentPos).Magnitude
                
                if hType == "Banana" then
                    if distToPlayer < 25 then 
                        table.insert(activeThreats, { 
                            instance = hazard, pos = currentPos, vel = Vector3.zero, 
                            isStatic = true, isExtreme = false, threatRadius = BANANA_DISTANCE, type = "Banana"
                        })
                        currentTracked[hazard] = true
                        if not espObjects[hazard] then espObjects[hazard] = createESP(hazard, hType, false) end
                    end
                elseif hType == "Ball" or hType == "GoldenBall" then
                    local isMoving = speed > 5
                    local isGolden = (hType == "GoldenBall")
                    local isExtreme = (isGolden and speed > 40) or (isTurning and speed > 40) or (speed > 85)
                    
                    local dynamicRadius = THREAT_DISTANCE
                    if isMoving then
                        dynamicRadius = math.clamp(speed * 0.35, THREAT_DISTANCE, 35)
                        if isExtreme then
                            dynamicRadius = math.clamp(speed * 0.5, 25, 50) 
                        end
                    end
                    
                    local isDangerouslyClose = distToPlayer < dynamicRadius
                    
                    if isMoving or isDangerouslyClose then
                        table.insert(activeThreats, { 
                            instance = hazard, pos = currentPos, vel = vel, speed = speed,
                            isStatic = not isMoving, isExtreme = isExtreme, threatRadius = dynamicRadius, type = "Ball"
                        })
                        currentTracked[hazard] = true
                        
                        if not espObjects[hazard] then
                            espObjects[hazard] = createESP(hazard, hType, isExtreme)
                        else
                            local espColor = isExtreme and Color3.new(1, 0, 0) or hazard.Color
                            espObjects[hazard].frame.BackgroundColor3 = espColor
                            espObjects[hazard].highlight.FillColor = espColor
                        end
                    end
                end
            else
                onDescendantRemoving(hazard)
            end
        end
        
        for hazard, esp in pairs(espObjects) do
            if not currentTracked[hazard] then
                esp.billboard:Destroy()
                esp.highlight:Destroy()
                espObjects[hazard] = nil
            end
        end
        
        if hrp and humanoid and humanoid.Health > 0 then
            local groundRayParams = RaycastParams.new()
            groundRayParams.FilterType = Enum.RaycastFilterType.Exclude
            groundRayParams.FilterDescendantsInstances = {player.Character, espFolder}
            
            local groundCheck = workspace:Raycast(hrpPos, Vector3.new(0, -5, 0), groundRayParams)
            local isGrounded = groundCheck ~= nil
            
            local deepGroundCheck = workspace:Raycast(hrpPos, Vector3.new(0, -35, 0), groundRayParams)
            if deepGroundCheck == nil then
                applyPush(hrp, Vector3.zero, false, 0)
                return
            end

            local threatsToDodge = {}
            local shouldJump = false
            
            for _, bData in ipairs(activeThreats) do
                local bPos2D = Vector3.new(bData.pos.X, 0, bData.pos.Z)
                local bVel2D = Vector3.new(bData.vel.X, 0, bData.vel.Z)
                local W2D = hrpPos2D - bPos2D
                
                if bData.isStatic or bData.isExtreme then
                    if W2D.Magnitude < bData.threatRadius then
                        table.insert(threatsToDodge, bData)
                        if bData.type == "Ball" and W2D.Magnitude < 15 and bData.pos.Y < (hrpPos.Y + 2) then 
                            shouldJump = true 
                        end
                    end
                else
                    local vSq2D = bVel2D:Dot(bVel2D)
                    if vSq2D > 0 then
                        local t = W2D:Dot(bVel2D) / vSq2D
                        if t > -0.1 and t < 1.5 then
                            local closestPoint2D = bPos2D + bVel2D * t
                            local distanceAtClosest2D = (hrpPos2D - closestPoint2D).Magnitude
                            
                            if distanceAtClosest2D < bData.threatRadius then
                                table.insert(threatsToDodge, bData)
                                if bData.type == "Ball" and distanceAtClosest2D < 5 and t < 0.6 and bData.pos.Y < (hrpPos.Y + 1.5) then
                                    shouldJump = true
                                end
                            end
                        end
                    end
                end
            end
            
            local safeDirection = Vector3.zero
            local dangerLevel = 0
            
            if #threatsToDodge > 0 then
                safeDirection, dangerLevel = getBestDodgeDirection(hrpPos, threatsToDodge)
                if dangerLevel > 3000 then
                    shouldJump = true
                end
            end
            
            if shouldJump and isGrounded and jumpState == "None" and (tick() - lastJumpTime > 0.6) then
                jumpState = "Up"
                jumpTimer = tick()
                lastJumpTime = tick()
            end
            
            local useForceY = false
            local currentYVel = 0
            
            if jumpState == "Up" then
                useForceY = true
                currentYVel = JUMP_UP_SPEED
                if tick() - jumpTimer > 0.25 then 
                    jumpState = "Down"
                    jumpTimer = tick()
                end
            elseif jumpState == "Down" then
                useForceY = true
                currentYVel = JUMP_DOWN_SPEED
                if tick() - jumpTimer > 0.2 or (isGrounded and tick() - jumpTimer > 0.05) then
                    jumpState = "None"
                end
            end
            
            if #threatsToDodge > 0 then
                applyPush(hrp, safeDirection, useForceY, currentYVel)
            else
                if jumpState ~= "None" then
                    applyPush(hrp, Vector3.zero, useForceY, currentYVel)
                else
                    applyPush(hrp, Vector3.zero, false, 0)
                end
            end
        end
    end)
end

local function setOffline()
    status.Text = "Status: Offline"
    status.TextColor3 = Color3.fromRGB(255, 0, 0)
    
    if mainLoopConnection then
        mainLoopConnection:Disconnect()
        mainLoopConnection = nil
    end
    
    local hrp = getHRP()
    if hrp then applyPush(hrp, Vector3.zero, false, 0) end
    
    for _, esp in pairs(espObjects) do
        esp.billboard:Destroy()
        esp.highlight:Destroy()
    end
    table.clear(espObjects)
end


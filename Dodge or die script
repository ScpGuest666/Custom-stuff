local function getHazardType(obj)
    if not obj:IsA("BasePart") then return nil end
    if obj.Name == "HumanoidRootPart" then return nil end
    local model = obj:FindFirstAncestorOfClass("Model")
    if model and model:FindFirstChildOfClass("Humanoid") then return nil end
    if obj:FindFirstAncestorWhichIsA("Tool") then return nil end
    
    local name = string.lower(obj.Name)
    if string.find(name, "banana") or string.find(name, "peel") or name == "bananamodel" then return "Banana" end
    if obj:IsA("MeshPart") and obj.MeshId and string.find(string.lower(obj.MeshId), "banana") then return "Banana" end
    
    local isBall = false
    if obj:IsA("Part") and obj.Shape == Enum.PartType.Ball then isBall = true
    elseif string.find(name, "ball") then isBall = true end
    
    if isBall then
        local size = obj.Size
        local maxDim = math.max(size.X, size.Y, size.Z)
        local minDim = math.min(size.X, size.Y, size.Z)
        if maxDim > 20 or maxDim / (minDim + 0.001) > 4 then return nil end
        local c = obj.Color
        if c.R > 0.6 and c.G > 0.5 and c.B < 0.4 then return "GoldenBall" end
        return "Ball"
    end
    return nil
end

local function onDescendantAdded(obj)

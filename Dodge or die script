local wallEspConnection = nil

local function isWall(obj)
    if not obj:IsA("BasePart") then return false end
    local name = string.lower(obj.Name)
    if string.find(name, "wall") or string.find(name, "barrier") or string.find(name, "boundary") or string.find(name, "border") or string.find(name, "clip") then
        return true
    end
    if obj.Transparency == 1 then
        if obj.Size.X > 25 or obj.Size.Y > 25 or obj.Size.Z > 25 then
            return true
        end
    end
    return false
end

local function highlightWall(obj)
    if isWall(obj) and not obj:FindFirstChild("WallESP_Box") then
        local box = Instance.new("SelectionBox")
        box.Name = "WallESP_Box"
        box.Adornee = obj
        box.LineThickness = 0.1
        box.Color3 = Color3.fromRGB(0, 0, 0)
        box.SurfaceColor3 = Color3.fromRGB(255, 255, 0)
        box.SurfaceTransparency = 0.6
        box.Parent = obj
    end
end

local function removeWallHighlights()
    for _, obj in ipairs(workspace:GetDescendants()) do
        local box = obj:FindFirstChild("WallESP_Box")
        if box and box:IsA("SelectionBox") then
            box:Destroy()
        end
    end
end

local function scanAndCacheWalls()
    for _, obj in ipairs(workspace:GetDescendants()) do
        if isWall(obj) then
            addWallToCache(obj.Position)
            highlightWall(obj)
        end
    end
end

local function startWallESP()
    scanAndCacheWalls()
    if not wallEspConnection then
        wallEspConnection = workspace.DescendantAdded:Connect(function(newObj)
            task.defer(function()
                if isWall(newObj) then
                    addWallToCache(newObj.Position)
                    highlightWall(newObj)
                end
            end)
        end)
    end
end

local function stopWallESP()
    if wallEspConnection then
        wallEspConnection:Disconnect()
        wallEspConnection = nil
    end
    removeWallHighlights()
end


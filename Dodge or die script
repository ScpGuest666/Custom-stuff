-------------------------------------------------------------------------------
-- STRICT HAZARD DETECTION SYSTEM
-------------------------------------------------------------------------------
local activeHazards = {}
local hazardData = {} 
local espObjects = {}
local mainLoopConnection = nil

local jumpState = "None"
local jumpTimer = 0
local lastJumpTime = 0 

local function getHazardType(obj)
    if not obj:IsA("BasePart") then return nil end
    if obj.Name == "HumanoidRootPart" then return nil end
    
    local model = obj:FindFirstAncestorOfClass("Model")
    if model and model:FindFirstChildOfClass("Humanoid") then return nil end
    if obj:FindFirstAncestorWhichIsA("Tool") then return nil end
    
    local name = string.lower(obj.Name)
    
    -- 1. Banana Check
    if string.find(name, "banana") or string.find(name, "peel") or name == "bananamodel" then 
        return "Banana" 
    end
    if obj:IsA("MeshPart") and obj.MeshId and string.find(string.lower(obj.MeshId), "banana") then 
        return "Banana" 
    end
    
    -- 2. Strict Ball Check
    local isBall = false
    
    -- If it's physically a sphere
    if obj:IsA("Part") and obj.Shape == Enum.PartType.Ball then
        isBall = true
    -- Or if it explicitly has "ball" in the name
    elseif string.find(name, "ball") then
        isBall = true
    end
    
    if isBall then
        local size = obj.Size
        local maxDim = math.max(size.X, size.Y, size.Z)
        local minDim = math.min(size.X, size.Y, size.Z)
        
        -- Filter out massive objects (like skyboxes or map boundaries named "ball")
        if maxDim > 20 then return nil end
        
        -- Filter out flat objects (like the lobby pads in your screenshots)
        -- A real ball has roughly equal dimensions. A flat pad has a huge maxDim compared to minDim.
        if maxDim / (minDim + 0.001) > 4 then return nil end
        
        -- Check for Golden Ball
        local c = obj.Color
        if c.R > 0.6 and c.G > 0.5 and c.B < 0.4 then
            return "GoldenBall"
        end
        
        return "Ball"
    end

    -- FIX: Return nil by default so random lobby parts are ignored!
    return nil
end

local function onDescendantAdded(obj)
    pcall(function()
        local hType = getHazardType(obj)
        if hType then
            activeHazards[obj] = hType
            hazardData[obj] = { lastPos = obj.Position, velocity = Vector3.zero, lastVel = Vector3.zero }
        end
    end)
end

local function onDescendantRemoving(obj)
    if activeHazards[obj] then
        activeHazards[obj] = nil
        hazardData[obj] = nil
        if espObjects[obj] then
            espObjects[obj].billboard:Destroy()
            espObjects[obj].highlight:Destroy()
            espObjects[obj] = nil
        end
    end
end

task.spawn(function()
    for _, obj in ipairs(workspace:GetDescendants()) do
        onDescendantAdded(obj)
    end
end)

local addedConn = workspace.DescendantAdded:Connect(onDescendantAdded)
local removingConn = workspace.DescendantRemoving:Connect(onDescendantRemoving)


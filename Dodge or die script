local function simulateTouch(isRight)
    local x = isRight and RIGHT_DASH_X or LEFT_DASH_X
    local y = isRight and RIGHT_DASH_Y or LEFT_DASH_Y
    local touchId = isRight and TOUCH_ID_RIGHT or TOUCH_ID_LEFT
    
    if isRight then lastRightClickX, lastRightClickY = x, y
    else lastLeftClickX, lastLeftClickY = x, y end

    task.spawn(function()
        pcall(function()
            vim:SendTouchEvent(touchId, 0, x, y) 
            task.wait(0.05)
            vim:SendTouchEvent(touchId, 1, x, y) 
            task.wait(0.05)
            vim:SendTouchEvent(touchId, 2, x, y) 
        end)
    end)
end

local function simulateRoll()

local function getHRP()
    local char = player.Character
    if char then return char:FindFirstChild("HumanoidRootPart"), char:FindFirstChild("Humanoid") end
    return nil, nil
end

local function get1v1Opponent(myHrpPos)
    local aliveOpponents = {}
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= player then
            local char = p.Character
            if char then
                local hrp = char:FindFirstChild("HumanoidRootPart")
                local hum = char:FindFirstChild("Humanoid")
                if hrp and hum and hum.Health > 0 then
                    if math.abs(hrp.Position.Y - myHrpPos.Y) < 50 and (hrp.Position - myHrpPos).Magnitude < 400 then
                        table.insert(aliveOpponents, hrp)
                    end
                end
            end
        end
    end
    if #aliveOpponents == 1 then return aliveOpponents[1] end
    return nil
end

local function applyPush(hrp, direction, useForceY, yVelocity, speed, lookDir)
    local attachment = hrp:FindFirstChild("AutoDodgeAttachment")
    local linVel = hrp:FindFirstChild("AutoDodgeVelocity")
    local alignOri = hrp:FindFirstChild("AutoDodgeOrientation")
    
    if not attachment then
        attachment = Instance.new("Attachment")
        attachment.Name = "AutoDodgeAttachment"
        attachment.Parent = hrp
    end
    if not linVel then
        linVel = Instance.new("LinearVelocity")
        linVel.Name = "AutoDodgeVelocity"
        linVel.Attachment0 = attachment
        linVel.ForceLimitMode = Enum.ForceLimitMode.PerAxis
        linVel.VelocityConstraintMode = Enum.VelocityConstraintMode.Vector
        linVel.RelativeTo = Enum.ActuatorRelativeTo.World
        linVel.Parent = hrp
    end
    if not alignOri then
        alignOri = Instance.new("AlignOrientation")
        alignOri.Name = "AutoDodgeOrientation"
        alignOri.Mode = Enum.OrientationAlignmentMode.OneAttachment
        alignOri.Attachment0 = attachment
        alignOri.MaxTorque = 1000000
        alignOri.MaxAngularVelocity = 50
        alignOri.Responsiveness = 40
        alignOri.Parent = hrp
    end
    
    if useForceY then
        linVel.MaxAxesForce = Vector3.new(500000, 500000, 500000) 
    else
        linVel.MaxAxesForce = Vector3.new(500000, 0, 500000) 
    end
    
    -- FIX: Properly disable AlignOrientation when not forcing movement
    if direction == Vector3.zero and not useForceY then
        linVel.Enabled = false
        alignOri.Enabled = false
    else
        local flatDir = Vector3.new(direction.X, 0, direction.Z).Unit
        if flatDir.Magnitude ~= flatDir.Magnitude then flatDir = Vector3.zero end 
        
        local targetVel = flatDir * speed
        if useForceY then targetVel = Vector3.new(targetVel.X, yVelocity, targetVel.Z)
        else targetVel = Vector3.new(targetVel.X, 0, targetVel.Z) end
        
        linVel.VectorVelocity = targetVel
        linVel.Enabled = true
        
        if lookDir and lookDir.Magnitude > 0.1 then
            alignOri.CFrame = CFrame.lookAt(Vector3.zero, lookDir)
            alignOri.Enabled = true
        elseif flatDir.Magnitude > 0.1 then
            alignOri.CFrame = CFrame.lookAt(Vector3.zero, flatDir)
            alignOri.Enabled = true
        else
            alignOri.Enabled = false
        end
    end
end

-------------------------------------------------------------------------------
-- DYNAMIC BURST DISTANCE CALCULATOR (ANTI-WALL COLLISION)
-------------------------------------------------------------------------------
local function getSafeBurstDistance(hrpPos, dir, threats, rayParams)
    local maxDist = MAX_BURST_DIST
    
    local right = dir:Cross(Vector3.new(0, 1, 0)).Unit
    local hits = {}
    table.insert(hits, workspace:Raycast(hrpPos, dir * maxDist, rayParams))
    table.insert(hits, workspace:Raycast(hrpPos + right * 3, dir * maxDist, rayParams))
    table.insert(hits, workspace:Raycast(hrpPos - right * 3, dir * maxDist, rayParams))
    table.insert(hits, workspace:Raycast(hrpPos + right * 6, dir * maxDist, rayParams))
    table.insert(hits, workspace:Raycast(hrpPos - right * 6, dir * maxDist, rayParams))
    
    for _, hit in ipairs(hits) do
        if hit and hit.Distance - 4 < maxDist then
            maxDist = hit.Distance - 4
        end
    end
    
    for step = 5, math.floor(maxDist), 5 do
        local checkPos = hrpPos + (dir * step) + Vector3.new(0, 2, 0)
        if not workspace:Raycast(checkPos, Vector3.new(0, -15, 0), rayParams) then
            maxDist = step - 3
            break
        end
    end
    
    for _, t in ipairs(threats) do
        local bPos = Vector3.new(t.pos.X, hrpPos.Y, t.pos.Z)
        local toBall = bPos - hrpPos
        local dot = toBall:Dot(dir)
        
        if dot > 0 and dot < maxDist + t.threatRadius then
            local proj = hrpPos + (dir * dot)
            local distToLine = (bPos - proj).Magnitude
            local requiredClearance = t.threatRadius + PLAYER_RADIUS
            
            if distToLine < requiredClearance then
                local stopDist = dot - math.sqrt(requiredClearance^2 - distToLine^2) - 2
                if stopDist < maxDist then
                    maxDist = stopDist
                end
            end
        end
    end
    
    return math.max(0, maxDist)
end

-------------------------------------------------------------------------------
-- HERDING & KITING PREDICTION ENGINE
-------------------------------------------------------------------------------
local dodgeDirections = {}
for i = 1, 36 do
    local angle = (i / 36) * math.pi * 2
    table.insert(dodgeDirections, Vector3.new(math.cos(angle), 0, math.sin(angle)))
end

local function getBestDirection(hrpPos, threats, isRoaming, huntTargetPos, currentDir)
    local bestDir = Vector3.zero
    local lowestCost = math.huge
    local highestDangerEncountered = 0
    
    local hrpPos2D = Vector3.new(hrpPos.X, 0, hrpPos.Z)
    local raycastParams = RaycastParams.new()
    raycastParams.FilterType = Enum.RaycastFilterType.Exclude
    local ignoreList = {player.Character, espFolder}
    for _, t in ipairs(threats) do table.insert(ignoreList, t.instance) end
    raycastParams.FilterDescendantsInstances = ignoreList
    
    local speedToUse = isRoaming and ROAM_SPEED or DODGE_SPEED
    local timeSteps = {0.1, 0.3, 0.6, 0.9, 1.2, 1.5} 

    local centerOfMass = Vector3.zero
    if #threats > 0 then
        for _, t in ipairs(threats) do
            centerOfMass = centerOfMass + Vector3.new(t.pos.X, 0, t.pos.Z)
        end
        centerOfMass = centerOfMass / #threats
    end

    for _, dir in ipairs(dodgeDirections) do
        local availableDist = WALL_CHECK_DIST
        local right = dir:Cross(Vector3.new(0, 1, 0)).Unit
        
        local hits = {}
        table.insert(hits, workspace:Raycast(hrpPos, dir * WALL_CHECK_DIST, raycastParams))
        table.insert(hits, workspace:Raycast(hrpPos + right * 2.5, dir * WALL_CHECK_DIST, raycastParams))
        table.insert(hits, workspace:Raycast(hrpPos - right * 2.5, dir * WALL_CHECK_DIST, raycastParams))
        
        for _, hit in ipairs(hits) do
            if hit and (hit.Position - hrpPos).Magnitude < availableDist then 
                availableDist = (hit.Position - hrpPos).Magnitude 
            end
        end
        
        for step = 5, math.floor(availableDist), 5 do
            local checkPos = hrpPos + dir * step + Vector3.new(0, 2, 0)
            if not workspace:Raycast(checkPos, Vector3.new(0, -15, 0), raycastParams) then
                availableDist = step - 2 
                break
            end
        end
        
        if availableDist < 3 then continue end 
        
        local dangerScore = 0
        local maxTestDist = math.min(20, availableDist - 1)
        
        for _, tStep in ipairs(timeSteps) do
            local expectedTravel = math.min(speedToUse * tStep, maxTestDist)
            local futurePlayerPos = hrpPos2D + (dir * expectedTravel)
            
            for _, t in ipairs(threats) do
                local futureThreatPos
                if t.isStatic then
                    futureThreatPos = Vector3.new(t.pos.X, 0, t.pos.Z)
                else
                    local bPos2D = Vector3.new(t.pos.X, 0, t.pos.Z)
                    local bVel2D = Vector3.new(t.vel.X, 0, t.vel.Z)
                    futureThreatPos = bPos2D + (bVel2D * tStep)
                end
                
                local rawDist = (futurePlayerPos - futureThreatPos).Magnitude
                local effectiveDist = math.max(0.1, rawDist - PLAYER_RADIUS)
                
                if effectiveDist < t.threatRadius then
                    dangerScore = dangerScore + (25000 / effectiveDist) 
                else
                    dangerScore = dangerScore + (500 / (effectiveDist * effectiveDist))
                end
            end
        end
        
        local spaceScore = - (availableDist * 15) 
        
        local momentumScore = 0
        if currentDir and currentDir.Magnitude > 0.1 then
            momentumScore = - (dir:Dot(currentDir) * 400) 
        end
        
        local herdScore = 0
        if #threats > 0 then
            local toBalls = (centerOfMass - hrpPos2D).Unit
            if toBalls.Magnitude > 0 then
                herdScore = (dir:Dot(toBalls) * 600) 
            end
        end
        
        if huntTargetPos then
            local targetDir = (Vector3.new(huntTargetPos.X, 0, huntTargetPos.Z) - hrpPos2D).Unit
            herdScore = herdScore - (dir:Dot(targetDir) * 300)
        end
        
        local totalCost = dangerScore + spaceScore + momentumScore + herdScore
        
        if dangerScore > highestDangerEncountered then
            highestDangerEncountered = dangerScore
        end
        
        if totalCost < lowestCost then
            lowestCost = totalCost
            bestDir = dir
        end
    end
    
    return bestDir, lowestCost, highestDangerEncountered
end


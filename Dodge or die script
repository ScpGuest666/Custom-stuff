local function setOnline()
    if mainLoopConnection then return end
    status.Text = "Status: Online"
    status.TextColor3 = Color3.fromRGB(0, 255, 0)
    
    startWallESP()
    
    mainLoopConnection = RunService.Heartbeat:Connect(function(dt)
        local hrp, humanoid = getHRP()
        local char = player.Character
        
        if not hrp or not humanoid or humanoid.Health <= 0 then
            if hrp then lastHrpPos = hrp.Position end
            isBursting = false
            jumpState = "None"
            return
        end
        
        local hrpPos = hrp.Position
        local hrpPos2D = Vector3.new(hrpPos.X, 0, hrpPos.Z)
        local playerVelY = hrp.AssemblyLinearVelocity.Y
        
        humanoid:SetStateEnabled(Enum.HumanoidStateType.FallingDown, false)
        humanoid:SetStateEnabled(Enum.HumanoidStateType.Ragdoll, false)
        humanoid.PlatformStand = false
        humanoid.Sit = false
        if humanoid:GetState() == Enum.HumanoidStateType.FallingDown or humanoid:GetState() == Enum.HumanoidStateType.Ragdoll then
            humanoid:ChangeState(Enum.HumanoidStateType.GettingUp)
        end
        
        local groundRayParams = RaycastParams.new()
        groundRayParams.FilterType = Enum.RaycastFilterType.Exclude
        groundRayParams.FilterDescendantsInstances = {char, espFolder}
        
        local groundHit = workspace:Raycast(hrpPos, Vector3.new(0, -500, 0), groundRayParams)
        local isGrounded = workspace:Raycast(hrpPos, Vector3.new(0, -5, 0), groundRayParams) ~= nil
        local currentFloor = groundHit and groundHit.Instance or nil
        
        local activeThreats = {}
        local allHazardsList = {} 
        local currentTracked = {}
        local closestBallDist = math.huge
        
        for hazard, hType in pairs(activeHazards) do
            if hazard.Parent and not hazard:FindFirstAncestorWhichIsA("Tool") then
                local currentPos = hazard.Position
                local data = hazardData[hazard] or { lastPos = currentPos, velocity = Vector3.zero, lastVel = Vector3.zero }
                
                local realVel = hazard.AssemblyLinearVelocity
                local calcVel = (currentPos - data.lastPos) / dt
                local vel = (realVel.Magnitude > calcVel.Magnitude) and realVel or calcVel
                if vel.Magnitude > 1000 then vel = Vector3.zero end
                
                local speed = vel.Magnitude
                local lastVel = data.lastVel
                local isTurning = (speed > 30 and lastVel.Magnitude > 30 and vel.Unit:Dot(lastVel.Unit) < 0.9)
                
                data.lastVel = vel
                data.velocity = vel
                
                local distToPlayer = (hrpPos - currentPos).Magnitude
                if distToPlayer < closestBallDist then closestBallDist = distToPlayer end
                
                data.lastPos = currentPos
                hazardData[hazard] = data
                
                local hazardInfo = {
                    instance = hazard, pos = currentPos, vel = vel, speed = speed,
                    isStatic = (speed < 5), isExtreme = false, threatRadius = THREAT_DISTANCE, type = hType
                }
                table.insert(allHazardsList, hazardInfo)
                
                if hType == "Banana" then
                    if distToPlayer < 25 then 
                        hazardInfo.threatRadius = BANANA_DISTANCE
                        table.insert(activeThreats, hazardInfo)
                        currentTracked[hazard] = true
                        if not espObjects[hazard] then espObjects[hazard] = createESP(hazard, hType, false) end
                    end
                elseif hType == "Ball" or hType == "GoldenBall" then
                    local isMoving = speed > 5
                    local isExtreme = (hType == "GoldenBall" and speed > 40) or (isTurning and speed > 40) or (speed > 85)
                    
                    local dynamicRadius = THREAT_DISTANCE
                    if isMoving then
                        dynamicRadius = math.clamp(speed * 0.35, THREAT_DISTANCE, 35)
                        if isExtreme then dynamicRadius = math.clamp(speed * 0.5, 25, 50) end
                    end
                    
                    if isMoving or distToPlayer < dynamicRadius then
                        hazardInfo.isExtreme = isExtreme
                        hazardInfo.threatRadius = dynamicRadius
                        table.insert(activeThreats, hazardInfo)
                        currentTracked[hazard] = true
                        
                        if not espObjects[hazard] then espObjects[hazard] = createESP(hazard, hType, isExtreme)
                        else
                            local espColor = isExtreme and Color3.new(1, 0, 0) or hazard.Color
                            espObjects[hazard].frame.BackgroundColor3 = espColor
                            espObjects[hazard].highlight.FillColor = espColor
                        end
                    end
                end
            else
                onDescendantRemoving(hazard)
            end
        end
        
        for hazard, esp in pairs(espObjects) do
            if not currentTracked[hazard] then
                esp.billboard:Destroy()
                esp.highlight:Destroy()
                espObjects[hazard] = nil
            end
        end
        
        local pitIgnoreList = {char, espFolder}
        for _, t in ipairs(allHazardsList) do
            if t.instance then table.insert(pitIgnoreList, t.instance) end
        end
        local pitRayParams = RaycastParams.new()
        pitRayParams.FilterType = Enum.RaycastFilterType.Exclude
        pitRayParams.FilterDescendantsInstances = pitIgnoreList

        local wallIgnoreList = {char, espFolder}
        for _, t in ipairs(allHazardsList) do
            if t.instance then table.insert(wallIgnoreList, t.instance) end
        end
        local wallRayParams = RaycastParams.new()
        wallRayParams.FilterType = Enum.RaycastFilterType.Exclude
        wallRayParams.FilterDescendantsInstances = wallIgnoreList
        
        if workspace:Raycast(hrpPos, Vector3.new(0, -500, 0), groundRayParams) == nil then
            applyPush(hrp, humanoid, Vector3.zero, false, 0, 0, nil)
            return
        end

        local threatsToDodge = {}
        local primaryThreat = nil
        local minThreatDist = math.huge
        local imminentImpact = false
        
        for _, bData in ipairs(activeThreats) do
            local bPos2D = Vector3.new(bData.pos.X, 0, bData.pos.Z)
            local bVel2D = Vector3.new(bData.vel.X, 0, bData.vel.Z)
            local W2D = hrpPos2D - bPos2D
            local dist = W2D.Magnitude
            
            if dist < minThreatDist then
                minThreatDist = dist
                primaryThreat = bData
            end
            
            if bData.isStatic or bData.isExtreme then
                if dist < bData.threatRadius then
                    table.insert(threatsToDodge, bData)
                end
            else
                local vSq2D = bVel2D:Dot(bVel2D)
                if vSq2D > 0 then
                    local t = W2D:Dot(bVel2D) / vSq2D
                    if t > -0.1 and t < 1.5 then
                        local closestPoint2D = bPos2D + bVel2D * t
                        local distanceAtClosest2D = (hrpPos2D - closestPoint2D).Magnitude
                        
                        if distanceAtClosest2D < bData.threatRadius then
                            table.insert(threatsToDodge, bData)
                            if bData.type == "Ball" and distanceAtClosest2D < 5 and t < 0.3 and bData.pos.Y < (hrpPos.Y + 2) then
                                imminentImpact = true
                            end
                        end
                    end
                end
            end
        end
        
        local safeDirection = Vector3.zero
        local dangerLevel = 0
        local isRoaming = false
        local lookDirection = Vector3.zero
        local shouldJump = false
        
        -- Stuck detection
        if safeDirection ~= Vector3.zero or currentMovementDir ~= Vector3.zero then
            if lastPosition then
                local moved = (hrpPos - lastPosition).Magnitude
                if moved < 0.1 then
                    stuckCounter = stuckCounter + 1
                else
                    stuckCounter = 0
                end
            end
            lastPosition = hrpPos
        end
        
        if stuckCounter > 15 then
            local escapeDir = Vector3.new(math.random(-1,1), 0, math.random(-1,1)).Unit
            if escapeDir.Magnitude < 0.1 then escapeDir = Vector3.new(1,0,0) end
            applyPush(hrp, humanoid, escapeDir, false, 0, 20, escapeDir)
            stuckCounter = 0
            safeDirection = Vector3.zero
        else
            -- Normal movement
            if isBursting and tick() < burstEndTime then
                local newDist = getSafeBurstDistance(hrpPos, burstDir, activeThreats, wallRayParams, pitRayParams)
                if newDist < 5 then
                    isBursting = false
                    safeDirection = Vector3.zero
                else
                    burstEndTime = tick() + (newDist / DASH_SPEED)
                    safeDirection = burstDir
                    lookDirection = burstLookDir
                    shouldJump = false
                end
            else
                isBursting = false
                
                if #threatsToDodge > 0 then
                    local rawDanger
                    safeDirection, dangerLevel, rawDanger = getBestDirection(hrpPos, playerVelY, threatsToDodge, false, currentMovementDir, wallRayParams, pitRayParams)
                    currentMovementDir = safeDirection
                    
                    if safeDirection ~= Vector3.zero then
                        lookDirection = safeDirection
                    elseif primaryThreat then
                        local flatThreatPos = Vector3.new(primaryThreat.pos.X, hrpPos.Y, primaryThreat.pos.Z)
                        if (flatThreatPos - hrpPos).Magnitude > 0.1 then
                            lookDirection = (flatThreatPos - hrpPos).Unit
                        end
                    end
                    
                    -- JUMP only if no safe direction and extreme danger
                    if imminentImpact and dangerLevel > 12000 and safeDirection == Vector3.zero then
                        shouldJump = true
                    end
                    
                    -- ABILITY USAGE: only if danger is extremely high AND there is no safe non‑burst path
                    -- Also ensure we don't spam: require dangerLevel > 5000 and no safe direction that has a decent gap
                    local canUseBurst = dangerLevel > 5000 and safeDirection ~= Vector3.zero
                    if canUseBurst then
                        -- Check if there is a safe direction without bursting (i.e., we already have a safeDirection)
                        -- But we want to burst if the safe direction is not providing enough clearance (e.g., gap < threshold)
                        -- We'll compute if the safeDirection has a gap sufficient for normal movement
                        local gap = getMinimumGap(hrpPos, safeDirection, activeThreats, 15)
                        local needBurst = (gap < PLAYER_RADIUS * 2 + 1) and (dangerLevel > 8000)
                        if not needBurst then
                            -- Still, we might want to use burst if we are about to be hit
                            needBurst = (minThreatDist < 8 and dangerLevel > 6000)
                        end
                        if needBurst then
                            local bestBurst = nil
                            local desiredBurstDir = safeDirection
                            local safeDist = getSafeBurstDistance(hrpPos, desiredBurstDir, activeThreats, wallRayParams, pitRayParams)
                            
                            if safeDist > 15 then 
                                if tick() - lastRollTime > ROLL_COOLDOWN then
                                    bestBurst = {type = "Roll", dir = desiredBurstDir, lookDir = desiredBurstDir, dist = safeDist}
                                elseif tick() - lastDashTime > DASH_COOLDOWN then
                                    local lookRight = CFrame.Angles(0, -math.pi/2, 0) * desiredBurstDir
                                    local lookLeft = CFrame.Angles(0, math.pi/2, 0) * desiredBurstDir
                                    if nextDashSide == "Left" then
                                        bestBurst = {type = "DashLeft", dir = desiredBurstDir, lookDir = lookRight, dist = safeDist}
                                    else
                                        bestBurst = {type = "DashRight", dir = desiredBurstDir, lookDir = lookLeft, dist = safeDist}
                                    end
                                end
                            end
                            
                            if not bestBurst then
                                -- Try alternative directions
                                local bestAltDir = Vector3.zero
                                local lowestAltDanger = math.huge
                                local bestAltDist = 0
                                
                                for _, dir in ipairs(dodgeDirections) do
                                    local dist = getSafeBurstDistance(hrpPos, dir, activeThreats, wallRayParams, pitRayParams)
                                    if dist > 18 then
                                        local futurePos = hrpPos + (dir * dist)
                                        local altDanger = 0
                                        
                                        for _, t in ipairs(activeThreats) do
                                            local futureThreatPos
                                            if t.isStatic then
                                                futureThreatPos = t.pos
                                            else
                                                local burstTime = dist / DASH_SPEED
                                                futureThreatPos = t.pos + (t.vel * burstTime)
                                            end
                                            
                                            local rawDist = (futurePos - futureThreatPos).Magnitude
                                            local effectiveDist = math.max(0.1, rawDist - PLAYER_RADIUS)
                                            
                                            if effectiveDist < t.threatRadius then
                                                altDanger = altDanger + (25000 / effectiveDist)
                                            else
                                                altDanger = altDanger + (500 / (effectiveDist * effectiveDist))
                                            end
                                        end
                                        
                                        if altDanger < lowestAltDanger then
                                            lowestAltDanger = altDanger
                                            bestAltDir = dir
                                            bestAltDist = dist
                                        end
                                    end
                                end
                                
                                if bestAltDist > 18 and lowestAltDanger < dangerLevel then
                                    if tick() - lastRollTime > ROLL_COOLDOWN then
                                        bestBurst = {type = "Roll", dir = bestAltDir, lookDir = bestAltDir, dist = bestAltDist}
                                    elseif tick() - lastDashTime > DASH_COOLDOWN then
                                        local lookRight = CFrame.Angles(0, -math.pi/2, 0) * bestAltDir
                                        local lookLeft = CFrame.Angles(0, math.pi/2, 0) * bestAltDir
                                        if nextDashSide == "Left" then
                                            bestBurst = {type = "DashLeft", dir = bestAltDir, lookDir = lookRight, dist = bestAltDist}
                                        else
                                            bestBurst = {type = "DashRight", dir = bestAltDir, lookDir = lookLeft, dist = bestAltDist}
                                        end
                                    end
                                end
                            end
                            
                            if bestBurst then
                                isBursting = true
                                burstEndTime = tick() + (bestBurst.dist / DASH_SPEED)
                                burstDir = bestBurst.dir
                                burstLookDir = bestBurst.lookDir
                                
                                hrp.CFrame = CFrame.lookAt(hrp.Position, hrp.Position + burstLookDir)
                                
                                if bestBurst.type == "Roll" then
                                    lastRollTime = tick()
                                    simulateRoll()
                                elseif bestBurst.type == "DashLeft" then
                                    lastDashTime = tick()
                                    simulateTouch(false) 
                                    nextDashSide = "Right"
                                elseif bestBurst.type == "DashRight" then
                                    lastDashTime = tick()
                                    simulateTouch(true) 
                                    nextDashSide = "Left"
                                end
                                
                                safeDirection = burstDir
                                lookDirection = burstLookDir
                                shouldJump = false 
                            end
                        end
                    end
                else
                    if closestBallDist > 40 then
                        safeDirection = Vector3.zero
                        currentMovementDir = Vector3.zero
                        lookDirection = hrp.CFrame.LookVector
                    elseif #allHazardsList > 0 then
                        if tick() - lastRoamTime > 0.5 or lastRoamDir == Vector3.zero then
                            lastRoamDir, _, _ = getBestDirection(hrpPos, playerVelY, allHazardsList, true, currentMovementDir, wallRayParams, pitRayParams)
                            lastRoamTime = tick()
                        end
                        safeDirection = lastRoamDir
                        currentMovementDir = safeDirection
                        isRoaming = true
                        lookDirection = safeDirection 
                    end
                end
            end
        end
        
        -- REAL‑TIME WALL AVOIDANCE & CACHING
        if safeDirection ~= Vector3.zero then
            local wallCheckDist = 3.5
            local wallHit = workspace:Raycast(hrpPos, safeDirection * wallCheckDist, wallRayParams)
            if wallHit and wallHit.Distance < wallCheckDist then
                addWallToCache(wallHit.Position)
                safeDirection = Vector3.zero
                local normal = wallHit.Normal
                local tangent = (safeDirection - normal * safeDirection:Dot(normal)).Unit
                if tangent.Magnitude > 0.1 then
                    safeDirection = tangent
                end
            end
        end
        
        if shouldJump and isGrounded and jumpState == "None" and (tick() - lastJumpTime > 0.6) then
            jumpState = "Airborne"
            currentYVel = JUMP_POWER
            lastJumpTime = tick()
        end
        
        local useForceY = false
        if jumpState == "Airborne" then
            currentYVel = currentYVel - (GRAVITY_PULL * dt)
            if currentYVel > 0 then
                useForceY = true
            else
                useForceY = false
            end
            if currentYVel < 0 and isGrounded and (tick() - lastJumpTime > 0.2) then
                jumpState = "None"
                currentYVel = 0
            end
        end
        
        local moveSpeed = DODGE_SPEED
        if isBursting then moveSpeed = DASH_SPEED
        elseif isRoaming then moveSpeed = ROAM_SPEED end
        
        if safeDirection ~= Vector3.zero then
            applyPush(hrp, humanoid, safeDirection, useForceY, currentYVel, moveSpeed, lookDirection)
        else
            if jumpState ~= "None" then applyPush(hrp, humanoid, Vector3.zero, useForceY, currentYVel, 0, lookDirection)
            else applyPush(hrp, humanoid, Vector3.zero, false, 0, 0, lookDirection) end
        end
    end)
end

local function setOffline()
    status.Text = "Status: Offline"
    status.TextColor3 = Color3.fromRGB(255, 0, 0)
    
    stopWallESP()
    
    if mainLoopConnection then
        mainLoopConnection:Disconnect()
        mainLoopConnection = nil
    end
    
    pcall(function()
        vim:SendTouchEvent(TOUCH_ID_LEFT, 2, lastLeftClickX, lastLeftClickY)
        vim:SendTouchEvent(TOUCH_ID_RIGHT, 2, lastRightClickX, lastRightClickY)
        vim:SendTouchEvent(TOUCH_ID_ROLL, 2, lastRollClickX, lastRollClickY)
    end)
    
    local hrp = getHRP()
    if hrp then 
        local linVel = hrp:FindFirstChild("AutoDodgeVelocity")
        if linVel then linVel.Enabled = false end
        local alignOri = hrp:FindFirstChild("AutoDodgeOrientation")
        if alignOri then alignOri.Enabled = false end
    end
    
    for _, esp in pairs(espObjects) do
        esp.billboard:Destroy()
        esp.highlight:Destroy()
    end
    table.clear(espObjects)
end

onBtn.Activated:Connect(setOnline)
offBtn.Activated:Connect(setOffline)
destroyBtn.Activated:Connect(function()
    setOffline()
    if addedConn then addedConn:Disconnect() end
    if removingConn then removingConn:Disconnect() end
    if forceQueryLoop then task.cancel(forceQueryLoop) end
    
    local hrp = getHRP()
    if hrp then
        local att = hrp:FindFirstChild("AutoDodgeAttachment")
        local vel = hrp:FindFirstChild("AutoDodgeVelocity")
        local ori = hrp:FindFirstChild("AutoDodgeOrientation")
        if att then att:Destroy() end
        if vel then vel:Destroy() end
        if ori then ori:Destroy() end
    end
    
    screenGui:Destroy()
    espFolder:Destroy()
end)

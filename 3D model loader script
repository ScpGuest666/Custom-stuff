    activeFaces = {}
    paletteData = {}
end

local function refreshPaletteUI()
    local currentCounts = {}
    for _, line in ipairs(activeLines) do
        if not line.isFilled then
            currentCounts[line.rounded] = (currentCounts[line.rounded] or 0) + 1
        end
    end
    for len, data in pairs(paletteData) do
        local remaining = currentCounts[len] or 0
        local billboard = data.label.Parent
        local part = billboard.Adornee
        if remaining > 0 then
            billboard.Enabled = true
            if part then part.Transparency = 0 end
            data.label.Text = string.format("%g, %g, %g\nx%d", lineThickness, lineThickness, len, remaining)
        else
            billboard.Enabled = false
            if part then part.Transparency = 1 end
        end
    end
end

-- SMART BATCHED SCANNER (PERFECT PLANE PROJECTION)
task.spawn(function()
    local SCAN_BATCH_SIZE = 50 
    local SCAN_STEP_DELAY = 0.03
    while true do
        if #activeLines > 0 and not isBuilding then
            local overlapParams = OverlapParams.new()
            overlapParams.FilterDescendantsInstances = {player.Character, workspace:FindFirstChild(FOLDER_NAME)}
            overlapParams.FilterType = Enum.RaycastFilterType.Exclude
            
            -- 1. Scan Lines
            for i = 1, #activeLines do
                local line = activeLines[i]
                if not line then continue end
                
                local isFilled = false
                local detectedPart = nil
                
                pcall(function()
                    local parts = workspace:GetPartBoundsInBox(line.cframe, Vector3.new(0.5, 0.5, line.rounded - 0.1), overlapParams)
                    for _, p in ipairs(parts) do
                        if p:IsA("BasePart") and p.Anchored then
                            local pMax = math.max(p.Size.X, p.Size.Y, p.Size.Z)
                            if math.abs(pMax - line.rounded) < 0.2 and (p.Position - line.cframe.Position).Magnitude < 0.5 then
                                isFilled = true
                                detectedPart = p
                                break
                            end
                        end
                    end
                end)
                
                line.isFilled = isFilled
                line.detectedPart = detectedPart
                
                if line.refPart and line.refPart.Parent then
                    line.refPart.Transparency = isFilled and 1 or 0.4
                end
                if i % SCAN_BATCH_SIZE == 0 then task.wait(SCAN_STEP_DELAY) end
            end
            
            -- 2. Update Face Guides (Perfect Plane Projection)
            if fillMode then
                for _, face in ipairs(activeFaces) do
                    local filledLines = {}
                    for _, line in ipairs(face.lines) do
                        if line.isFilled and line.detectedPart then
                            table.insert(filledLines, line)
                        end
                    end
                    
                    local center = face.defaultCenter
                    local edge1 = face.defaultEdge
                    local normal = face.originalNormal
                    
                    if #filledLines > 0 then
                        -- Align rotation to the first physical block, but PROJECT it onto the perfect plane
                        local rawEdge = (filledLines[1].worldP2 - filledLines[1].worldP1).Unit
                        edge1 = (rawEdge - normal * rawEdge:Dot(normal)).Unit
                        
                        if #filledLines >= 2 then
                            local uniquePoints = {}
                            local function addPoint(p)
                                for _, existing in ipairs(uniquePoints) do
                                    if (existing.pos - p).Magnitude < 0.01 then
                                        existing.count = existing.count + 1
                                        return
                                    end
                                end
                                table.insert(uniquePoints, {pos = p, count = 1})
                            end
                            
                            for _, line in ipairs(filledLines) do
                                addPoint(line.worldP1)
                                addPoint(line.worldP2)
                            end
                            
                            local extremities = {}
                            for _, pt in ipairs(uniquePoints) do
                                if pt.count == 1 then table.insert(extremities, pt.pos) end
                            end
                            
                            if #filledLines == 2 and #extremities == 2 then
                                center = (extremities[1] + extremities[2]) / 2
                            else
                                center = Vector3.new(0,0,0)
                                for _, pt in ipairs(uniquePoints) do center += pt.pos end
                                center /= #uniquePoints
                            end
                            
                            -- PROJECT CENTER ONTO PERFECT PLANE TO PREVENT SINKING/RAISING
                            local offset = center - face.defaultCenter
                            local distFromPlane = offset:Dot(normal)
                            center = center - (normal * distFromPlane)
                        end
                    end
                    
                    if face.guidePart then
                        local backVector = edge1:Cross(normal).Unit
                        face.guidePart.CFrame = CFrame.fromMatrix(center, edge1, normal, backVector)
                        face.guidePart.Transparency = 0.5
                    end
                end
            else
                for _, face in ipairs(activeFaces) do
                    if face.guidePart then face.guidePart.Transparency = 1 end
                end
            end
            
            refreshPaletteUI()
            task.wait()
        else
            task.wait(1)
        end
    end
end)

local function drawLine(p1, p2, distance, parent)
    local line = Instance.new("Part")
    line.Anchored = true
    line.CanCollide = false
    line.CanTouch = false
    line.CanQuery = false 
    line.Size = Vector3.new(lineThickness, lineThickness, distance)
    line.CFrame = CFrame.lookAt(p1, p2) * CFrame.new(0, 0, -distance / 2)
    line.Material = Enum.Material.SmoothPlastic
    line.Color = Color3.fromRGB(0, 180, 255)
    line.Transparency = 0.4
    line.Parent = parent
    return line
end

local function createFaceGuide(center, normal, edgeDir, parent)
    local guide = Instance.new("Part")
    guide.Anchored = true
    guide.CanCollide = false
    guide.CanQuery = true
    guide.Transparency = fillMode and 0.5 or 1
    guide.Color = Color3.fromRGB(255, 0, 255)
    guide.Material = Enum.Material.SmoothPlastic
    guide.Size = Vector3.new(0.5, 0.5, 0.5)
    guide.CFrame = CFrame.fromMatrix(center, edgeDir, normal, edgeDir:Cross(normal))
    guide.Parent = parent
    return guide
end

local function drawPalette(lengthCounts, folder, startPos, lookDir, rightDir)
    local sortedLengths = {}
    for len, _ in pairs(lengthCounts) do table.insert(sortedLengths, len) end
    table.sort(sortedLengths)
    for i, len in ipairs(sortedLengths) do
        local count = lengthCounts[len]
        local pos = startPos + (lookDir * ((i - 1) * 2))
        local part = Instance.new("Part")
        part.Anchored = true
        part.CanCollide = false
        part.CanQuery = false 
        part.Size = Vector3.new(lineThickness, lineThickness, len)
        part.CFrame = CFrame.lookAt(pos, pos + rightDir)
        part.Material = Enum.Material.SmoothPlastic
        part.Color = Color3.fromRGB(0, 255, 100)
        part.Parent = folder
        local billboard = Instance.new("BillboardGui")
        billboard.Adornee = part
        billboard.Size = UDim2.new(4, 0, 2, 0) 
        billboard.StudsOffset = Vector3.new(0, 1.5, 0)
        billboard.AlwaysOnTop = true
        billboard.Parent = part
        local textLabel = Instance.new("TextLabel")
        textLabel.Size = UDim2.new(1, 0, 1, 0)
        textLabel.BackgroundTransparency = 1
        textLabel.Text = string.format("%g, %g, %g\nx%d", lineThickness, lineThickness, len, count)
        textLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
        textLabel.TextStrokeTransparency = 0
        textLabel.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
        textLabel.TextScaled = true
        textLabel.Parent = billboard
        paletteData[len] = { label = textLabel, total = count }
    end
end

local function parseOBJ(objText)
    parsedVertices = {}
    parsedLayers = {}
    local currentLayerFaces = {}
    local minX, minY, minZ = math.huge, math.huge, math.huge
    local maxX, maxY, maxZ = -math.huge, -math.huge, -math.huge
    for line in objText:gmatch("[^\r\n]+") do
        line = line:match("^%s*(.-)%s*$")
        if line:sub(1, 2) == "v " then
            local coords = {}
            for val in line:gmatch("%S+") do if val ~= "v" then table.insert(coords, tonumber(val)) end end
            if #coords >= 3 then
                local v = Vector3.new(coords[1], coords[2], coords[3])
                table.insert(parsedVertices, v)
                minX = math.min(minX, v.X); minY = math.min(minY, v.Y); minZ = math.min(minZ, v.Z)
                maxX = math.max(maxX, v.X); maxY = math.max(maxY, v.Y); maxZ = math.max(maxZ, v.Z)
            end
        elseif line:sub(1, 2) == "f " then
            local faceVerts = {}
            for block in line:gmatch("%S+") do
                if block ~= "f" then
                    local vIdx = tonumber(block:match("^([^/]+)"))
                    if vIdx then if vIdx < 0 then vIdx = #parsedVertices + vIdx + 1 end table.insert(faceVerts, vIdx) end
                end
            end
            if #faceVerts >= 3 then table.insert(currentLayerFaces, faceVerts) end
        elseif line:sub(1, 2) == "o " or line:sub(1, 2) == "g " or line:sub(1, 7) == "usemtl " then
            if #currentLayerFaces > 0 then table.insert(parsedLayers, currentLayerFaces) currentLayerFaces = {} end
        end
    end
    if #currentLayerFaces > 0 then table.insert(parsedLayers, currentLayerFaces) end
    globalCenterOffset = Vector3.new((minX + maxX)/2, (minY + maxY)/2, (minZ + maxZ)/2)
end

local function drawLayer(index)
    clearReference()
    updateInputs()
    local folder = Instance.new("Folder", workspace)
    folder.Name = FOLDER_NAME
    local faces = parsedLayers[index]
    if not faces then return end
    setStatus("Drawing Layer " .. index, Color3.fromRGB(0, 255, 255))
    nextButton.Text = "Next (" .. index .. "/" .. #parsedLayers .. ")"
    
    local edgeToLineData = {}
    local lengthCounts = {}
    local char = player.Character
    local hrp = char.HumanoidRootPart
    local paletteRightDir = hrp.CFrame.RightVector
    local paletteLookDir = hrp.CFrame.LookVector
    local paletteStartPos = hrp.Position + (paletteRightDir * 20)
    
    for _, face in ipairs(faces) do
        local faceLines = {}
        local faceWorldVerts = {}
        
        for i = 1, #face do
            local idx1 = face[i]
            local idx2 = face[i % #face + 1]
            local localV1 = (parsedVertices[idx1] - globalCenterOffset)
            local localV2 = (parsedVertices[idx2] - globalCenterOffset)
            
            if not splitMode or (localV1.X >= -0.01 or localV2.X >= -0.01) then
                local worldP1 = spawnCFrame * (localV1 * modelScale)
                local worldP2 = spawnCFrame * (localV2 * modelScale)
                table.insert(faceWorldVerts, worldP1)
                
                local edgeKey = math.min(idx1, idx2) .. "_" .. math.max(idx1, idx2)
                local lineData = edgeToLineData[edgeKey]
                
                if not lineData then
                    local distance = (worldP2 - worldP1).Magnitude
                    if distance >= 0.01 then
                        local roundedDist = math.ceil(distance * 2) / 2
                        lengthCounts[roundedDist] = (lengthCounts[roundedDist] or 0) + 1
                        local linePart = drawLine(worldP1, worldP2, distance, folder)
                        lineData = {
                            cframe = linePart.CFrame, 
                            rounded = roundedDist, 
                            refPart = linePart, 
                            isFilled = false,
                            worldP1 = worldP1,
                            worldP2 = worldP2
                        }
                        edgeToLineData[edgeKey] = lineData
                        table.insert(activeLines, lineData)
                    end
                end
                if lineData then table.insert(faceLines, lineData) end
            end
        end
        
        if #faceWorldVerts >= 3 then
            local center = Vector3.new(0,0,0)
            for _, v in ipairs(faceWorldVerts) do center += v end
            center /= #faceWorldVerts
            
            local shortestEdgeLen = math.huge
            local bestEdgeDir = (faceWorldVerts[2] - faceWorldVerts[1]).Unit
            for i = 1, #faceWorldVerts do
                local p1 = faceWorldVerts[i]
                local p2 = faceWorldVerts[i % #faceWorldVerts + 1]
                local dir = p2 - p1
                local len = dir.Magnitude
                if len < shortestEdgeLen and len > 0.01 then
                    shortestEdgeLen = len
                    bestEdgeDir = dir.Unit
                end
            end
            
            local normal = bestEdgeDir:Cross((faceWorldVerts[3] - faceWorldVerts[1]).Unit).Unit
            if normal.Magnitude < 0.01 then normal = Vector3.new(0,1,0) end
            
            local guide = createFaceGuide(center, normal, bestEdgeDir, folder)
            table.insert(activeFaces, {
                lines = faceLines, 
                guidePart = guide, 
                originalNormal = normal,
                defaultCenter = center,
                defaultEdge = bestEdgeDir
            })
        end
    end
    
    drawPalette(lengthCounts, folder, paletteStartPos, paletteLookDir, paletteRightDir)
    setStatus("Online", Color3.fromRGB(0, 255, 0))
end

local function buildReference()
    if isBuilding then return end
    isBuilding = true
    clearReference()
    updateInputs()
    if not cachedObjText then
        setStatus("Fetching OBJ...", Color3.fromRGB(255, 255, 0))
        local success, objText = pcall(function() return game:HttpGet(OBJ_URL) end)
        if not success or not objText then setStatus("Fetch Failed!", Color3.fromRGB(255, 0, 0)) isBuilding = false return end
        cachedObjText = objText
    end
    if #parsedLayers == 0 then parseOBJ(cachedObjText) end
    local char = player.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then setStatus("Char not found!", Color3.fromRGB(255, 0, 0)) isBuilding = false return end
    local hrp = char.HumanoidRootPart
    
    local rayParams = RaycastParams.new()
    rayParams.FilterDescendantsInstances = {char}
    rayParams.FilterType = Enum.RaycastFilterType.Exclude
    local result = workspace:Raycast(hrp.Position, Vector3.new(0, -100, 0), rayParams)
    local spawnPos = result and (Vector3.new(result.Instance.Position.X, result.Position.Y + 5, result.Instance.Position.Z)) or (hrp.Position + Vector3.new(0, 5, 0))
    local look = hrp.CFrame.LookVector
    local angle = math.atan2(look.X, look.Z)
    local snappedAngle = math.round(angle / (math.pi / 2)) * (math.pi / 2)
    spawnCFrame = CFrame.new(spawnPos) * CFrame.Angles(0, snappedAngle, 0)
    
    drawLayer(currentLayerIndex)
    isBuilding = false
end


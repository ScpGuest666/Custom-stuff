-- INSTANT TP PHYSICS LOGIC
moveButton.MouseButton1Click:Connect(function()
    if isMovingBlock then return end
    local char = player.Character
    if not char or not char:FindFirstChild("Humanoid") or not char:FindFirstChild("HumanoidRootPart") then return end
    local humanoid = char.Humanoid
    local hrp = char.HumanoidRootPart
    local seat = humanoid.SeatPart
    if not seat then setStatus("Sit on the block first!", Color3.fromRGB(255, 165, 0)) return end
    
    local connectedParts = seat:GetConnectedParts()
    local targetBlock = nil
    local maxDim = 0
    for _, part in ipairs(connectedParts) do
        if part ~= seat and not part:IsA("Seat") and not part:IsA("VehicleSeat") then
            if part.Parent and not part.Parent:FindFirstChild("Humanoid") then
                local dim = math.max(part.Size.X, part.Size.Y, part.Size.Z)
                if dim > maxDim then maxDim = dim targetBlock = part end
            end
        end
    end
    if not targetBlock then setStatus("No block attached!", Color3.fromRGB(255, 0, 0)) return end
    if targetBlock.Anchored then setStatus("Unanchor first!", Color3.fromRGB(255, 0, 0)) return end
    
    local size = targetBlock.Size
    local maxDim = math.max(size.X, size.Y, size.Z)
    local roundedMaxDim = math.ceil(maxDim * 2) / 2
    local matchIndex = nil
    for i, line in ipairs(activeLines) do
        if line.rounded == roundedMaxDim and not line.isFilled then matchIndex = i break end
    end
    if not matchIndex then setStatus("No " .. roundedMaxDim .. " line!", Color3.fromRGB(255, 165, 0)) return end
    
    isMovingBlock = true
    humanoid:SetStateEnabled(Enum.HumanoidStateType.Seated, false)
    seat.CanQuery = false 
    local originalCollisions = {}
    local function disableCollision(part)
        if part:IsA("BasePart") then originalCollisions[part] = part.CanCollide part.CanCollide = false end
    end
    for _, part in ipairs(char:GetDescendants()) do disableCollision(part) end
    for _, part in ipairs(seat:GetConnectedParts()) do disableCollision(part) end
    
    local pos = hrp.Position
    local _, yRot, _ = hrp.CFrame:ToEulerAnglesYXZ()
    local startCFrame = CFrame.new(pos) * CFrame.Angles(0, yRot, 0)
    
    local lineData = activeLines[matchIndex]
    local targetBlockCFrame = lineData.cframe
    if size.X > size.Y and size.X > size.Z then targetBlockCFrame *= CFrame.Angles(0, math.rad(90), 0)
    elseif size.Y > size.X and size.Y > size.Z then targetBlockCFrame *= CFrame.Angles(math.rad(90), 0, 0) end
    local seatOffset = targetBlock.CFrame:ToObjectSpace(seat.CFrame)
    local targetSeatCFrame = targetBlockCFrame * seatOffset
    
    local anchorConnection
    anchorConnection = targetBlock:GetPropertyChangedSignal("Anchored"):Connect(function()
        if targetBlock.Anchored then
            lineData.isFilled = true
            lineData.detectedPart = targetBlock
            if lineData.refPart then lineData.refPart.Transparency = 1 end
            refreshPaletteUI()
            anchorConnection:Disconnect()
        end
    end)
    
    local bv = Instance.new("BodyVelocity", seat)
    bv.MaxForce = Vector3.new(9e9, 9e9, 9e9)
    bv.Velocity = Vector3.new(0, 0, 0)
    local bg = Instance.new("BodyGyro", seat)
    bg.MaxTorque = Vector3.new(9e9, 9e9, 9e9)
    bg.P = 9e9 
    bg.D = 9e9 
    bg.CFrame = targetSeatCFrame
    
    seat.CFrame = targetSeatCFrame
    setStatus("Arrived! Anchor & Jump.", Color3.fromRGB(0, 255, 0))
    
    local jumpConnection
    jumpConnection = humanoid:GetPropertyChangedSignal("SeatPart"):Connect(function()
        if not humanoid.SeatPart then
            bv:Destroy() bg:Destroy() jumpConnection:Disconnect()
            if anchorConnection then anchorConnection:Disconnect() end
            if seat and seat.Parent then seat.CanQuery = true end
            task.wait(0.1)
            hrp.Velocity = Vector3.new(0,0,0)
            hrp.RotVelocity = Vector3.new(0,0,0)
            hrp.CFrame = startCFrame
            for part, state in pairs(originalCollisions) do if part and part.Parent then part.CanCollide = state end end
            task.wait(0.2)
            humanoid:SetStateEnabled(Enum.HumanoidStateType.Seated, true)
            setStatus("Returned.", Color3.fromRGB(0, 255, 0))
            isMovingBlock = false
        end
    end)
end)


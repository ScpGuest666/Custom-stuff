        autoDetectBtn.Text = "Auto-Detect: ON"
        autoDetectBtn.BackgroundColor3 = Color3.fromRGB(0, 150, 0)
    else
        autoDetectBtn.Text = "Auto-Detect: OFF"
        autoDetectBtn.BackgroundColor3 = Color3.fromRGB(150, 100, 0)
        lastDetectedPrompt = "" -- Reset so it can re-detect if turned back on
    end
end)

task.spawn(function()
    while task.wait(0.5) do
        if not autoDetectEnabled then continue end
        
        local detected = nil
        local guis = {}
        
        -- Collect all UI elements (ScreenGuis and BillboardGuis)
        for _, child in ipairs(player.PlayerGui:GetChildren()) do
            if child:IsA("ScreenGui") or child:IsA("BillboardGui") then table.insert(guis, child) end
        end
        for _, desc in ipairs(workspace:GetDescendants()) do
            if desc:IsA("BillboardGui") or desc:IsA("SurfaceGui") then table.insert(guis, desc) end
        end
        
        for _, gui in ipairs(guis) do
            local promptLabel = nil
            
            -- Find the text label asking for the word
            for _, desc in ipairs(gui:GetDescendants()) do
                if desc:IsA("TextLabel") and desc.Visible and desc.Text:lower():find("type an english word starting with") then
                    promptLabel = desc
                    break
                end
            end
            
            if promptLabel then
                -- 1. Check if the letters are written inside the same text label
                local inline = promptLabel.Text:match("starting with:%s*<[^>]+>%s*([A-Za-z]+)") 
                            or promptLabel.Text:match("starting with:%s*([A-Za-z]+)")
                if inline and #inline > 0 then
                    detected = string.upper(inline)
                    break
                end
                
                -- 2. If not, scan the surrounding UI for the individual letter boxes (e.g. [Y] [E] [P])
                local letters = {}
                for _, sibling in ipairs(gui:GetDescendants()) do
                    if sibling:IsA("TextLabel") and sibling.Visible and sibling ~= promptLabel then
                        local t = sibling.Text:gsub("<[^>]+>", ""):gsub("[%s%p]", "")
                        if #t > 0 and t:match("^%a+$") then
                            -- Only grab labels that are 1 letter long, or fully uppercase words up to 5 letters
                            if #t == 1 or (#t <= 5 and t == string.upper(t)) then
                                table.insert(letters, {
                                    text = string.upper(t), 
                                    x = sibling.AbsolutePosition.X, 
                                    layoutOrder = sibling.LayoutOrder
                                })
                            end
                        end
                    end
                end
                
                -- Sort the letters from left to right based on their screen position
                if #letters > 0 then
                    table.sort(letters, function(a, b) 
                        if math.abs(a.x - b.x) < 5 then return a.layoutOrder < b.layoutOrder end
                        return a.x < b.x 
                    end)
                    local res = ""
                    for _, l in ipairs(letters) do res = res .. l.text end
                    detected = res
                    break
                end
            end
        end
        
        -- If we found a new prompt, automatically type it into the input box!
        if detected and detected ~= lastDetectedPrompt then
            lastDetectedPrompt = detected
            inputBox.Text = detected
        end
    end
end)

-------------------------------------------------------------------------------
-- TEXT BOX INPUT LOGIC
-------------------------------------------------------------------------------

local function findWords(prompt)
    local results = {}
    local promptLen = string.len(prompt)
    
    for i = 1, #allWords do
        local word = allWords[i]
        if string.sub(word, 1, promptLen) == prompt then
            table.insert(results, word)
            if #results >= 50 then break end
        end
    end
    return results
end

inputBox:GetPropertyChangedSignal("Text"):Connect(function()
    local text = string.upper(inputBox.Text:gsub("[%s%p]", ""))
    
    if text ~= "" then
        local words = findWords(text)
        
        if #words > 0 then
            local displayText = ""
            for i, word in ipairs(words) do
                local lowerWord = string.lower(word)
                local displayWord
                
                if string.sub(word, -2) == "OX" then
                    displayWord = string.sub(lowerWord, 1, -3) .. "OX"
                else
                    displayWord = string.sub(lowerWord, 1, -2) .. string.upper(string.sub(lowerWord, -1))
                end
                
                if customWordsSet[word] then
                    displayText = displayText .. i .. ". <font color=\"#FFFF00\">" .. displayWord .. "</font>\n"
                else
                    displayText = displayText .. i .. ". <font color=\"#FFFFFF\">" .. displayWord .. "</font>\n"
                end
            end
            wordList.Text = " " .. displayText
        else
            wordList.Text = " <font color=\"#FFA500\">No words found starting with:\n " .. text .. "</font>"
        end
    else
        wordList.Text = " <font color=\"#969696\">Waiting for game prompt...</font>"
    end
end)


-- Colors for roles
local roleColors = {
    Murderer = Color3.fromRGB(255, 0, 0),      -- Red
    Sheriff = Color3.fromRGB(0, 0, 255),       -- Blue
    Hero = Color3.fromRGB(255, 255, 0),        -- Yellow
    Innocent = Color3.fromRGB(0, 255, 0),      -- Green
    GunDrop = Color3.fromRGB(255, 0, 255)      -- Magenta
}

-- Function to get MM2 Timer from the UI
local function getMM2Timer()
    local timerText = "0:00"
    pcall(function()
        local mainGui = player.PlayerGui:FindFirstChild("MainGUI")
        if mainGui then
            local gameGui = mainGui:FindFirstChild("Game")
            if gameGui then
                local timer = gameGui:FindFirstChild("Timer")
                if timer then
                    if timer:IsA("TextLabel") then
                        timerText = timer.Text
                    elseif timer:FindFirstChild("Time") and timer.Time:IsA("TextLabel") then
                        timerText = timer.Time.Text
                    end
                end
            end
        end
    end)
    if timerText == "" or timerText == "Label" then timerText = "0:00" end
    return timerText
end

-- Function to instantly fetch roles from ReplicatedStorage
local function updateRolesInstantly()
    pcall(function()
        local getPlayerData = game:GetService("ReplicatedStorage"):FindFirstChild("GetPlayerData", true)
        if getPlayerData and getPlayerData:IsA("RemoteFunction") then
            local data = getPlayerData:InvokeServer()
            if type(data) == "table" then
                local newRoles = {}
                for playerName, playerInfo in pairs(data) do
                    if type(playerInfo) == "table" and playerInfo.Role then
                        newRoles[playerName] = playerInfo.Role
                        if playerInfo.Role == "Sheriff" then
                            local plr = PlayerService:FindFirstChild(playerName)
                            if plr then originalSheriff = plr end
                        end
                    end
                end
                cachedRoles = newRoles
            end
        end
    end)
end

-- Function to determine player role
local function getPlayerRole(plr)
    local role = "Innocent"
    
    if cachedRoles[plr.Name] then
        local cachedRole = cachedRoles[plr.Name]
        if cachedRole == "Murderer" or cachedRole == "Sheriff" then
            role = cachedRole
        end
    end
    
    local hasKnife = false
    local hasGun = false
    
    local function checkItems(parent)
        if not parent then return end
        for _, item in pairs(parent:GetChildren()) do
            if item:IsA("Tool") then
                if item.Name == "Knife" or item:FindFirstChild("KnifeServer") or item:FindFirstChild("KnifeClient") then
                    hasKnife = true
                elseif item.Name == "Gun" or item.Name == "Revolver" or item:FindFirstChild("GunServer") or item:FindFirstChild("GunClient") then
                    hasGun = true
                end
            end
        end
    end
    
    checkItems(plr.Character)
    checkItems(plr:FindFirstChild("Backpack"))
    
    if hasKnife then
        role = "Murderer"
    elseif hasGun then
        if cachedRoles[plr.Name] ~= "Sheriff" and originalSheriff ~= plr then
            role = "Hero"
        else
            role = "Sheriff"
        end
    end
    
    return role
end

-- Function to create ESP
local function createESP(target, name, color)
    if not target then return end
    
    if espObjects[target] then
        espObjects[target].Highlight:Destroy()
        espObjects[target].Billboard:Destroy()
        espObjects[target] = nil
    end
    
    local adornee = target
    if target:IsA("Model") then
        adornee = target.PrimaryPart or target:FindFirstChild("HumanoidRootPart") or target:FindFirstChildWhichIsA("BasePart")
    end
    
    if not adornee then return end
    
    local highlight = Instance.new("Highlight")
    highlight.Adornee = target
    highlight.FillColor = color
    highlight.OutlineColor = Color3.new(1, 1, 1)
    highlight.FillTransparency = 0.5
    highlight.OutlineTransparency = 0.2
    highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    highlight.Parent = screenGui
    
    local billboard = Instance.new("BillboardGui")
    billboard.Adornee = adornee
    billboard.Size = UDim2.new(0, 100, 0, 40)
    billboard.StudsOffset = Vector3.new(0, 3, 0)
    billboard.AlwaysOnTop = true
    billboard.Parent = screenGui
    
    local textLabel = Instance.new("TextLabel")
    textLabel.Parent = billboard
    textLabel.Size = UDim2.new(1, 0, 1, 0)
    textLabel.BackgroundTransparency = 1
    textLabel.Text = name
    textLabel.TextColor3 = color
    textLabel.TextStrokeTransparency = 0
    textLabel.TextScaled = true
    textLabel.Font = Enum.Font.SourceSansBold
    
    espObjects[target] = {
        Highlight = highlight,
        Billboard = billboard,
        Name = name
    }
end

-- Function to clear all ESP
local function clearESP()
    for target, objects in pairs(espObjects) do
        if objects.Highlight then objects.Highlight:Destroy() end
        if objects.Billboard then objects.Billboard:Destroy() end
    end
    espObjects = {}
end

-- Main ESP Update Loop
local function updateESP()
    if not espEnabled then return end
    
    local currentTimer = getMM2Timer()
    statusLabel.Text = "Status: Online | " .. currentTimer
    
    if tick() - lastRoleUpdate > 2 then
        lastRoleUpdate = tick()
        task.spawn(updateRolesInstantly)
    end
    
    local currentMurdererExists = false
    local currentSheriffExists = false
    
    for _, plr in pairs(PlayerService:GetPlayers()) do
        if plr ~= player and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
            local role = getPlayerRole(plr)
            local color = roleColors[role]
            local displayName = plr.Name .. " [" .. role .. "]"
            
            if role == "Murderer" then
                currentMurdererExists = true
            elseif role == "Sheriff" or role == "Hero" then
                currentSheriffExists = true
            end
            
            if not espObjects[plr.Character] or espObjects[plr.Character].Name ~= displayName then
                createESP(plr.Character, displayName, color)
            end
        end
    end
    
    if not currentMurdererExists and not currentSheriffExists then
        originalSheriff = nil
        cachedRoles = {}
    end
    
    if tick() - lastGunCheck > 0.5 then
        lastGunCheck = tick()
        cachedGunDrop = Workspace:FindFirstChild("GunDrop", true)
    end
    
    if cachedGunDrop then
        if not espObjects[cachedGunDrop] then
            createESP(cachedGunDrop, "Dropped Gun", roleColors.GunDrop)
        end
    end
    
    for target, objects in pairs(espObjects) do
        if not target or not target.Parent then
            if objects.Highlight then objects.Highlight:Destroy() end
            if objects.Billboard then objects.Billboard:Destroy() end
            espObjects[target] = nil
        end
    end
end

-- Totem Functions
local function applyTotem(char)
    local hum = char:WaitForChild("Humanoid", 3)
    if hum then
        -- Disables the death state so you don't die at 0 HP
        hum:SetStateEnabled(Enum.HumanoidStateType.Dead, false)
        
        -- Forces health to 1 if it drops to 0
        local conn = hum.HealthChanged:Connect(function(hp)
            if hp <= 1 then
                hum.Health = 1
            end
        end)
        table.insert(totemConnections, conn)
    end
end

local function disableTotem()
    for _, conn in pairs(totemConnections) do
        if conn then conn:Disconnect() end
    end
    totemConnections = {}
    
    if player.Character then
        local hum = player.Character:FindFirstChild("Humanoid")
        if hum then
            hum:SetStateEnabled(Enum.HumanoidStateType.Dead, true)
        end
    end
end


-- Global Variables
local activeConnections = {}
local heartbeatConn
local renderSteppedConn
local steppedConn
local savedVelocity = Vector3.zero
local savedRotVelocity = Vector3.zero

-- Function to set status to Online (Downward Fling ON)
local function setStatusOnline()
    if heartbeatConn or steppedConn then return end
    
    statusLabel.Text = "Status: Online"
    statusLabel.TextColor3 = Color3.fromRGB(0, 255, 0)
    
    local char = player.Character
    if char then
        local humanoid = char:FindFirstChildOfClass("Humanoid")
        if humanoid then
            -- FIX: Disable states that cause the animation seizure and infinite jump
            humanoid:SetStateEnabled(Enum.HumanoidStateType.Freefall, false)
            humanoid:SetStateEnabled(Enum.HumanoidStateType.Landed, false)
        end
    end
    
    heartbeatConn = RunService.Heartbeat:Connect(function()
        local currentChar = player.Character
        if currentChar and currentChar:FindFirstChild("HumanoidRootPart") then
            local hrp = currentChar.HumanoidRootPart
            savedVelocity = hrp.AssemblyLinearVelocity
            savedRotVelocity = hrp.AssemblyAngularVelocity
            
            -- Fling downward
            hrp.AssemblyLinearVelocity = Vector3.new(-9e9, -9e9, -9e9)
        end
    end)
    
    -- FIX: Restore velocity before the frame renders to hide it from the client's camera/input
    renderSteppedConn = RunService.RenderStepped:Connect(function()
        local currentChar = player.Character
        if currentChar and currentChar:FindFirstChild("HumanoidRootPart") then
            local hrp = currentChar.HumanoidRootPart
            hrp.AssemblyLinearVelocity = savedVelocity
            hrp.AssemblyAngularVelocity = savedRotVelocity
        end
    end)
    
    steppedConn = RunService.Stepped:Connect(function()
        local currentChar = player.Character
        if currentChar and currentChar:FindFirstChild("HumanoidRootPart") then
            local hrp = currentChar.HumanoidRootPart
            -- Restore normal velocity for physics simulation
            hrp.AssemblyLinearVelocity = savedVelocity
            hrp.AssemblyAngularVelocity = savedRotVelocity
        end
    end)
    
    table.insert(activeConnections, heartbeatConn)
    table.insert(activeConnections, renderSteppedConn)
    table.insert(activeConnections, steppedConn)
end

-- Function to set status to Offline (Fling OFF & Stabilize)
local function setStatusOffline()
    statusLabel.Text = "Status: Offline"
    statusLabel.TextColor3 = Color3.fromRGB(255, 0, 0)
    
    if heartbeatConn then heartbeatConn:Disconnect() heartbeatConn = nil end
    if renderSteppedConn then renderSteppedConn:Disconnect() renderSteppedConn = nil end
    if steppedConn then steppedConn:Disconnect() steppedConn = nil end
    
    local char = player.Character
    if char then
        local humanoid = char:FindFirstChildOfClass("Humanoid")
        if humanoid then
            -- Re-enable normal humanoid states
            humanoid:SetStateEnabled(Enum.HumanoidStateType.Freefall, true)
            humanoid:SetStateEnabled(Enum.HumanoidStateType.Landed, true)
        end
        
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if hrp then
            -- Zero out any residual momentum
            hrp.AssemblyLinearVelocity = Vector3.zero
            hrp.AssemblyAngularVelocity = Vector3.zero
            hrp.CFrame = hrp.CFrame 
        end
    end
end

-- Cleanup function
local function cleanup()
    setStatusOffline()
    
    for _, connection in pairs(activeConnections) do
        if connection and connection.Disconnect then
            connection:Disconnect()
        end
    end
    activeConnections = {}
    
    if screenGui then
        screenGui:Destroy()
    end
end

-- Button Functions
onButton.MouseButton1Click:Connect(function()
    setStatusOnline()
end)

offButton.MouseButton1Click:Connect(function()
    setStatusOffline()
end)

destroyButton.MouseButton1Click:Connect(function()
    cleanup()
end)




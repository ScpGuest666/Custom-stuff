bringButton.MouseButton1Click:Connect(function()
    if getPlayerRole(player) == "Murderer" then
        local myChar = player.Character
        local myRoot = myChar and myChar:FindFirstChild("HumanoidRootPart")
        
        if myRoot then
            for _, plr in pairs(PlayerService:GetPlayers()) do
                if plr ~= player then
                    local char = plr.Character
                    if char then
                        local root = char:FindFirstChild("HumanoidRootPart")
                        local hum = char:FindFirstChild("Humanoid")
                        
                        if root and hum and hum.Health > 0 then
                            root.CFrame = myRoot.CFrame * CFrame.new(0, 0, -2)
                        end
                    end
                end
            end
        end
    end
end)

totemButton.MouseButton1Click:Connect(function()
    totemEnabled = not totemEnabled
    if totemEnabled then
        totemButton.Text = "Totem: On"
        totemButton.TextColor3 = Color3.fromRGB(0, 255, 0)
        
        if player.Character then
            applyTotem(player.Character)
        end
        local conn = player.CharacterAdded:Connect(applyTotem)
        table.insert(totemConnections, conn)
    else
        totemButton.Text = "Totem: Off"
        totemButton.TextColor3 = Color3.fromRGB(255, 255, 255)
        disableTotem()
    end
end)

destroyButton.MouseButton1Click:Connect(function()
    if espEnabled then
        offButton.MouseButton1Click:Fire()
    end
    disableTotem()
    screenGui:Destroy()
end)

local MAX_MOVEMENT_SPEED = 10 
local MAX_TURN_RATE = math.rad(40) 
local RIDE_HEIGHT = 9.5 
local BASE_STEP_HEIGHT = 3.5
local STEP_DURATION = 0.3 -- Faster, snappier steps
local STEP_THRESHOLD = 3 -- Steps more frequently to prevent stretching
local GRAVITY_FORCE = 30 

-- Leg Proportions
local COXA_LEN = 3
local FEMUR_LEN = 7
local KNEE_LEN = 7
local TIBIA_LEN = 8 

-- State Variables
local hexapodModel = nil
local runConnection = nil
local legs = {}
local body = nil
local targetPos = nil
local targetMarker = nil
local lastTapTime = 0

-- PERSISTENT STATE
local currentRotationYaw = 0 
local lastValidGroundY = 0
local currentGaitGroup = 1 


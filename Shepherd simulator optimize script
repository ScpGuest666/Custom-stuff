-------------------------------------------------------------------------------
local function isTrulyVisible(guiObject)
    local current = guiObject
    while current and current:IsA("GuiObject") do
        if not current.Visible then return false end
        if current:IsA("TextLabel") or current:IsA("TextButton") then
            if current.TextTransparency >= 1 then return false end
        end
        current = current.Parent
    end
    return true
end

local function cleanText(str)
    if type(str) ~= "string" then return "" end
    str = string.gsub(str, "<[^>]+>", "") 
    str = string.lower(str) 
    str = string.gsub(str, "%s+", " ") 
    return str
end

local function findUIElementByKeywords(keywords)
    local playerGui = player:FindFirstChild("PlayerGui")
    if not playerGui then return nil end

    for _, desc in ipairs(playerGui:GetDescendants()) do
        if desc:IsA("TextLabel") or desc:IsA("TextButton") then
            if desc.Text and desc.Text ~= "" then
                local text = cleanText(desc.Text)
                local allMatch = true
                for _, kw in ipairs(keywords) do
                    if not string.find(text, string.lower(kw), 1, true) then
                        allMatch = false
                        break
                    end
                end
                if allMatch and isTrulyVisible(desc) then
                    return desc
                end
            end
        end
    end
    return nil
end

local function findUIElementByText(targetText, excludeText)
    local playerGui = player:FindFirstChild("PlayerGui")
    if not playerGui then return nil end

    targetText = string.lower(targetText)
    excludeText = excludeText and string.lower(excludeText) or nil
    
    for _, desc in ipairs(playerGui:GetDescendants()) do
        if desc:IsA("TextLabel") or desc:IsA("TextButton") then
            if desc.Text and desc.Text ~= "" then
                local text = cleanText(desc.Text)
                if string.find(text, targetText, 1, true) then
                    local isExcluded = false
                    if excludeText and string.find(text, excludeText, 1, true) then
                        isExcluded = true
                    end
                    if not isExcluded and isTrulyVisible(desc) then
                        return desc
                    end
                end
            end
        end
    end
    return nil
end

local function clickUIElement(element, buttonName)
    if not element then return false end
    
    local absPos = element.AbsolutePosition
    local absSize = element.AbsoluteSize

    local offsets = buttonOffsets[buttonName] or { offsetX = 50, offsetY = 80 }
    local bOffsetX = offsets.offsetX
    local bOffsetY = offsets.offsetY

    local x = absPos.X + (absSize.X / 2) + bOffsetX
    local y = absPos.Y + (absSize.Y / 2) + bOffsetY

    lastClickX = x
    lastClickY = y

    pointer.Position = UDim2.new(0, x + pointerOffsetX, 0, y + pointerOffsetY)
    pointer.Visible = true

    task.spawn(function()
        pcall(function()
            vim:SendTouchEvent(TOUCH_ID, 0, x, y) 
            task.wait(0.05)
            vim:SendTouchEvent(TOUCH_ID, 1, x, y) 
            task.wait(0.05)
            vim:SendTouchEvent(TOUCH_ID, 2, x, y) 
        end)
        task.wait(0.1)
        pointer.Visible = false
    end)
    
    task.wait(0.2) 
    return true
end


-- GLOBAL CLEANUP & DESTROY
-------------------------------------------------------------------------------
local function cleanupScript()
    isFarming = false
    sideActive = false
    stopHighlighting()
    stopUFODetection()
    showAllSheep()
    
    if farmCoroutine then task.cancel(farmCoroutine) end
    if missingSheepCoroutine then task.cancel(missingSheepCoroutine) end
    if autoBuyCoroutine then task.cancel(autoBuyCoroutine) end
    if limitCheckerCoroutine then task.cancel(limitCheckerCoroutine) end
    if afkConnection then afkConnection:Disconnect() end
    
    pcall(function() vim:SendTouchEvent(TOUCH_ID, 2, 0, 0) end)
    
    _G.AutoBuyTarget = nil
    workspace.CurrentCamera.CameraType = Enum.CameraType.Custom
    
    if screenGui and screenGui.Parent then
        screenGui:Destroy()
    end
end

_G.MySheepFarmScript_Cleanup = cleanupScript


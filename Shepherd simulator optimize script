local toggleWiggle = false
local function doWoolCollection(char, currentHrp)
    if not currentHrp then return end
    toggleWiggle = not toggleWiggle
    local wiggleOffset = toggleWiggle and Vector3.new(0, 0.1, 0) or Vector3.new(0, -0.1, 0)

    for sheepModel, _ in pairs(mySheep) do
        if sheepModel and sheepModel.Parent then
            for _, desc in ipairs(sheepModel:GetDescendants()) do
                if desc:IsA("ProximityPrompt") then
                    if fireproximityprompt then fireproximityprompt(desc)
                    else
                        desc:InputHoldBegin()
                        task.wait(desc.HoldDuration + 0.05)
                        desc:InputHoldEnd()
                    end
                end
                if desc:IsA("BasePart") then
                    if firetouchinterest then
                        firetouchinterest(currentHrp, desc, 0)
                        firetouchinterest(currentHrp, desc, 1)
                    end
                end
            end
            if not activeFakeLimb or not activeFakeLimb.Parent then
                activeFakeLimb = Instance.new("Part")
                activeFakeLimb.Name = "Right Arm"
                activeFakeLimb.CanCollide = false
                activeFakeLimb.Transparency = 1
                activeFakeLimb.Massless = true
                activeFakeLimb.Parent = char
            end
            local sheepCFrame, sheepSize = sheepModel:GetBoundingBox()
            if activeFakeLimb and activeFakeLimb.Parent then
                activeFakeLimb.Size = sheepSize + Vector3.new(2, 2, 2)
                activeFakeLimb.CFrame = sheepCFrame + wiggleOffset
            end
        else
            mySheep[sheepModel] = nil 
        end
    end
end

local function secureSheepForAutoBuy(hrp, grazeAreaCFrame)
    status.Text = "Securing Sheep for Auto-Buy..."
    while isFarming and _G.AutoBuyTarget do
        local stopBtn = findUIElementByText("stop grazing")
        local grazeBtn = findUIElementByText("graze", "stop")
        local bringInBtn = findUIElementByText("bring in")
        local bringOutBtn = findUIElementByText("bring out")
        
        if stopBtn then
            if (hrp.Position - grazeAreaCFrame.Position).Magnitude > 50 then hrp.CFrame = grazeAreaCFrame; task.wait(1.5)
            else clickUIElement(stopBtn, "Stop Grazing"); task.wait(1.5) end
        elseif grazeBtn then
            if (hrp.Position - originalCFrame.Position).Magnitude > 50 then hrp.CFrame = originalCFrame; task.wait(1.5)
            else hrp.CFrame = grazeAreaCFrame; task.wait(1.5) end
        elseif bringInBtn then
            if (hrp.Position - originalCFrame.Position).Magnitude > 50 then hrp.CFrame = originalCFrame; task.wait(1.5)
            else clickUIElement(bringInBtn, "Bring in"); task.wait(1.5) end
        elseif bringOutBtn then
            _G.SheepSecured = true
            status.Text = "Sheep Secured. Auto-Buying..."
            
            while _G.AutoBuyTarget and isFarming do task.wait(0.5) end
            
            _G.SheepSecured = false
            
            if hrp and originalCFrame then
                hrp.CFrame = originalCFrame
                task.wait(0.5)
            end
            return 
        else
            if (hrp.Position - originalCFrame.Position).Magnitude > 50 then hrp.CFrame = originalCFrame; task.wait(1.5)
            else hrp.CFrame = grazeAreaCFrame; task.wait(1.5) end
        end
    end
end

local function startFarmingCycle()
    local character = player.Character
    local hrp = character and character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    local grazeAreaCFrame = CFrame.new(176.67967224121095, 10.65000057220459, 311.4925231933594)

    while isFarming do
        if _G.AutoBuyTarget then
            secureSheepForAutoBuy(hrp, grazeAreaCFrame)
            continue 
        end

        local currentFarmDuration = 4 * 60 
        status.Text = "Bringing Out..."
        while isFarming do
            local bringOutBtn = findUIElementByText("bring out")
            if bringOutBtn then
                clickUIElement(bringOutBtn, "Bring out")
                task.wait(1)
                if not findUIElementByText("bring out") then break end
            else
                if findUIElementByText("bring in") or findUIElementByText("graze", "stop") then break end
                local sheepList = {}
                for _, part in pairs(mySheep) do
                    if part and part.Parent then table.insert(sheepList, part) end
                end
                if #sheepList > 0 then
                    hrp.CFrame = sheepList[math.random(1, #sheepList)].CFrame + Vector3.new(0, 3, 0)
                else
                    hrp.CFrame = originalCFrame
                end
                task.wait(0.5)
            end
        end
        if not isFarming then break end

        status.Text = "Going to Graze Area..."
        local uiAppeared = false
        while isFarming and not uiAppeared do
            hrp.CFrame = grazeAreaCFrame
            task.wait(1.5)
            if findUIElementByText("graze", "stop") or findUIElementByText("stop grazing") then
                uiAppeared = true
            else
                status.Text = "UI Missing! Retrying..."
                hrp.CFrame = originalCFrame
                task.wait(1.5)
            end
        end
        if not isFarming then break end

        local elapsedGrazeTime = 0
        local maxGrazeTime = 30 
        local isAtGrazeArea = true

        while isFarming and elapsedGrazeTime < maxGrazeTime do
            if _G.AutoBuyTarget then break end 

            if ufoState.threatLevel >= 2 then
                local stopBtn = findUIElementByText("stop grazing")
                if stopBtn then clickUIElement(stopBtn, "Stop Grazing"); task.wait(1) end
                if isAtGrazeArea then
                    status.Text = "UFO Inside! Evading..."
                    hrp.CFrame = originalCFrame
                    isAtGrazeArea = false
                    task.wait(1.5)
                end
                local bringInBtn = findUIElementByText("bring in")
                if bringInBtn then clickUIElement(bringInBtn, "Bring in"); task.wait(1) end
                doWoolCollection(player.Character, hrp)
                task.wait(0.5)
            else
                if not isAtGrazeArea then
                    status.Text = "Threat Cleared! Bringing Out..."
                    local bringOutBtn = findUIElementByText("bring out")
                    if bringOutBtn then clickUIElement(bringOutBtn, "Bring out"); task.wait(1) end
                    local returnUiAppeared = false
                    while isFarming and not returnUiAppeared do
                        if ufoState.threatLevel >= 2 or _G.AutoBuyTarget then break end
                        hrp.CFrame = grazeAreaCFrame
                        task.wait(1.5)
                        if findUIElementByText("graze", "stop") or findUIElementByText("stop grazing") then
                            returnUiAppeared = true
                        else
                            hrp.CFrame = originalCFrame
                            task.wait(1.5)
                            local retryBringOut = findUIElementByText("bring out")
                            if retryBringOut then clickUIElement(retryBringOut, "Bring out"); task.wait(1) end
                        end
                    end
                    if not returnUiAppeared then continue end
                    isAtGrazeArea = true
                end

                if not findUIElementByText("graze", "stop") and not findUIElementByText("stop grazing") then
                    hrp.CFrame = originalCFrame
                    task.wait(1.5)
                    hrp.CFrame = grazeAreaCFrame
                    task.wait(1.5)
                    continue
                end

                local waitTime = 0
                while waitTime < 2 and isFarming do
                    if ufoState.threatLevel >= 2 or _G.AutoBuyTarget then break end
                    status.Text = string.format("Grazing... (%d/%d)", math.floor(elapsedGrazeTime + waitTime), maxGrazeTime)
                    task.wait(0.1)
                    waitTime = waitTime + 0.1
                end
                elapsedGrazeTime = elapsedGrazeTime + waitTime
                if not isFarming or ufoState.threatLevel >= 2 or _G.AutoBuyTarget then continue end
                
                local stopBtn = findUIElementByText("stop grazing")
                if stopBtn then clickUIElement(stopBtn, "Stop Grazing") end
                
                local pollTime = 0
                while isFarming do
                    if ufoState.threatLevel >= 2 or _G.AutoBuyTarget then break end
                    local grazeBtn = findUIElementByText("graze", "stop")
                    if grazeBtn then clickUIElement(grazeBtn, "Graze"); break end
                    if not grazeBtn and not findUIElementByText("stop grazing") and pollTime > 1 then break end
                    task.wait(0.03)
                    pollTime = pollTime + 0.03
                    if pollTime > 2 then break end
                end
                elapsedGrazeTime = elapsedGrazeTime + pollTime
                if findUIElementByText("are full") then break end
            end
        end
        if not isFarming then break end
        if _G.AutoBuyTarget then continue end 

        status.Text = "Finishing Graze & Returning..."
        while isFarming do
            local stopBtn = findUIElementByText("stop grazing")
            local grazeBtn = findUIElementByText("graze", "stop")
            local bringInBtn = findUIElementByText("bring in")
            local bringOutBtn = findUIElementByText("bring out")

            if stopBtn then
                if (hrp.Position - grazeAreaCFrame.Position).Magnitude > 50 then hrp.CFrame = grazeAreaCFrame; task.wait(1.5)
                else clickUIElement(stopBtn, "Stop Grazing"); task.wait(1.5) end
            elseif grazeBtn then
                if (hrp.Position - originalCFrame.Position).Magnitude > 50 then hrp.CFrame = originalCFrame; task.wait(1.5)
                else hrp.CFrame = grazeAreaCFrame; task.wait(1.5) end
            elseif bringInBtn then
                local currentSheep, totalSheep = getSheepCountFromUI()
                if currentSheep and (currentSheep == 0 or currentSheep == 2 or currentSheep == 4) then
                    hrp.CFrame = grazeAreaCFrame; task.wait(1.5)
                    local recoverStop = findUIElementByText("stop grazing")
                    if recoverStop then clickUIElement(recoverStop, "Stop Grazing"); task.wait(1.5) end
                else
                    if (hrp.Position - originalCFrame.Position).Magnitude > 50 then hrp.CFrame = originalCFrame; task.wait(1.5)
                    else clickUIElement(bringInBtn, "Bring in"); task.wait(1.5) end
                end
            elseif bringOutBtn then
                local sheepAreNear = false
                for sheepModel, part in pairs(mySheep) do
                    if part and part.Parent and (part.Position - hrp.Position).Magnitude < 80 then
                        sheepAreNear = true; break
                    end
                end
                if sheepAreNear then break
                else
                    hrp.CFrame = grazeAreaCFrame; task.wait(1.5)
                    local recoverStop = findUIElementByText("stop grazing")
                    if recoverStop then clickUIElement(recoverStop, "Stop Grazing"); task.wait(1.5) end
                end
            else
                if (hrp.Position - originalCFrame.Position).Magnitude > 50 then hrp.CFrame = originalCFrame; task.wait(1.5)
                else hrp.CFrame = grazeAreaCFrame; task.wait(1.5) end
            end
        end
        if not isFarming then break end
        if _G.AutoBuyTarget then continue end

        local endTime = os.time() + currentFarmDuration
        while isFarming and os.time() < endTime do
            if _G.AutoBuyTarget then break end
            local remaining = endTime - os.time()
            status.Text = string.format("%02d:%02d", math.floor(remaining / 60), remaining % 60)
            local char = player.Character
            local currentHrp = char and char:FindFirstChild("HumanoidRootPart")
            if currentHrp then doWoolCollection(char, currentHrp); task.wait(0.5) else task.wait(1) end
        end

        if isFarming and originalCFrame and not _G.AutoBuyTarget then
            local char = player.Character
            local finalHrp = char and char:FindFirstChild("HumanoidRootPart")
            if finalHrp then finalHrp.CFrame = originalCFrame; task.wait(0.5) end
        end
    end
end


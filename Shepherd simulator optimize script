local targetKeywords = { "heavenly pasture", "heavenly_pasture", "heavenlypasture", "pasture 6", "pasture_6", "pasture6" }

local function containsKeyword(text)
    if type(text) ~= "string" then return false end
    local lowerText = string.lower(text)
    for _, kw in ipairs(targetKeywords) do
        if string.find(lowerText, kw, 1, true) then return true end
    end
    return false
end

local function isUFOTargetingPasture(ufoModel)
    if containsKeyword(ufoModel.Name) then return true end
    for attr, val in pairs(ufoModel:GetAttributes()) do
        if containsKeyword(attr) or containsKeyword(tostring(val)) then return true end
    end
    for _, desc in ipairs(ufoModel:GetDescendants()) do
        if containsKeyword(desc.Name) then return true end
        if desc:IsA("StringValue") and containsKeyword(desc.Value) then return true end
        if desc:IsA("ObjectValue") and desc.Value and containsKeyword(desc.Value.Name) then return true end
        if desc:IsA("TextLabel") or desc:IsA("TextButton") then
            if containsKeyword(desc.Text) then return true end
        end
    end
    return false
end

local function isHeadingTowards(ufoPos, ufoVel, targetPos, targetRadius)
    local ux, uz = ufoPos.X, ufoPos.Z
    local vx, vz = ufoVel.X, ufoVel.Z
    local tx, tz = targetPos.X, targetPos.Z
    local speedXZ = math.sqrt(vx^2 + vz^2)
    if speedXZ < 0.5 then return false end 
    local wx, wz = tx - ux, tz - uz
    local dot = (vx * wx) + (vz * wz)
    if dot <= 0 then return false end 
    local dist = math.abs(vz * tx - vx * tz + vx * uz - vz * ux) / speedXZ
    return dist <= targetRadius
end

local function startUFODetection()
    activeUFOsCache = {}
    ufoData = {}
    trackedUFOs = {}
    ufoState.threatLevel = 0

    local function checkAndCacheUFO(desc)
        if desc.Name == "FlyingSaucer" then
            task.spawn(function()
                task.wait(0.5)
                local ufoPart = desc:IsA("BasePart") and desc or desc:FindFirstChildWhichIsA("BasePart")
                if ufoPart then
                    activeUFOsCache[ufoPart] = true
                    local isTargeting = isUFOTargetingPasture(desc)
                    ufoData[ufoPart] = { lastPos = ufoPart.Position, velocity = Vector3.new(0,0,0), isTargeting = isTargeting }
                end
            end)
        elseif desc.Parent and desc.Parent.Name == "FlyingSaucer" and desc:IsA("BasePart") then
            activeUFOsCache[desc] = true
        end
    end

    for _, desc in ipairs(workspace:GetDescendants()) do checkAndCacheUFO(desc) end
    ufoAddedConn = workspace.DescendantAdded:Connect(checkAndCacheUFO)
    ufoRemovedConn = workspace.DescendantRemoving:Connect(function(desc)
        if desc.Name == "FlyingSaucer" then
            for part, _ in pairs(activeUFOsCache) do
                if part == desc or part:IsDescendantOf(desc) then
                    activeUFOsCache[part] = nil
                end
            end
        end
    end)

    ufoHeartbeatConn = RunService.Heartbeat:Connect(function(dt)
        if not foundPasture then
            for _, desc in ipairs(workspace:GetDescendants()) do
                if desc.Name == "Pasture_6" then
                    if desc:IsA("BasePart") then foundPasture = desc; break
                    elseif desc:IsA("Model") or desc:IsA("Folder") then
                        foundPasture = desc:FindFirstChildWhichIsA("BasePart")
                        if foundPasture then break end
                    end
                end
            end
            if foundPasture and not zoneVisualizer then
                zoneVisualizer = Instance.new("Part")
                zoneVisualizer.Name = "UFO_Detection_Zone"
                zoneVisualizer.Shape = Enum.PartType.Block 
                zoneVisualizer.Size = Vector3.new(foundPasture.Size.X, 3000, foundPasture.Size.Z) 
                zoneVisualizer.CFrame = foundPasture.CFrame 
                zoneVisualizer.Anchored = true
                zoneVisualizer.CanCollide = false
                zoneVisualizer.CastShadow = false
                zoneVisualizer.Transparency = 0.5 
                zoneVisualizer.Color = Color3.fromRGB(255, 85, 0) 
                zoneVisualizer.Material = Enum.Material.SmoothPlastic
                zoneVisualizer.Parent = workspace
            end
        end

        if not foundPasture then return end

        local pasturePos = foundPasture.Position
        local pastureTopY = pasturePos.Y + (foundPasture.Size.Y / 2) + 15 
        local incomingRadius = math.max(foundPasture.Size.X, foundPasture.Size.Z)
        local highestThreat = 0

        for ufoPart, _ in pairs(activeUFOsCache) do
            if ufoPart and ufoPart.Parent then
                local currentPos = ufoPart.Position
                local data = ufoData[ufoPart]
                if not data then
                    data = { lastPos = currentPos, velocity = Vector3.new(0,0,0), isTargeting = false }
                    ufoData[ufoPart] = data
                else
                    data.velocity = (currentPos - data.lastPos) / dt
                    data.lastPos = currentPos
                end

                local localPos = foundPasture.CFrame:PointToObjectSpace(currentPos)
                local isInside = math.abs(localPos.X) <= (foundPasture.Size.X / 2) and math.abs(localPos.Z) <= (foundPasture.Size.Z / 2)
                local threat = 0

                if isInside then
                    if currentPos.Y > pastureTopY and data.velocity.Y > 0.5 then threat = 3
                    else threat = 2 end
                else
                    if data.isTargeting then threat = 2 
                    elseif isHeadingTowards(currentPos, data.velocity, pasturePos, incomingRadius) then threat = 1 end
                end

                if threat > highestThreat then highestThreat = threat end

                if threat > 0 then
                    local ufoESP = trackedUFOs[ufoPart]
                    if not ufoESP then
                        ufoESP = Instance.new("Highlight")
                        ufoESP.Name = "UFO_ESP"
                        ufoESP.FillTransparency = 0.5
                        ufoESP.OutlineTransparency = 0
                        ufoESP.Parent = ufoPart
                        trackedUFOs[ufoPart] = ufoESP
                    end
                    if data.isTargeting then
                        local cycle = (math.sin(os.clock() * 8) + 1) / 2 
                        local flashColor = Color3.fromRGB(255, 0, 0):Lerp(Color3.fromRGB(0, 0, 255), cycle)
                        ufoESP.FillColor = flashColor
                        ufoESP.OutlineColor = flashColor
                    else
                        ufoESP.FillColor = Color3.fromRGB(170, 0, 255)
                        ufoESP.OutlineColor = Color3.fromRGB(255, 255, 255)
                    end
                else
                    if trackedUFOs[ufoPart] then
                        trackedUFOs[ufoPart]:Destroy()
                        trackedUFOs[ufoPart] = nil
                    end
                end
            else
                activeUFOsCache[ufoPart] = nil
                ufoData[ufoPart] = nil
                if trackedUFOs[ufoPart] then
                    trackedUFOs[ufoPart]:Destroy()
                    trackedUFOs[ufoPart] = nil
                end
            end
        end
        ufoState.threatLevel = highestThreat
    end)
end

local function stopUFODetection()
    if ufoAddedConn then ufoAddedConn:Disconnect(); ufoAddedConn = nil end
    if ufoRemovedConn then ufoRemovedConn:Disconnect(); ufoRemovedConn = nil end
    if ufoHeartbeatConn then ufoHeartbeatConn:Disconnect(); ufoHeartbeatConn = nil end
    ufoState.threatLevel = 0
    for ufo, esp in pairs(trackedUFOs) do if esp then esp:Destroy() end end
    trackedUFOs = {}
    ufoData = {}
    activeUFOsCache = {}
    foundPasture = nil
    if zoneVisualizer then zoneVisualizer:Destroy(); zoneVisualizer = nil end
end


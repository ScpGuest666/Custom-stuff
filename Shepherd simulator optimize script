local toggleWiggle = false
local function doWoolCollection(char, currentHrp)
    if not currentHrp then return end
    toggleWiggle = not toggleWiggle
    local wiggleOffset = toggleWiggle and Vector3.new(0, 0.1, 0) or Vector3.new(0, -0.1, 0)

    for sheepModel, _ in pairs(mySheep) do
        if sheepModel and sheepModel.Parent then
            for _, desc in ipairs(sheepModel:GetDescendants()) do
                if desc:IsA("ProximityPrompt") then
                    if fireproximityprompt then
                        fireproximityprompt(desc)
                    else
                        desc:InputHoldBegin()
                        task.wait(desc.HoldDuration + 0.05)
                        desc:InputHoldEnd()
                    end
                end
                if desc:IsA("BasePart") then
                    if firetouchinterest then
                        firetouchinterest(currentHrp, desc, 0)
                        firetouchinterest(currentHrp, desc, 1)
                    end
                end
            end

            if not activeFakeLimb or not activeFakeLimb.Parent then
                activeFakeLimb = Instance.new("Part")
                activeFakeLimb.Name = "Right Arm"
                activeFakeLimb.CanCollide = false
                activeFakeLimb.Transparency = 1
                activeFakeLimb.Massless = true
                activeFakeLimb.Parent = char
            end
            
            local sheepCFrame, sheepSize = sheepModel:GetBoundingBox()
            if activeFakeLimb and activeFakeLimb.Parent then
                activeFakeLimb.Size = sheepSize + Vector3.new(2, 2, 2)
                activeFakeLimb.CFrame = sheepCFrame + wiggleOffset
            end
        else
            mySheep[sheepModel] = nil 
        end
    end
end

-------------------------------------------------------------------------------
-- UFO LOCK-ON ENGINE (STRICT RADIUS, ZERO FLICKER)
-------------------------------------------------------------------------------
RunService.Heartbeat:Connect(function(dt)
    if not isFarming then return end

    if not foundPasture then
        for _, desc in ipairs(workspace:GetDescendants()) do
            if desc.Name == "Pasture_6" then
                if desc:IsA("BasePart") then
                    foundPasture = desc
                    break
                elseif desc:IsA("Model") or desc:IsA("Folder") then
                    foundPasture = desc:FindFirstChildWhichIsA("BasePart")
                    if foundPasture then break end
                end
            end
        end
    end

    if not foundPasture then return end

    local pasturePos = foundPasture.Position
    local pastureTopY = pasturePos.Y + (foundPasture.Size.Y / 2) + 15 

    -- 1. Check if our locked UFO was destroyed/despawned
    if ufoState.lockedUFO and not ufoState.lockedUFO.Parent then
        ufoState.lockedUFO = nil
        ufoState.threatLevel = 0
    end

    -- 2. If we don't have a locked UFO, scan the sky directly above Pasture 6
    if not ufoState.lockedUFO then
        -- STRICT RADIUS: Only 60% of the smallest width. Completely ignores Pasture 5.
        local searchRadius = (math.min(foundPasture.Size.X, foundPasture.Size.Z) / 2) * 0.6 
        
        for ufoPart, _ in pairs(activeUFOsCache) do
            if ufoPart and ufoPart.Parent then
                local distXZ = math.sqrt((ufoPart.Position.X - pasturePos.X)^2 + (ufoPart.Position.Z - pasturePos.Z)^2)
                if distXZ <= searchRadius then
                    ufoState.lockedUFO = ufoPart
                    break 
                end
            else
                activeUFOsCache[ufoPart] = nil
            end
        end
    end

    -- 3. Process the Locked UFO
    if ufoState.lockedUFO then
        local ufoPart = ufoState.lockedUFO
        local currentPos = ufoPart.Position
        local data = ufoData[ufoPart]
        
        if not data then
            data = { lastPos = currentPos, velocity = Vector3.new(0,0,0) }
            ufoData[ufoPart] = data
        else
            data.velocity = (currentPos - data.lastPos) / dt
            data.lastPos = currentPos
        end

        -- Threat Level Logic
        if currentPos.Y > pastureTopY and data.velocity.Y > 0.5 then
            ufoState.threatLevel = 2 -- Strike Confirmed! Ascending!
        else
            ufoState.threatLevel = 1 -- Locked & Descending/Hovering
        end

        -- Apply ESP Highlight
        if not trackedUFOs[ufoPart] then
            local ufoESP = Instance.new("Highlight")
            ufoESP.Name = "UFO_ESP"
            ufoESP.FillColor = Color3.fromRGB(170, 0, 255)
            ufoESP.OutlineColor = Color3.fromRGB(255, 255, 255)
            ufoESP.FillTransparency = 0.5
            ufoESP.OutlineTransparency = 0
            ufoESP.Parent = ufoPart
            trackedUFOs[ufoPart] = ufoESP
        end
    end

    -- 4. Cleanup ESPs for any UFOs that are NOT our locked target
    for ufo, esp in pairs(trackedUFOs) do
        if ufo ~= ufoState.lockedUFO then
            if esp then esp:Destroy() end
            trackedUFOs[ufo] = nil
            ufoData[ufo] = nil
        end
    end
end)


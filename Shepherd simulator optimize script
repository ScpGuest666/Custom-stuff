local function startFarmingCycle()
    local character = player.Character
    local hrp = character and character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    local grazeAreaCFrame = CFrame.new(176.67967224121095, 10.65000057220459, 311.4925231933594)

    while isFarming do
        local currentFarmDuration = 4 * 60 

        ---------------------------------------------------------
        -- PHASE 1: BRING OUT
        ---------------------------------------------------------
        status.Text = "Bringing Out..."
        while isFarming do
            local bringOutBtn = findUIElementByText("bring out")
            if bringOutBtn then
                clickUIElement(bringOutBtn, "Bring out")
                task.wait(1)
                
                if not findUIElementByText("bring out") then
                    break
                end
            else
                if findUIElementByText("bring in") or findUIElementByText("graze", "stop") then
                    break
                end
                
                local sheepList = {}
                for _, part in pairs(mySheep) do
                    if part and part.Parent then
                        table.insert(sheepList, part)
                    end
                end
                
                if #sheepList > 0 then
                    local randomSheep = sheepList[math.random(1, #sheepList)]
                    hrp.CFrame = randomSheep.CFrame + Vector3.new(0, 3, 0)
                else
                    hrp.CFrame = originalCFrame
                end
                
                task.wait(0.5)
            end
        end
        if not isFarming then break end

        ---------------------------------------------------------
        -- PHASE 2: TELEPORT TO GRAZE AREA & VERIFY UI
        ---------------------------------------------------------
        status.Text = "Going to Graze Area..."
        
        local uiAppeared = false
        while isFarming and not uiAppeared do
            hrp.CFrame = grazeAreaCFrame
            task.wait(1.5)
            
            if not isFarming then break end
            
            local grazeBtn = findUIElementByText("graze", "stop")
            local stopBtn = findUIElementByText("stop grazing")
            
            if grazeBtn or stopBtn then
                uiAppeared = true
            else
                status.Text = "UI Missing! Retrying..."
                hrp.CFrame = originalCFrame
                task.wait(1.5)
            end
        end
        if not isFarming then break end

        ---------------------------------------------------------
        -- PHASE 3 & 4: DYNAMIC GRAZING & ACTIVE EVASION
        ---------------------------------------------------------
        local elapsedGrazeTime = 0
        local maxGrazeTime = 30 
        local isAtGrazeArea = true

        while isFarming and elapsedGrazeTime < maxGrazeTime do
            
            if ufoState.threatLevel > 0 then
                
                -- 1. Bail out immediately (Stop Grazing)
                local stopBtn = findUIElementByText("stop grazing")
                if stopBtn then 
                    clickUIElement(stopBtn, "Stop Grazing") 
                end

                -- 2. Teleport character back to sheepfold to physically evade
                if isAtGrazeArea then
                    status.Text = "Evading! Teleporting to Sheepfold..."
                    hrp.CFrame = originalCFrame
                    isAtGrazeArea = false
                    task.wait(1.5) -- Wait for teleport and UI update
                end

                -- 3. Bring In Sheep to protect them
                local bringInBtn = findUIElementByText("bring in")
                if bringInBtn then
                    clickUIElement(bringInBtn, "Bring in")
                    task.wait(1)
                end

                -- 4. Actively Collect Wool while waiting for UFO to leave
                status.Text = "UFO Threat! Collecting Wool..."
                doWoolCollection(player.Character, hrp)
                task.wait(0.5)
                
            else
                -- NO THREAT (SAFE TO GRAZE)
                
                -- If we were evading and the threat cleared, return to graze area
                if not isAtGrazeArea then
                    status.Text = "Threat Cleared! Bringing Out..."
                    
                    -- Bring sheep back out
                    local bringOutBtn = findUIElementByText("bring out")
                    if bringOutBtn then
                        clickUIElement(bringOutBtn, "Bring out")
                        task.wait(1)
                    end

                    -- Teleport to Graze Area
                    local returnUiAppeared = false
                    while isFarming and not returnUiAppeared and ufoState.threatLevel == 0 do
                        hrp.CFrame = grazeAreaCFrame
                        task.wait(1.5)
                        
                        if not isFarming or ufoState.threatLevel > 0 then break end
                        
                        local grazeBtn = findUIElementByText("graze", "stop")
                        local stopBtn2 = findUIElementByText("stop grazing")
                        
                        if grazeBtn or stopBtn2 then
                            returnUiAppeared = true
                        else
                            status.Text = "UI Missing! Retrying..."
                            hrp.CFrame = originalCFrame
                            task.wait(1.5)
                            
                            -- Ensure sheep are brought out if we had to retry
                            local retryBringOut = findUIElementByText("bring out")
                            if retryBringOut then
                                clickUIElement(retryBringOut, "Bring out")
                                task.wait(1)
                            end
                        end
                    end
                    
                    if ufoState.threatLevel > 0 then continue end -- Threat returned while we were trying to go back
                    isAtGrazeArea = true
                end

                status.Text = string.format("Grazing... (%d/%d)", math.floor(elapsedGrazeTime), maxGrazeTime)
                
                -- 1. Wait exactly 2 seconds before pressing Stop Grazing
                task.wait(2)
                elapsedGrazeTime = elapsedGrazeTime + 2
                
                -- Re-check threat just in case a UFO appeared during that 2 second wait
                if not isFarming or ufoState.threatLevel > 0 then continue end
                
                -- 2. Press Stop Grazing
                local stopBtn = findUIElementByText("stop grazing")
                if stopBtn then 
                    clickUIElement(stopBtn, "Stop Grazing") 
                end
                
                -- 3. Lightning Fast Reaction: Wait for Graze button to appear and click it instantly
                local pollTime = 0
                while isFarming and ufoState.threatLevel == 0 do
                    local grazeBtn = findUIElementByText("graze", "stop")
                    if grazeBtn then 
                        clickUIElement(grazeBtn, "Graze") 
                        break 
                    end
                    task.wait(0.03) -- 30ms polling rate for near-instant reaction
                    pollTime = pollTime + 0.03
                    if pollTime > 2 then break end -- 2-second safety timeout to prevent infinite loops
                end
                
                elapsedGrazeTime = elapsedGrazeTime + pollTime

                if findUIElementByText("are full") then
                    currentFarmDuration = 4 * 60
                    break
                end
            end
        end
        if not isFarming then break end

        ---------------------------------------------------------
        -- PHASE 5: FINISH GRAZE (STRICT SYNC)
        ---------------------------------------------------------
        status.Text = "Finishing Graze..."
        local successfullyStopped = false
        while isFarming and not successfullyStopped do
            local finalStopBtn = findUIElementByText("stop grazing")
            if finalStopBtn then 
                clickUIElement(finalStopBtn, "Stop Grazing") 
                task.wait(1) -- Wait for server to process the click
            end
            
            -- Verify that Stop Grazing is gone and Graze is present
            local checkStop = findUIElementByText("stop grazing")
            local checkGraze = findUIElementByText("graze", "stop")
            
            if checkGraze and not checkStop then
                status.Text = "Graze Stopped. Syncing..."
                task.wait(2) -- CRUCIAL: Wait 2 seconds to let the server teleport sheep to the player before we leave
                successfullyStopped = true
            end
            task.wait(0.5)
        end
        
        if not isFarming then break end

        ---------------------------------------------------------
        -- PHASE 5.5: RETURN TO SHEEPFOLD & VERIFY UI
        ---------------------------------------------------------
        status.Text = "Returning to Sheepfold..."
        local sheepfoldUiAppeared = false
        
        while isFarming and not sheepfoldUiAppeared do
            hrp.CFrame = originalCFrame
            task.wait(1.5)
            
            if not isFarming then break end
            
            local bringInBtn = findUIElementByText("bring in")
            local bringOutBtn = findUIElementByText("bring out")
            local grazeBtn = findUIElementByText("graze", "stop")
            local stopBtn = findUIElementByText("stop grazing")
            
            if grazeBtn or stopBtn then
                -- UI is bugged, still showing grazing buttons
                status.Text = "UI Bugged! Retrying Zone..."
                hrp.CFrame = grazeAreaCFrame
                task.wait(1.5)
            elseif bringInBtn then
                -- Perfect, ready to bring in
                sheepfoldUiAppeared = true
            elseif bringOutBtn then
                -- UI says Bring Out. Did the sheep follow us, or were they left behind?
                local sheepAreNear = false
                for sheepModel, part in pairs(mySheep) do
                    if part and part.Parent and (part.Position - hrp.Position).Magnitude < 80 then
                        sheepAreNear = true
                        break
                    end
                end
                
                if sheepAreNear then
                    -- Sheep are here, they were already brought in somehow
                    sheepfoldUiAppeared = true 
                else
                    -- Sheep are missing! They got left behind at the grazing area.
                    status.Text = "Sheep Left Behind! Recovering..."
                    hrp.CFrame = grazeAreaCFrame
                    task.wait(1.5)
                    
                    -- Try to stop grazing again just in case
                    local recoverStop = findUIElementByText("stop grazing")
                    if recoverStop then 
                        clickUIElement(recoverStop, "Stop Grazing") 
                        task.wait(1.5)
                    end
                end
            else
                status.Text = "UI Missing! Retrying Sheepfold..."
                hrp.CFrame = grazeAreaCFrame
                task.wait(1.5)
            end
        end
        if not isFarming then break end

        ---------------------------------------------------------
        -- PHASE 6: BRING IN
        ---------------------------------------------------------
        status.Text = "Bringing In..."
        while isFarming do
            local bringInBtn = findUIElementByText("bring in")
            if bringInBtn then
                clickUIElement(bringInBtn, "Bring in")
                task.wait(1)
            else
                local bringOutBtn = findUIElementByText("bring out")
                if bringOutBtn then
                    break -- Successfully brought in
                end
            end
            task.wait(0.5)
        end
        if not isFarming then break end

        ---------------------------------------------------------
        -- PHASE 7: FARM SHEEP (WOOL COLLECTION)
        ---------------------------------------------------------
        local endTime = os.time() + currentFarmDuration
        
        while isFarming and os.time() < endTime do
            local remaining = endTime - os.time()
            local mins = math.floor(remaining / 60)
            local secs = remaining % 60
            status.Text = string.format("%02d:%02d", mins, secs)

            local char = player.Character
            local currentHrp = char and char:FindFirstChild("HumanoidRootPart")

            if currentHrp then
                doWoolCollection(char, currentHrp)
                task.wait(0.5) 
            else
                task.wait(1) 
            end
        end

        if isFarming and originalCFrame then
            local char = player.Character
            local finalHrp = char and char:FindFirstChild("HumanoidRootPart")
            if finalHrp then
                finalHrp.CFrame = originalCFrame
                task.wait(0.5) 
            end
        end
    end
end


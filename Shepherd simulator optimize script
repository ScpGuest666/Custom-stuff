-------------------------------------------------------------------------------
-- FRAME 2: ESP & AUTO-BUY LOGIC
-------------------------------------------------------------------------------
local isActive = false
local boxEspObjects = {} 
local trackedSheep = {} 
local activeLabels = {} 
local myBoxes = {}
local sheepStart = nil
local sheepEnd = nil
local sheepConnection
local renderConnection
local trackerLoopCoroutine = nil

local function getPosition(obj)
    if obj:IsA("Model") then
        if obj.PrimaryPart then return obj.PrimaryPart.Position else return obj:GetPivot().Position end
    elseif obj:IsA("BasePart") then return obj.Position end
    return nil
end

local function getSheepColor(sheep)
    if sheep:IsA("BasePart") then return sheep.Color end
    local bestPart = nil
    for _, child in ipairs(sheep:GetDescendants()) do
        if child:IsA("BasePart") then
            local name = string.lower(child.Name)
            if string.find(name, "body") or string.find(name, "torso") or string.find(name, "fleece") then return child.Color end
            if not bestPart then bestPart = child end
        end
    end
    return bestPart and bestPart.Color or Color3.fromRGB(255, 255, 255)
end

local function getTopSheepModel(obj)
    if not obj or not obj:IsA("Model") then return nil end
    local name = string.lower(obj.Name)
    if not (string.find(name, "sheep") or string.find(name, "sheel")) then return nil end
    local current = obj
    while current.Parent and current.Parent:IsA("Model") do
        local pName = string.lower(current.Parent.Name)
        if string.find(pName, "sheep") or string.find(pName, "sheel") then current = current.Parent else break end
    end
    return current
end

local function findMyBoxesAndPath()
    table.clear(myBoxes)
    sheepStart = nil
    sheepEnd = nil
    local char = player.Character or player.CharacterAdded:Wait()
    local hrp = char:WaitForChild("HumanoidRootPart")
    local allBoxes = {}
    for _, v in pairs(workspace:GetDescendants()) do
        if v.Name == "Box1" and (v:IsA("Model") or v:IsA("BasePart")) then table.insert(allBoxes, v) end
    end
    table.sort(allBoxes, function(a, b)
        local posA, posB = getPosition(a), getPosition(b)
        if posA and posB then return (posA - hrp.Position).Magnitude < (posB - hrp.Position).Magnitude end
        return false
    end)
    if allBoxes[1] then table.insert(myBoxes, allBoxes[1]) end
    if allBoxes[2] then table.insert(myBoxes, allBoxes[2]) end
    for _, box in ipairs(myBoxes) do
        local startNode = box:FindFirstChild("SheepStart", true)
        if startNode then sheepStart = startNode end
        local endNode = box:FindFirstChild("SheepEnd", true)
        if endNode then sheepEnd = endNode end
    end
end

local function getDistanceToPen(pos)
    local a = sheepStart and getPosition(sheepStart) or (myBoxes[1] and getPosition(myBoxes[1]))
    local b = sheepEnd and getPosition(sheepEnd) or (myBoxes[2] and getPosition(myBoxes[2]))
    if a and b then
        local ab = b - a
        local ap = pos - a
        local dotAB = ab:Dot(ab)
        if dotAB == 0 then return (pos - a).Magnitude end
        local t = math.clamp(ap:Dot(ab) / dotAB, 0, 1)
        local closestPoint = a + ab * t
        return (pos - closestPoint).Magnitude
    elseif a then return (pos - a).Magnitude
    elseif b then return (pos - b).Magnitude end
    return 999
end

local function isSheepValidToTrack(topSheep)
    if not topSheep or not topSheep.Parent then return false end
    local ownerTag = topSheep:FindFirstChild("Owner", true) or topSheep:FindFirstChild("owner", true)
    if ownerTag and tostring(ownerTag.Value) ~= "" then return false end
    return true
end

local function shouldRemoveHighlight(topSheep)
    if not topSheep or not topSheep.Parent then return true end
    if not isSheepValidToTrack(topSheep) then return true end
    
    local pos = getPosition(topSheep)
    if not pos then return true end
    
    -- REMOVE HIGHLIGHT IF IT WALKS OUT OF RANGE
    if getDistanceToPen(pos) > 35 then
        return true
    end
    
    if sheepEnd then
        local endPos = getPosition(sheepEnd)
        if endPos and (pos - endPos).Magnitude <= 25 then
            return true
        end
    end
    
    return false
end

local function unhighlightSheep(sheep)
    if trackedSheep[sheep] then
        if trackedSheep[sheep].highlight then trackedSheep[sheep].highlight:Destroy() end
        if trackedSheep[sheep].billboard then trackedSheep[sheep].billboard:Destroy() end
        activeLabels[trackedSheep[sheep].textLabel] = nil
        trackedSheep[sheep] = nil
    end
end

local function processSheep(sheep)
    local topSheep = getTopSheepModel(sheep)
    if not topSheep then return end
    if trackedSheep[topSheep] then return end 

    local sheepColor = getSheepColor(topSheep)
    local realName = topSheep.Name 
    
    local hl = Instance.new("Highlight")
    hl.Name = "ESP_Highlight"
    hl.Parent = topSheep
    hl.Adornee = topSheep
    hl.FillTransparency = 1 
    hl.OutlineColor = sheepColor 
    hl.OutlineTransparency = 0 

    local bg = Instance.new("BillboardGui")
    bg.Name = "ESP_Billboard"
    bg.Adornee = topSheep
    bg.Size = UDim2.new(6, 0, 1.5, 0) 
    bg.ExtentsOffsetWorldSpace = Vector3.new(0, 4, 0) 
    bg.AlwaysOnTop = true 
    
    local tl = Instance.new("TextLabel")
    tl.Parent = bg
    tl.Size = UDim2.new(1, 0, 1, 0)
    tl.BackgroundTransparency = 1
    tl.TextColor3 = Color3.fromRGB(255, 255, 255)
    tl.TextScaled = true
    tl.Font = Enum.Font.GothamBold
    tl.RichText = true
    
    bg.Parent = topSheep

    trackedSheep[topSheep] = { highlight = hl, billboard = bg, textLabel = tl }
    activeLabels[tl] = realName
end

-------------------------------------------------------------------------------
-- HIDE/SHOW OTHER SHEEP LOGIC (EXTREMELY THOROUGH)
-------------------------------------------------------------------------------
local hiddenSheepCache = {}

local function hideOtherSheep(targetSheep)
    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("Model") then
            local name = string.lower(v.Name)
            if string.find(name, "sheep") or string.find(name, "sheel") then
                local topSheep = getTopSheepModel(v)
                -- Ensure we DO NOT hide the target sheep
                if topSheep and topSheep ~= targetSheep then
                    if not hiddenSheepCache[topSheep] then
                        hiddenSheepCache[topSheep] = {}
                        
                        -- Hide everything inside the sheep model
                        for _, desc in ipairs(topSheep:GetDescendants()) do
                            if desc:IsA("BasePart") then
                                hiddenSheepCache[topSheep][desc] = {
                                    Transparency = desc.Transparency,
                                    CanQuery = desc.CanQuery,
                                    CanCollide = desc.CanCollide,
                                    CanTouch = desc.CanTouch
                                }
                                desc.Transparency = 1
                                desc.CanQuery = false
                                desc.CanCollide = false
                                desc.CanTouch = false
                            elseif desc:IsA("Decal") or desc:IsA("Texture") then
                                hiddenSheepCache[topSheep][desc] = { Transparency = desc.Transparency }
                                desc.Transparency = 1
                            elseif desc:IsA("BillboardGui") or desc:IsA("SurfaceGui") or desc:IsA("ProximityPrompt") or desc:IsA("ParticleEmitter") or desc:IsA("Trail") or desc:IsA("Beam") or desc:IsA("Highlight") then
                                hiddenSheepCache[topSheep][desc] = { Enabled = desc.Enabled }
                                desc.Enabled = false
                            elseif desc:IsA("ClickDetector") then
                                hiddenSheepCache[topSheep][desc] = { MaxActivationDistance = desc.MaxActivationDistance }
                                desc.MaxActivationDistance = 0
                            end
                        end
                        
                        -- Hide our own ESP for this sheep
                        if trackedSheep[topSheep] then
                            if trackedSheep[topSheep].highlight then trackedSheep[topSheep].highlight.Enabled = false end
                            if trackedSheep[topSheep].billboard then trackedSheep[topSheep].billboard.Enabled = false end
                        end
                    end
                end
            end
        end
    end
    
    -- Hide any PlayerGui BillboardGuis/SurfaceGuis Adornee'd to the hidden sheep
    local playerGui = player:FindFirstChild("PlayerGui")
    if playerGui then
        for _, gui in ipairs(playerGui:GetDescendants()) do
            if gui:IsA("BillboardGui") or gui:IsA("SurfaceGui") or gui:IsA("Highlight") then
                local adornee = gui.Adornee
                if adornee then
                    local topAdorneeSheep = getTopSheepModel(adornee)
                    if topAdorneeSheep and topAdorneeSheep ~= targetSheep and hiddenSheepCache[topAdorneeSheep] then
                        if not hiddenSheepCache[topAdorneeSheep][gui] then
                            hiddenSheepCache[topAdorneeSheep][gui] = { Enabled = gui.Enabled }
                            gui.Enabled = false
                        end
                    end
                end
            end
        end
    end
end

local function showAllSheep()
    for sheep, cache in pairs(hiddenSheepCache) do
        if sheep and sheep.Parent then
            for obj, props in pairs(cache) do
                if obj and obj.Parent then
                    if obj:IsA("BasePart") then
                        obj.Transparency = props.Transparency
                        obj.CanQuery = props.CanQuery
                        obj.CanCollide = props.CanCollide
                        obj.CanTouch = props.CanTouch
                    elseif obj:IsA("Decal") or obj:IsA("Texture") then
                        obj.Transparency = props.Transparency
                    elseif obj:IsA("BillboardGui") or obj:IsA("SurfaceGui") or obj:IsA("ProximityPrompt") or obj:IsA("ParticleEmitter") or obj:IsA("Trail") or obj:IsA("Beam") or obj:IsA("Highlight") then
                        obj.Enabled = props.Enabled
                    elseif obj:IsA("ClickDetector") then
                        obj.MaxActivationDistance = props.MaxActivationDistance
                    end
                end
            end
            if trackedSheep[sheep] then
                if trackedSheep[sheep].highlight then trackedSheep[sheep].highlight.Enabled = true end
                if trackedSheep[sheep].billboard then trackedSheep[sheep].billboard.Enabled = true end
            end
        end
    end
    table.clear(hiddenSheepCache)
end


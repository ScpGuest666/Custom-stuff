local function startFarmingCycle()
    local character = player.Character
    local hrp = character and character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    local grazeAreaCFrame = CFrame.new(176.67967224121095, 10.65000057220459, 311.4925231933594)

    while isFarming do
        local currentFarmDuration = 4 * 60 

        ---------------------------------------------------------
        -- PHASE 1: BRING OUT
        ---------------------------------------------------------
        status.Text = "Bringing Out..."
        while isFarming do
            local bringOutBtn = findUIElementByText("bring out")
            if bringOutBtn then
                clickUIElement(bringOutBtn, "Bring out")
                task.wait(1)
                
                if not findUIElementByText("bring out") then
                    break
                end
            else
                if findUIElementByText("bring in") or findUIElementByText("graze", "stop") then
                    break
                end
                
                local sheepList = {}
                for _, part in pairs(mySheep) do
                    if part and part.Parent then
                        table.insert(sheepList, part)
                    end
                end
                
                if #sheepList > 0 then
                    local randomSheep = sheepList[math.random(1, #sheepList)]
                    hrp.CFrame = randomSheep.CFrame + Vector3.new(0, 3, 0)
                else
                    hrp.CFrame = originalCFrame
                end
                
                task.wait(0.5)
            end
        end
        if not isFarming then break end

        ---------------------------------------------------------
        -- PHASE 2: TELEPORT TO GRAZE AREA & VERIFY UI
        ---------------------------------------------------------
        status.Text = "Going to Graze Area..."
        
        local uiAppeared = false
        while isFarming and not uiAppeared do
            hrp.CFrame = grazeAreaCFrame
            task.wait(1.5)
            
            if not isFarming then break end
            
            local grazeBtn = findUIElementByText("graze", "stop")
            local stopBtn = findUIElementByText("stop grazing")
            
            if grazeBtn or stopBtn then
                uiAppeared = true
            else
                status.Text = "UI Missing! Retrying..."
                hrp.CFrame = originalCFrame
                task.wait(1.5)
            end
        end
        if not isFarming then break end

        ---------------------------------------------------------
        -- PHASE 3 & 4: DYNAMIC GRAZING & ACTIVE EVASION
        ---------------------------------------------------------
        local elapsedGrazeTime = 0
        local maxGrazeTime = 30 
        local isAtGrazeArea = true

        while isFarming and elapsedGrazeTime < maxGrazeTime do
            
            if ufoState.threatLevel >= 2 then
                
                -- 1. Bail out immediately (Stop Grazing)
                local stopBtn = findUIElementByText("stop grazing")
                if stopBtn then 
                    clickUIElement(stopBtn, "Stop Grazing") 
                    task.wait(1) -- Give it a moment to register
                end

                -- 2. Teleport character back to sheepfold to physically evade
                if isAtGrazeArea then
                    status.Text = "UFO Inside! Evading to Sheepfold..."
                    hrp.CFrame = originalCFrame
                    isAtGrazeArea = false
                    task.wait(1.5) -- Wait for teleport and UI update
                end

                -- 3. Bring In Sheep to protect them
                local bringInBtn = findUIElementByText("bring in")
                if bringInBtn then
                    clickUIElement(bringInBtn, "Bring in")
                    task.wait(1)
                end

                -- 4. Actively Collect Wool while waiting for UFO to leave
                status.Text = "UFO Inside! Collecting Wool..."
                doWoolCollection(player.Character, hrp)
                task.wait(0.5)
                
            else
                -- NO THREAT (SAFE TO GRAZE)
                
                -- If we were evading and the threat cleared, return to graze area
                if not isAtGrazeArea then
                    status.Text = "Threat Cleared! Bringing Out..."
                    
                    -- Bring sheep back out
                    local bringOutBtn = findUIElementByText("bring out")
                    if bringOutBtn then
                        clickUIElement(bringOutBtn, "Bring out")
                        task.wait(1)
                    end

                    -- Teleport to Graze Area
                    local returnUiAppeared = false
                    while isFarming and not returnUiAppeared do
                        -- Re-check threat during transit
                        if ufoState.threatLevel >= 2 then
                            break
                        end

                        hrp.CFrame = grazeAreaCFrame
                        task.wait(1.5)
                        
                        local grazeBtn = findUIElementByText("graze", "stop")
                        local stopBtn2 = findUIElementByText("stop grazing")
                        
                        if grazeBtn or stopBtn2 then
                            returnUiAppeared = true
                        else
                            status.Text = "UI Missing! Retrying..."
                            hrp.CFrame = originalCFrame
                            task.wait(1.5)
                            
                            -- Ensure sheep are brought out if we had to retry
                            local retryBringOut = findUIElementByText("bring out")
                            if retryBringOut then
                                clickUIElement(retryBringOut, "Bring out")
                                task.wait(1)
                            end
                        end
                    end
                    
                    if not returnUiAppeared then continue end -- Threat returned while we were trying to go back
                    isAtGrazeArea = true
                end

                -- NEW FAILSAFE: Check if UI randomly disappeared while grazing
                local currentGrazeBtn = findUIElementByText("graze", "stop")
                local currentStopBtn = findUIElementByText("stop grazing")
                
                if not currentGrazeBtn and not currentStopBtn then
                    status.Text = "UI Missing! Resetting Zone..."
                    hrp.CFrame = originalCFrame
                    task.wait(1.5)
                    hrp.CFrame = grazeAreaCFrame
                    task.wait(1.5)
                    continue -- Restart loop to re-evaluate
                end

                -- 1. Wait exactly 2 seconds before pressing Stop Grazing (Interruptible if UFO enters)
                local waitTime = 0
                while waitTime < 2 and isFarming do
                    -- Check threat dynamically
                    if ufoState.threatLevel >= 2 then
                        break
                    end

                    -- Update UI smoothly (1, 2, 3...)
                    if ufoState.threatLevel == 1 then
                        status.Text = string.format("UFO Incoming! Grazing... (%d/%d)", math.floor(elapsedGrazeTime + waitTime), maxGrazeTime)
                    else
                        status.Text = string.format("Grazing... (%d/%d)", math.floor(elapsedGrazeTime + waitTime), maxGrazeTime)
                    end

                    task.wait(0.1)
                    waitTime = waitTime + 0.1
                end
                elapsedGrazeTime = elapsedGrazeTime + waitTime
                
                -- Re-check threat just in case a UFO entered during that 2 second wait
                if not isFarming or ufoState.threatLevel >= 2 then continue end
                
                -- 2. Press Stop Grazing
                local stopBtn = findUIElementByText("stop grazing")
                if stopBtn then 
                    clickUIElement(stopBtn, "Stop Grazing") 
                end
                
                -- 3. Lightning Fast Reaction: Wait for Graze button to appear and click it instantly
                local pollTime = 0
                while isFarming do
                    if ufoState.threatLevel >= 2 then
                        break
                    end

                    local grazeBtn = findUIElementByText("graze", "stop")
                    if grazeBtn then 
                        clickUIElement(grazeBtn, "Graze") 
                        break 
                    end
                    
                    -- Failsafe: If UI completely vanished after clicking Stop Grazing
                    local checkStop = findUIElementByText("stop grazing")
                    if not grazeBtn and not checkStop and pollTime > 1 then
                        break -- Break out of polling if UI is dead, the outer loop will catch it and reset
                    end

                    task.wait(0.03) -- 30ms polling rate for near-instant reaction
                    pollTime = pollTime + 0.03
                    if pollTime > 2 then break end -- 2-second safety timeout to prevent infinite loops
                end
                
                elapsedGrazeTime = elapsedGrazeTime + pollTime

                if findUIElementByText("are full") then
                    currentFarmDuration = 4 * 60
                    break
                end
            end
        end
        if not isFarming then break end

        ---------------------------------------------------------
        -- PHASE 5 & 6: SMART RETURN TO SHEEPFOLD & BRING IN
        ---------------------------------------------------------
        status.Text = "Finishing Graze & Returning..."
        
        while isFarming do
            local stopBtn = findUIElementByText("stop grazing")
            local grazeBtn = findUIElementByText("graze", "stop")
            local bringInBtn = findUIElementByText("bring in")
            local bringOutBtn = findUIElementByText("bring out")

            if stopBtn then
                status.Text = "Stopping Graze..."
                -- Ensure we are at the grazing area to click it
                if (hrp.Position - grazeAreaCFrame.Position).Magnitude > 50 then
                    hrp.CFrame = grazeAreaCFrame
                    task.wait(1.5)
                else
                    clickUIElement(stopBtn, "Stop Grazing")
                    task.wait(1.5)
                end
                
            elseif grazeBtn then
                status.Text = "Returning to Sheepfold..."
                -- Sheep are at graze area, but not grazing. Go to sheepfold to bring them in.
                if (hrp.Position - originalCFrame.Position).Magnitude > 50 then
                    hrp.CFrame = originalCFrame
                    task.wait(1.5)
                else
                    -- UI bug: at sheepfold but showing graze. Reset zone.
                    hrp.CFrame = grazeAreaCFrame
                    task.wait(1.5)
                end
                
            elseif bringInBtn then
                status.Text = "Bringing In..."
                -- Perfect, we are at the sheepfold and ready to bring in.
                if (hrp.Position - originalCFrame.Position).Magnitude > 50 then
                    hrp.CFrame = originalCFrame
                    task.wait(1.5)
                else
                    clickUIElement(bringInBtn, "Bring in")
                    task.wait(1.5)
                end
                
            elseif bringOutBtn then
                -- UI says Bring Out. Did the sheep follow us, or were they left behind?
                local sheepAreNear = false
                for sheepModel, part in pairs(mySheep) do
                    if part and part.Parent and (part.Position - hrp.Position).Magnitude < 80 then
                        sheepAreNear = true
                        break
                    end
                end
                
                if sheepAreNear then
                    break -- Successfully brought in and sheep are here!
                else
                    status.Text = "Sheep Left Behind! Recovering..."
                    hrp.CFrame = grazeAreaCFrame
                    task.wait(1.5)
                    local recoverStop = findUIElementByText("stop grazing")
                    if recoverStop then 
                        clickUIElement(recoverStop, "Stop Grazing") 
                        task.wait(1.5)
                    end
                end
                
            else
                -- No buttons found. Try moving to sheepfold to sync UI.
                status.Text = "Syncing UI..."
                if (hrp.Position - originalCFrame.Position).Magnitude > 50 then
                    hrp.CFrame = originalCFrame
                    task.wait(1.5)
                else
                    -- If at sheepfold and no buttons, reset zone
                    hrp.CFrame = grazeAreaCFrame
                    task.wait(1.5)
                end
            end
        end
        if not isFarming then break end

        ---------------------------------------------------------
        -- PHASE 7: FARM SHEEP (WOOL COLLECTION)
        ---------------------------------------------------------
        local endTime = os.time() + currentFarmDuration
        
        while isFarming and os.time() < endTime do
            local remaining = endTime - os.time()
            local mins = math.floor(remaining / 60)
            local secs = remaining % 60
            status.Text = string.format("%02d:%02d", mins, secs)

            local char = player.Character
            local currentHrp = char and char:FindFirstChild("HumanoidRootPart")

            if currentHrp then
                doWoolCollection(char, currentHrp)
                task.wait(0.5) 
            else
                task.wait(1) 
            end
        end

        if isFarming and originalCFrame then
            local char = player.Character
            local finalHrp = char and char:FindFirstChild("HumanoidRootPart")
            if finalHrp then
                finalHrp.CFrame = originalCFrame
                task.wait(0.5) 
            end
        end
    end
end

-------------------------------------------------------------------------------
-- BUTTON CONNECTIONS
-------------------------------------------------------------------------------
local function setOnline()
    if isFarming then return end
    
    -- Apply Anti-Lag immediately
    applyAntiLag()
    
    local character = player.Character
    local hrp = character and character:FindFirstChild("HumanoidRootPart")
    if hrp then
        originalCFrame = hrp.CFrame
    end
    
    if not activeFakeLimb or not activeFakeLimb.Parent then
        activeFakeLimb = Instance.new("Part")
        activeFakeLimb.Name = "Right Arm"
        activeFakeLimb.CanCollide = false
        activeFakeLimb.Transparency = 1
        activeFakeLimb.Massless = true
        if character then
            activeFakeLimb.Parent = character
        end
    end
    
    -- Setup UFO Event Listeners (Zero-Lag Cache System)
    activeUFOsCache = {}
    
    local function checkAndCacheUFO(desc)
        if desc.Name == "FlyingSaucer" then
            task.spawn(function()
                task.wait(0.5) -- Wait for model to load its parts
                local ufoPart = desc:IsA("BasePart") and desc or desc:FindFirstChildWhichIsA("BasePart")
                if ufoPart then
                    activeUFOsCache[ufoPart] = true
                end
            end)
        elseif desc.Parent and desc.Parent.Name == "FlyingSaucer" and desc:IsA("BasePart") then
            activeUFOsCache[desc] = true
        end
    end

    for _, desc in ipairs(workspace:GetDescendants()) do
        checkAndCacheUFO(desc)
    end

    ufoAddedConn = workspace.DescendantAdded:Connect(checkAndCacheUFO)
    ufoRemovedConn = workspace.DescendantRemoving:Connect(function(desc)
        if desc.Name == "FlyingSaucer" then
            for part, _ in pairs(activeUFOsCache) do
                if part == desc or part:IsDescendantOf(desc) then
                    activeUFOsCache[part] = nil
                end
            end
        end
    end)
    
    -- Whitelist Sheep
    mySheep = {}
    for _, desc in pairs(workspace:GetDescendants()) do
        if desc:IsA("BillboardGui") then
            local sheepModel = desc:FindFirstAncestorOfClass("Model")
            if sheepModel and not mySheep[sheepModel] then
                local part = sheepModel.PrimaryPart or sheepModel:FindFirstChildWhichIsA("BasePart")
                if part and part.Parent then
                    local dist = (part.Position - originalCFrame.Position).Magnitude
                    if dist <= maxDistance then
                        mySheep[sheepModel] = part
                    end
                end
            end
        end
    end
    
    isFarming = true
    status.TextColor3 = Color3.fromRGB(0, 255, 0)
    
    farmCoroutine = task.spawn(startFarmingCycle)
end

local function setOffline()
    isFarming = false
    status.Text = "Status: Offline"
    status.TextColor3 = Color3.fromRGB(255, 0, 0)
    pointer.Visible = false
    
    if farmCoroutine then
        task.cancel(farmCoroutine)
        farmCoroutine = nil
    end
    
    -- Failsafe: Release any stuck touches
    pcall(function()
        vim:SendTouchEvent(TOUCH_ID, 2, lastClickX, lastClickY)
    end)
    
    -- Disconnect UFO Listeners
    if ufoAddedConn then ufoAddedConn:Disconnect(); ufoAddedConn = nil end
    if ufoRemovedConn then ufoRemovedConn:Disconnect(); ufoRemovedConn = nil end
    
    -- Reset UFO states & Visualizer
    ufoState.threatLevel = 0
    for ufo, esp in pairs(trackedUFOs) do
        if esp then esp:Destroy() end
    end
    trackedUFOs = {}
    ufoData = {}
    activeUFOsCache = {}
    
    foundPasture = nil
    if zoneVisualizer then
        zoneVisualizer:Destroy()
        zoneVisualizer = nil
    end
    
    if activeFakeLimb then
        activeFakeLimb:Destroy()
        activeFakeLimb = nil
    end
    
    local stopBtn = findUIElementByText("stop grazing")
    if stopBtn then
        local function isElementGray(element)
            if not element or not element:IsA("GuiObject") then return false end
            local gray = false
            
            pcall(function() if element.Interactable == false then gray = true end end)
            pcall(function() if element.Active == false then gray = true end end)
            
            if element.BackgroundTransparency > 0.4 then gray = true end
            if (element:IsA("TextLabel") or element:IsA("TextButton")) and element.TextTransparency > 0.4 then 
                gray = true 
            end
            
            if element.BackgroundTransparency < 1 then
                local c = element.BackgroundColor3
                local maxDiff = math.max(math.abs(c.R - c.G), math.abs(c.G - c.B), math.abs(c.R - c.B))
                if maxDiff < 0.1 and c.R > 0.1 and c.R < 0.9 then
                    gray = true
                end
            end
            
            return gray
        end

        local isGray = isElementGray(stopBtn)
        
        if stopBtn.BackgroundTransparency == 1 and stopBtn.Parent and stopBtn.Parent:IsA("GuiObject") then
            if isElementGray(stopBtn.Parent) then
                isGray = true
            end
        end

        if isGray then
            return
        else
            clickUIElement(stopBtn, "Stop Grazing")
            task.wait(1) 
        end
    end
    
    local character = player.Character
    local hrp = character and character:FindFirstChild("HumanoidRootPart")
    if originalCFrame and hrp then
        hrp.CFrame = originalCFrame
    end
end

onBtn.MouseButton1Click:Connect(setOnline)
offBtn.MouseButton1Click:Connect(setOffline)
destroyBtn.MouseButton1Click:Connect(function()
    setOffline()
    screenGui:Destroy()
end)

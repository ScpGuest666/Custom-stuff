-- ESP START/STOP
-------------------------------------------------------------------------------
local function startHighlighting()
    if isActive then return end
    isActive = true
    findMyBoxesAndPath()

    for _, box in ipairs(myBoxes) do
        if not box:FindFirstChild("Box_Highlight") then
            local hl = Instance.new("Highlight")
            hl.Name = "Box_Highlight"
            hl.Parent = box
            hl.Adornee = box
            hl.FillColor = Color3.fromRGB(170, 0, 255)
            hl.OutlineColor = Color3.new(1, 1, 1)
            hl.FillTransparency = 0.5
            hl.OutlineTransparency = 0.1
            table.insert(boxEspObjects, hl)
        end
    end

    -- Initial Scan: Only highlight sheep currently within the radius
    task.spawn(function()
        for _, v in pairs(workspace:GetDescendants()) do
            if v:IsA("Model") then
                local name = string.lower(v.Name)
                if string.find(name, "sheep") or string.find(name, "sheel") then 
                    local topSheep = getTopSheepModel(v)
                    if topSheep and not trackedSheep[topSheep] then
                        local pos = getPosition(topSheep)
                        if pos and getDistanceToPen(pos) <= 35 and isSheepValidToTrack(topSheep) then
                            processSheep(topSheep)
                        end
                    end
                end
            end
        end
    end)

    -- Event Listener: Only highlight new sheep if they spawn at/near SheepStart
    sheepConnection = workspace.DescendantAdded:Connect(function(v)
        if not isActive then return end
        if v:IsA("Model") then
            local name = string.lower(v.Name)
            if string.find(name, "sheep") or string.find(name, "sheel") then
                task.spawn(function()
                    task.wait(0.5) 
                    if not isActive then return end
                    local topSheep = getTopSheepModel(v)
                    if topSheep and not trackedSheep[topSheep] then
                        local pos = getPosition(topSheep)
                        if pos then
                            local validSpawn = false
                            if sheepStart then
                                local startPos = getPosition(sheepStart)
                                if startPos and (pos - startPos).Magnitude <= 35 then
                                    validSpawn = true
                                end
                            elseif getDistanceToPen(pos) <= 35 then
                                validSpawn = true
                            end
                            
                            if validSpawn and isSheepValidToTrack(topSheep) then
                                processSheep(topSheep)
                            end
                        end
                    end
                end)
            end
        end
    end)

    -- Continuous Validation Loop: Removes invalid sheep & hides new ones if buying
    trackerLoopCoroutine = task.spawn(function()
        while isActive do
            task.wait(1)
            for sheep, data in pairs(trackedSheep) do
                if shouldRemoveHighlight(sheep) then 
                    unhighlightSheep(sheep) 
                end
            end
            
            -- If we are currently buying a target, ensure any newly spawned sheep are hidden
            if _G.AutoBuyTarget then
                hideOtherSheep(_G.AutoBuyTarget)
            end
        end
    end)

    renderConnection = RunService.RenderStepped:Connect(function()
        local t = tick()
        for label, baseText in pairs(activeLabels) do
            if label.Parent then
                local animatedText = ""
                for i = 1, #baseText do
                    local char = string.sub(baseText, i, i)
                    if char == " " then animatedText = animatedText .. " "
                    else
                        local wave = (math.sin(t * 6 + i * 0.8) + 1) / 2
                        local r = math.floor((1 - wave) * 255)
                        local b = math.floor(wave * 255)
                        local hexColor = string.format("#%02X00%02X", r, b)
                        animatedText = animatedText .. string.format('<stroke color="%s" thickness="3">%s</stroke>', hexColor, char)
                    end
                end
                label.Text = animatedText
            else
                activeLabels[label] = nil
            end
        end
    end)
end

local function stopHighlighting()
    isActive = false
    if sheepConnection then sheepConnection:Disconnect(); sheepConnection = nil end
    if renderConnection then renderConnection:Disconnect(); renderConnection = nil end
    if trackerLoopCoroutine then task.cancel(trackerLoopCoroutine); trackerLoopCoroutine = nil end
    for _, obj in ipairs(boxEspObjects) do if obj and obj.Parent then obj:Destroy() end end
    table.clear(boxEspObjects)
    for sheep, _ in pairs(trackedSheep) do unhighlightSheep(sheep) end
    table.clear(trackedSheep)
    table.clear(activeLabels)
    showAllSheep()
end

-------------------------------------------------------------------------------
-- AUTO-BUY LOGIC (WITH SPIN DETECTION & DYNAMIC MOUSE OFFSET)
-------------------------------------------------------------------------------
local sideActive = false
local boughtCount = 0
local autoBuyCoroutine = nil

local CAMERA_HEIGHT = 15
local CLICK_OFFSET_X = 0
local BASE_CLICK_OFFSET_Y = 0
local WALKING_OFFSET_Y = -25 -- Pixels to shift upward when sheep is walking
local RUNNING_OFFSET_Y = -50 -- Pixels to shift upward when sheep is running

local function cleanString(str)
    return string.gsub(string.lower(str), "%s+", "")
end

local function findTargetSheep(targetName)
    local cleanedTarget = cleanString(targetName)
    -- Only search through currently tracked (highlighted) sheep
    for sheep, _ in pairs(trackedSheep) do
        if sheep and sheep.Parent then
            if cleanString(sheep.Name) == cleanedTarget then
                if not shouldRemoveHighlight(sheep) then 
                    return sheep 
                end
            end
        end
    end
    return nil
end

local function autoBuyLoop()
    findMyBoxesAndPath() 
    
    while sideActive do
        local targetName = nameBox.Text
        local targetTimes = tonumber(timesBox.Text) or 0 
        
        if targetName ~= "" then
            local sheep = findTargetSheep(targetName)
            
            if sheep then
                _G.AutoBuyTarget = sheep
                
                local aborted = false
                if isFarming then
                    while isFarming and not _G.SheepSecured and sideActive do
                        if not sheep or not sheep.Parent or shouldRemoveHighlight(sheep) then
                            aborted = true
                            break
                        end
                        task.wait(0.1)
                    end
                end
                
                if aborted or not sideActive then 
                    _G.AutoBuyTarget = nil
                    showAllSheep()
                    task.wait(0.5)
                    continue 
                end
                
                -- HIDE ALL OTHER SHEEP TO PREVENT ACCIDENTAL CLICKS
                hideOtherSheep(sheep)
                
                local char = player.Character
                local hrp = char and char:FindFirstChild("HumanoidRootPart")
                local cam = workspace.CurrentCamera
                
                if hrp then
                    local preAutoBuyCFrame = hrp.CFrame
                    cam.CameraType = Enum.CameraType.Scriptable
                    
                    autoBuyPointer.Visible = true
                    
                    local isSpinning = false
                    local tpConnection
                    tpConnection = RunService.Heartbeat:Connect(function()
                        if not sideActive or not _G.AutoBuyTarget or isSpinning then 
                            if tpConnection then tpConnection:Disconnect() end
                            return 
                        end
                        if sheep and sheep.Parent and sheep.PrimaryPart then
                            local sheepCFrame = sheep.PrimaryPart.CFrame
                            local sheepPos = sheepCFrame.Position
                            local forwardDir = sheepCFrame.LookVector
                            
                            hrp.CFrame = CFrame.lookAt(sheepPos + (forwardDir * 3), sheepPos)
                            cam.CFrame = CFrame.lookAt(sheepPos + Vector3.new(0, CAMERA_HEIGHT, 0), sheepPos, forwardDir)
                        else
                            if tpConnection then tpConnection:Disconnect() end
                        end
                    end)
                    
                    task.wait(0.5) 
                    
                    if sideActive and sheep and sheep.PrimaryPart then
                        local viewport = cam.ViewportSize
                        local wasBought = false
                        
                        -- REPEATING 1.5s HOLD LOOP
                        while sideActive and sheep and sheep.Parent and not shouldRemoveHighlight(sheep) and not wasBought do
                            local lastPos = sheep.PrimaryPart.Position
                            local currentOffsetY = BASE_CLICK_OFFSET_Y
                            local clickX = (viewport.X / 2) + CLICK_OFFSET_X
                            local clickY = (viewport.Y / 2) + currentOffsetY
                            
                            autoBuyPointer.Position = UDim2.new(0.5, CLICK_OFFSET_X, 0.5, currentOffsetY)
                            vim:SendTouchEvent(TOUCH_ID, 0, clickX, clickY)
                            
                            local holdTime = 0
                            local lastFwd = sheep.PrimaryPart.CFrame.LookVector
                            local spinAccumulator = 0

                            while holdTime < 1.5 and sideActive and sheep and sheep.Parent and not shouldRemoveHighlight(sheep) do
                                task.wait(0.05)
                                holdTime = holdTime + 0.05
                                
                                if sheep.PrimaryPart then
                                    -- 1. Update Mouse/Dot Offset dynamically based on 3D Position change
                                    local currentPos = sheep.PrimaryPart.Position
                                    local distMoved = (currentPos - lastPos).Magnitude
                                    lastPos = currentPos
                                    
                                    -- Determine movement phase based on distance moved in 0.05s
                                    if distMoved > 0.5 then
                                        currentOffsetY = RUNNING_OFFSET_Y
                                    elseif distMoved > 0.02 then
                                        currentOffsetY = WALKING_OFFSET_Y
                                    else
                                        currentOffsetY = BASE_CLICK_OFFSET_Y
                                    end
                                    
                                    clickX = (viewport.X / 2) + CLICK_OFFSET_X
                                    clickY = (viewport.Y / 2) + currentOffsetY
                                    
                                    autoBuyPointer.Position = UDim2.new(0.5, CLICK_OFFSET_X, 0.5, currentOffsetY)
                                    vim:SendTouchEvent(TOUCH_ID, 1, clickX, clickY) -- Update touch position
                                    
                                    -- 2. Spin Detection (Tracking the SHEEP's rotation)
                                    local currentFwd = sheep.PrimaryPart.CFrame.LookVector
                                    local dot = math.clamp(lastFwd:Dot(currentFwd), -1, 1)
                                    local angle = math.acos(dot)
                                    spinAccumulator = spinAccumulator + angle
                                    lastFwd = currentFwd
                                    
                                    -- If the sheep rotates rapidly (more than ~180 degrees total during the hold)
                                    if spinAccumulator > math.pi then
                                        isSpinning = true
                                        break
                                    end
                                end
                            end
                            
                            vim:SendTouchEvent(TOUCH_ID, 2, clickX, clickY)
                            task.wait(0.1) -- Brief pause before checking or repeating
                            
                            -- VERIFY PURCHASE: Only count if it spun OR ownership changed
                            if isSpinning then
                                wasBought = true
                            elseif sheep and sheep.Parent then
                                local ownerTag = sheep:FindFirstChild("Owner", true) or sheep:FindFirstChild("owner", true)
                                if ownerTag and tostring(ownerTag.Value) ~= "" then
                                    wasBought = true
                                end
                            end
                        end
                        
                        if wasBought then
                            boughtCount = boughtCount + 1
                            unhighlightSheep(sheep) -- Instantly remove highlight so we don't target it again
                        end
                    end
                    
                    if tpConnection then tpConnection:Disconnect() end
                    cam.CameraType = Enum.CameraType.Custom
                    autoBuyPointer.Visible = false
                    
                    -- RESTORE ALL OTHER SHEEP
                    showAllSheep()
                    _G.AutoBuyTarget = nil
                    
                    if not isFarming then
                        hrp.CFrame = preAutoBuyCFrame
                    end
                end
            else
                _G.AutoBuyTarget = nil
                showAllSheep()
                task.wait(0.5) 
            end
        else
            _G.AutoBuyTarget = nil
            showAllSheep()
            task.wait(0.5)
        end
        
        if targetTimes > 0 and boughtCount >= targetTimes then
            sideActive = false
            sideActiveBtn.Text = "Active: OFF"
            sideActiveBtn.BackgroundColor3 = Color3.fromRGB(150, 0, 0)
            stopHighlighting()
            pcall(function() vim:SendTouchEvent(TOUCH_ID, 2, 0, 0) end)
            autoBuyPointer.Visible = false
            _G.AutoBuyTarget = nil
            showAllSheep()
            workspace.CurrentCamera.CameraType = Enum.CameraType.Custom
        end
    end
    
    _G.AutoBuyTarget = nil
    showAllSheep()
    workspace.CurrentCamera.CameraType = Enum.CameraType.Custom
    autoBuyPointer.Visible = false
end


                if #moveHistory > 0 then
                    local pm = moveHistory[#moveHistory]
                    squares[pm.fromR][pm.fromC].BackgroundColor3 = Color3.fromRGB(255, 255, 0)
                    squares[pm.toR][pm.toC].BackgroundColor3 = Color3.fromRGB(0, 150, 255)
                end
                selected=nil
                return
            end
            local lm,isl=generateLegalMoves(copyBoard(squares),playerColor),false
            for _,m in ipairs(lm) do
                if m.fromR==sr and m.fromC==sc and m.toR==tr and m.toC==tc then
                    isl=true
                    break
                end
            end
            if isl then
                local mp=selected.Text
                table.insert(moveHistory,{fromR=sr,fromC=sc,toR=tr,toC=tc,movedPiece=mp,capturedPiece=squares[tr][tc].Text,previousHasMoved=copyHasMoved(hasMoved)})
                
                if mp:lower() == 'p' and sc ~= tc and squares[tr][tc].Text == "" then
                    squares[sr][tc].Text = ""
                end
                
                sq.Text,sq.TextColor3,selected.Text=mp,selected.TextColor3,""
                if mp:lower()=='k' and math.abs(tc-sc)==2 then
                    local rc,nrc=(tc>sc) and 8 or 1,(tc>sc) and 6 or 4
                    local rp=squares[sr][rc].Text
                    squares[sr][nrc].Text,squares[sr][rc].Text=rp,""
                    squares[sr][nrc].TextColor3=getPieceTextColor(playerColor)
                end
                hasMoved[mp]=true
                if mp:lower()=='r' then hasMoved[mp..sc]=true end
                

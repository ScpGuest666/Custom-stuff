                return HttpService:JSONDecode(body).moves[1].uci
            end,
            function() -- 13. Fast Fallback (Depth 5)
                local body = fetchPost("https://chess-api.com/v1", HttpService:JSONEncode({fen = fen, depth = 5}))
                return HttpService:JSONDecode(body).move
            end
        }
        
        for i = 1, 13 do
            task.spawn(function()
                local success, move = pcall(tasks[i])
                if success and move and not completed then
                    bestMoveStr = move
                    completed = true
                end
            end)
        end
        
    elseif currentApi == "Stockfish" then
        task.spawn(function()
            local body = fetchGet("https://stockfish.online/api/s/v2.php?fen=" .. HttpService:UrlEncode(fen) .. "&depth=" .. tostring(stockfishDepth))

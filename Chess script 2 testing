local function isBoardValid(b)
    local wk, bk = false, false
    for r=1,8 do
        for c=1,8 do
            if b[r][c] == 'K' then bk = true end
            if b[r][c] == 'k' then wk = true end
        end
    end
    return wk and bk
end


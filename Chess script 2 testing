local function setBoardFlipped(flipped)
    if not chessBoard then return end
    local size = 25
    for r = 1, 8 do
        for c = 1, 8 do
            local square = squares[r][c]
            local newPos
            if flipped then
                newPos = UDim2.new(0, (8 - c) * size, 0, (8 - r) * size)
            else
                newPos = UDim2.new(0, (c - 1) * size, 0, (r - 1) * size)
            end
            square.Position = newPos
        end
    end
    isBoardFlipped = flipped
end

local function applyMoveToBoard(board, move)
    local nb = cloneBoard(board)
    nb[move.toR][move.toC] = move.piece
    nb[move.fromR][move.fromC] = ""
    if move.piece:lower() == 'k' and math.abs(move.toC - move.fromC) == 2 then
        local rookCol = (move.toC > move.fromC) and 8 or 1
        local newRookCol = (move.toC > move.fromC) and 6 or 4
        nb[move.fromR][newRookCol] = nb[move.fromR][rookCol]
        nb[move.fromR][rookCol] = ""
    end
    if move.piece:lower() == 'p' and move.fromC ~= move.toC and board[move.toR][move.toC] == "" then
        nb[move.fromR][move.toC] = ""
    end
    if move.piece:lower() == 'p' and (move.toR == 1 or move.toR == 8) then
        nb[move.toR][move.toC] = (getPieceColor(move.piece) == "White") and "q" or "Q"
    end
    return nb
end

local function boardsMatch(b1, b2)
    for r=1,8 do
        for c=1,8 do
            local p1, p2 = b1[r][c], b2[r][c]
            if p1 ~= p2 then
                if p1:lower() == 'q' and p2:lower() == 'p' and (r==1 or r==8) and getPieceColor(p1) == getPieceColor(p2) then
                    -- Accept promotion mismatch
                else
                    return false
                end
            end
        end
    end
    return true
end

-- Get 3D board state (only pieces on the board) and also build piece map
local function get3DBoardState()
    if not isMatching then return nil, nil end
    local pieces = {}
    
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj:IsA("Model") and obj ~= player.Character then
            local extents = obj:GetExtentsSize()
            -- Strict size limit to prevent detecting the entire chessboard as a piece
            if extents.X < 8 and extents.Y < 15 and extents.Z < 8 then
                local pType = getChessPieceType(obj.Name)
                if pType then
                    local pos = obj:GetPivot().Position
                    local distance = (pos - Camera.CFrame.Position).Magnitude
                    if distance < MAX_DISTANCE then
                        table.insert(pieces, {obj = obj, pos = pos, type = pType})
                    end
                end
            end
        end
    end
    
    if #pieces < 4 then return nil, nil end
    
    if not boardAnchor then
        local sumX, sumZ, count = 0, 0, 0
        for _, p in ipairs(pieces) do
            sumX = sumX + p.pos.X
            sumZ = sumZ + p.pos.Z
            count = count + 1
        end
        local centerX, centerZ = sumX / count, sumZ / count
        
        local validPieces = {}
        local validXs, validZs = {}, {}
        local MAX_DEVIATION = 40 
        for _, p in ipairs(pieces) do
            if (p.pos - Vector3.new(centerX, p.pos.Y, centerZ)).Magnitude < MAX_DEVIATION then
                table.insert(validPieces, p)
                table.insert(validXs, p.pos.X)
                table.insert(validZs, p.pos.Z)
            end
        end
        
        if #validPieces < 4 then return nil, nil end
        table.sort(validXs)
        table.sort(validZs)
        
        local minX, maxX = validXs[1], validXs[#validXs]
        local minZ, maxZ = validZs[1], validZs[#validZs]
        
        local squareSizeX = (maxX - minX) / 7
        local squareSizeZ = (maxZ - minZ) / 7
        
        if squareSizeX < 0.1 or squareSizeZ < 0.1 then return nil, nil end
        
        local minY = math.huge
        for _, p in ipairs(validPieces) do
            local bottomY = p.pos.Y - (p.obj:GetExtentsSize().Y / 2)
            if bottomY < minY then minY = bottomY end
        end
        
        -- Determine Player Side and Color based on distance to camera
        local backRank1Pos = Vector3.new((minX + maxX)/2, minY, minZ)
        local backRank2Pos = Vector3.new((minX + maxX)/2, minY, maxZ)
        local dist1 = (backRank1Pos - Camera.CFrame.Position).Magnitude
        local dist2 = (backRank2Pos - Camera.CFrame.Position).Magnitude
        
        local playerSideZ = (dist1 < dist2) and minZ or maxZ
        local opponentSideZ = (dist1 < dist2) and maxZ or minZ
        
        if not detectedPlayerColor then
            local whiteVotes, blackVotes = 0, 0
            for _, p in ipairs(validPieces) do
                -- Check pieces on the player's half of the board
                if math.abs(p.pos.Z - playerSideZ) < math.abs(p.pos.Z - opponentSideZ) then
                    local lowerName = string.lower(p.obj.Name)
                    if string.find(lowerName, "white") then whiteVotes = whiteVotes + 1
                    elseif string.find(lowerName, "black") then blackVotes = blackVotes + 1
                    else
                        local part = p.obj:FindFirstChildWhichIsA("BasePart", true)
                        if part then
                            local color = part.Color
                            if (color.r + color.g + color.b) / 3 > 0.5 then whiteVotes = whiteVotes + 1
                            else blackVotes = blackVotes + 1 end
                        end
                    end
                end
            end
            detectedPlayerColor = (whiteVotes >= blackVotes) and "White" or "Black"
            playerColor = detectedPlayerColor
        end
        
        local opponentColor = (detectedPlayerColor == "White") and "Black" or "White"
        
        -- Assign persistent colors to models based on their starting side
        for _, p in ipairs(validPieces) do
            if not persistentModelColors[p.obj] then
                if math.abs(p.pos.Z - playerSideZ) < math.abs(p.pos.Z - opponentSideZ) then
                    persistentModelColors[p.obj] = detectedPlayerColor
                else
                    persistentModelColors[p.obj] = opponentColor
                end
            end
        end
        
        local flipRow = false
        if playerSideZ == minZ and detectedPlayerColor == "White" then flipRow = true end
        if playerSideZ == maxZ and detectedPlayerColor == "Black" then flipRow = true end
        
        local whiteKingC, whiteQueenC
        for _, p in ipairs(validPieces) do
            if persistentModelColors[p.obj] == "White" then
                local c = math.floor(((p.pos.X - minX) / squareSizeX) + 0.5) + 1
                if p.type == "king" then whiteKingC = c end
                if p.type == "queen" then whiteQueenC = c end
            end
        end
        
        local flipCol = false
        if whiteKingC and whiteQueenC then
            if whiteKingC < whiteQueenC then flipCol = true end
        end
        
        boardAnchor = {
            minX = minX, maxX = maxX,
            minZ = minZ, maxZ = maxZ,
            squareSizeX = squareSizeX,
            squareSizeZ = squareSizeZ,
            baseY = minY,
            flipRow = flipRow,
            flipCol = flipCol
        }
    end
    
    local board3D = {}
    for r=1,8 do board3D[r] = {} for c=1,8 do board3D[r][c] = "" end end
    local pieceMap = {}
    
    for _, p in ipairs(pieces) do
        -- Fallback for new pieces (e.g., promotions)
        if not persistentModelColors[p.obj] then
            local lowerName = string.lower(p.obj.Name)
            if string.find(lowerName, "white") then persistentModelColors[p.obj] = "White"
            elseif string.find(lowerName, "black") then persistentModelColors[p.obj] = "Black"
            else
                local part = p.obj:FindFirstChildWhichIsA("BasePart", true)
                if part then
                    local color = part.Color
                    if (color.r + color.g + color.b) / 3 > 0.5 then persistentModelColors[p.obj] = "White"
                    else persistentModelColors[p.obj] = "Black" end
                else
                    persistentModelColors[p.obj] = "White"
                end
            end
        end
        p.color = persistentModelColors[p.obj]
        
        local c = math.floor(((p.pos.X - boardAnchor.minX) / boardAnchor.squareSizeX) + 0.5) + 1
        local r = math.floor(((p.pos.Z - boardAnchor.minZ) / boardAnchor.squareSizeZ) + 0.5) + 1
        
        if c >= 1 and c <= 8 and r >= 1 and r <= 8 then
            if boardAnchor.flipRow then r = 9 - r end
            if boardAnchor.flipCol then c = 9 - c end
            
            local char = ""
            if p.type == "pawn" then char = "p"
            elseif p.type == "knight" then char = "n"
            elseif p.type == "bishop" then char = "b"
            elseif p.type == "rook" then char = "r"
            elseif p.type == "queen" then char = "q"
            elseif p.type == "king" then char = "k"
            end
            if p.color == "Black" then char = char:upper() end
            
            if board3D[r][c] == "" then 
                board3D[r][c] = char 
                pieceMap[r..","..c] = p.obj
            end
        end
    end
    
    -- Visuals (ID tags)
    local scriptCounts = {}
    for r=1,8 do
        for c=1,8 do
            local p = squares[r][c].Text
            if p ~= "" then
                scriptCounts[p] = (scriptCounts[p] or 0) + 1
            end
        end
    end
    
    for _, p in ipairs(pieces) do
        local c = math.floor(((p.pos.X - boardAnchor.minX) / boardAnchor.squareSizeX) + 0.5) + 1
        local r = math.floor(((p.pos.Z - boardAnchor.minZ) / boardAnchor.squareSizeZ) + 0.5) + 1
        if c >= 1 and c <= 8 and r >= 1 and r <= 8 then
            local orR, orC = r, c
            if boardAnchor.flipRow then orR = 9 - r end
            if boardAnchor.flipCol then orC = 9 - c end
            
            local char = ""
            if p.type == "pawn" then char = "p"
            elseif p.type == "knight" then char = "n"
            elseif p.type == "bishop" then char = "b"
            elseif p.type == "rook" then char = "r"
            elseif p.type == "queen" then char = "q"
            elseif p.type == "king" then char = "k"
            end
            if p.color == "Black" then char = char:upper() end
            
            local isCaptured = true
            if scriptCounts[char] and scriptCounts[char] > 0 then
                scriptCounts[char] = scriptCounts[char] - 1
                isCaptured = false
            end
            if not isCaptured then
                local tColor = (p.color == "White") and Color3.fromRGB(0, 255, 255) or Color3.fromRGB(255, 0, 0)
                identifyTarget(p.obj, tColor, p.color, p.type)
            end
        end
    end
    
    return board3D, pieceMap
end

-- --- FEN and Repetition Logic ---
local function getSimpleFEN(board)
    local fen = ""
    for r = 1, 8 do
        local emptyCount = 0
        for c = 1, 8 do
            local p = board[r][c]
            if p == "" then
                emptyCount = emptyCount + 1
            else
                if emptyCount > 0 then
                    fen = fen .. tostring(emptyCount)
                    emptyCount = 0
                end
                local fenPiece = (p:upper() == p) and p:lower() or p:upper()
                fen = fen .. fenPiece
            end
        end
        if emptyCount > 0 then fen = fen .. tostring(emptyCount) end
        if r < 8 then fen = fen .. "/" end
    end
    return fen
end

local function getFEN()
    local fen = getSimpleFEN(copyBoard(squares))
    local activeColor = (currentTurn == "White") and "w" or "b"
    local castling = ""
    if not hasMoved["k"] then
        if not hasMoved["r8"] then castling = castling .. "K" end
        if not hasMoved["r1"] then castling = castling .. "Q" end
    end
    if not hasMoved["K"] then
        if not hasMoved["R8"] then castling = castling .. "k" end
        if not hasMoved["R1"] then castling = castling .. "q" end
    end
    if castling == "" then castling = "-" end
    
    fen = fen .. " " .. activeColor .. " " .. castling .. " - 0 1"
    return fen
end

local function uciToMove(uci)
    if not uci or #uci < 4 then return nil end
    local c1 = uci:sub(1,1):byte() - 96
    local r1 = 9 - tonumber(uci:sub(2,2))
    local c2 = uci:sub(3,3):byte() - 96
    local r2 = 9 - tonumber(uci:sub(4,4))
    local promo = uci:sub(5,5)
    return r1, c1, r2, c2, promo
end


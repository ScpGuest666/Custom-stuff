    checkGameState()
end

local function executeAIMove(color)
    if currentTurn ~= color or gamePaused or isThinking then return end
    isThinking = true
    local myState = stateVersion
    statusLabel.Text = "Status: AI (" .. color .. ") is thinking..."
    
    task.delay(5, function()
        if stateVersion == myState and isThinking then
            isThinking = false
            warn("AI thinking timed out forcefully.")
            statusLabel.Text = "Status: AI Timeout. Press Move."
        end
    end)
    
    task.wait(0.05) 
    
    local success, err = pcall(function()
        local fen = getFEN()
        local uciMove = getBestMoveFromAPI(fen)
        
        if stateVersion ~= myState then return end 
        
        if uciMove then
            local fromR, fromC, toR, toC, _ = uciToMove(uciMove)
            local tempBoard = applyMoveToBoard(copyBoard(squares), {fromR=fromR, fromC=fromC, toR=toR, toC=toC, piece=squares[fromR][fromC].Text})
            local newFen = getSimpleFEN(tempBoard)
            if positionHistory[newFen] and positionHistory[newFen] >= 2 then
                warn("API suggested a draw by repetition. Overriding with local AI.")
                uciMove = nil
            end
        end
        
        if uciMove then
            local fromR, fromC, toR, toC, promo = uciToMove(uciMove)
            if fromR and fromC and toR and toC and squares[fromR] and squares[fromR][fromC] then
                local movedPiece = squares[fromR][fromC].Text
                local move = {
                    fromR = fromR, fromC = fromC,
                    toR = toR, toC = toC,
                    piece = movedPiece,
                    captured = squares[toR][toC].Text
                }
                executeMove(move, color, promo)
                isThinking = false
                return
            end
        end
        
        warn("API failed or timed out, using local AI fallback.")
        local move = findBestMoveFor(color)
        
        if stateVersion ~= myState then return end 
        
        if move then
            executeMove(move, color)
        else
            checkGameState()
        end
    end)
    
    if not success then
        warn("AI Error: " .. tostring(err))
        statusLabel.Text = "Status: AI Error! Press Move."
    end
    
    isThinking = false
end


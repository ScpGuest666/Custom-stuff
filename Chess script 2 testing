local PST={p={{0,0,0,0,0,0,0,0},{50,50,50,50,50,50,50,50},{10,10,20,30,30,20,10,10},{5,5,10,25,25,10,5,5},{0,0,0,20,20,0,0,0},{5,-5,-10,0,0,-10,-5,5},{5,10,10,-20,-20,10,10,5},{0,0,0,0,0,0,0,0}},n={{-50,-40,-30,-30,-30,-30,-40,-50},{-40,-20,0,0,0,0,-20,-40},{-30,0,10,15,15,10,0,-30},{-30,5,15,20,20,15,5,-30},{-30,0,15,20,20,15,0,-30},{-30,5,10,15,15,10,5,-30},{-40,-20,0,5,5,0,-20,-40},{-50,-40,-30,-30,-30,-30,-40,-50}},b={{-20,-10,-10,-10,-10,-10,-10,-20},{-10,0,0,0,0,0,0,-10},{-10,0,5,10,10,5,0,-10},{-10,5,5,10,10,5,5,-10},{-10,0,10,10,10,10,0,-10},{-10,10,10,10,10,10,10,-10},{-10,5,0,0,0,0,5,-10},{-20,-10,-10,-10,-10,-10,-10,-20}},r={{0,0,0,0,0,0,0,0},{5,10,10,10,10,10,10,5},{-5,0,0,0,0,0,0,-5},{-5,0,0,0,0,0,0,-5},{-5,0,0,0,0,0,0,-5},{-5,0,0,0,0,0,0,-5},{-5,0,0,0,0,0,0,-5},{0,0,0,5,5,0,0,0}},q={{-20,-10,-10,-5,-5,-10,-10,-20},{-10,0,0,0,0,0,0,-10},{-10,0,5,5,5,5,0,-10},{-5,0,5,5,5,5,0,-5},{0,0,5,5,5,5,0,-5},{-10,5,5,5,5,5,0,-10},{-10,0,5,0,0,0,0,-10},{-20,-10,-10,-5,-5,-10,-10,-20}},k={{-30,-40,-40,-50,-50,-40,-40,-30},{-30,-40,-40,-50,-50,-40,-40,-30},{-30,-40,-40,-50,-50,-40,-40,-30},{-30,-40,-40,-50,-50,-40,-40,-30},{-20,-30,-30,-40,-40,-30,-30,-20},{-10,-20,-20,-20,-20,-20,-20,-10},{20,20,0,0,0,0,20,20},{20,30,10,0,0,10,30,20}}}
local function evaluateBoard(b) local s=0; for r=1,8 do for c=1,8 do local p=b[r][c]; if p~="" then local ms=PV[p] or 0; local pt,pc=p:lower(),getPieceColor(p); local ps=0; if PST[pt] then ps=(pc=="White") and PST[pt][r][c] or PST[pt][9-r][c] end; s+=(pc=="Black") and (ms-ps) or (ms+ps) end end end; return s end
local MAX_DEPTH_LOCAL,minimax_=2,nil; minimax_=function(b,d,a,be,isM) checkYield(); if d==0 then return evaluateBoard(b) end; local m=generateLegalMoves(b,isM and "Black" or "White"); if isM then local me=-math.huge; for _,mo in ipairs(m) do local nb=cloneBoard(b); nb[mo.toR][mo.toC]=mo.piece; nb[mo.fromR][mo.fromC]=""; local e=minimax_(nb,d-1,a,be,false); me=math.max(me,e); a=math.max(a,e); if be<=a then break end end; return me else local me=math.huge; for _,mo in ipairs(m) do local nb=cloneBoard(b); nb[mo.toR][mo.toC]=mo.piece; nb[mo.fromR][mo.fromC]=""; local e=minimax_(nb,d-1,a,be,true); me=math.min(me,e); be=math.min(be,e); if be<=a then break end end; return me end end
local function absPV(ch) return math.abs(PV[ch] or 0) end
local function moveLeavesPieceHanging(newBoard, move, moverColor) local oppColor = (moverColor == "White") and "Black" or "White"; local destR, destC = move.toR, move.toC; local moves = generateLegalMoves(newBoard, oppColor); for _, m in ipairs(moves) do if m.toR == destR and m.toC == destC and m.captured ~= "" then local capturedVal = (move.captured ~= "") and absPV(move.captured) or 0; local movedVal = absPV(move.piece); local netForMover = capturedVal - movedVal; if netForMover < 0 then return true, -netForMover end end end; return false, 0 end
local function findBestMoveFor(color) local board = copyBoard(squares); local bestMove, bestEval; local legalMoves = generateLegalMoves(board, color); if #legalMoves == 0 then return end; if color == "Black" then bestEval = math.huge; for _, move in ipairs(legalMoves) do checkYield(); local newBoard = applyMoveToBoard(board, move); local eval; local newFen = getSimpleFEN(newBoard); if positionHistory[newFen] and positionHistory[newFen] >= 2 then eval = 0 else eval = minimax_(newBoard, MAX_DEPTH_LOCAL - 1, -math.huge, math.huge, false) end; local hanging, penaltyMag = moveLeavesPieceHanging(newBoard, move, "Black"); if hanging then eval = eval + penaltyMag * 10 end; if eval < bestEval then bestEval, bestMove = eval, move end end else bestEval = -math.huge; for _, move in ipairs(legalMoves) do checkYield(); local newBoard = applyMoveToBoard(board, move); local eval; local newFen = getSimpleFEN(newBoard); if positionHistory[newFen] and positionHistory[newFen] >= 2 then eval = 0 else eval = minimax_(newBoard, MAX_DEPTH_LOCAL - 1, -math.huge, math.huge, true) end; local hanging, penaltyMag = moveLeavesPieceHanging(newBoard, move, "White"); if hanging then eval = eval - penaltyMag * 10 end; if eval > bestEval then bestEval, bestMove = eval, move end end end; return bestMove end


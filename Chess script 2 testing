local function copyHasMoved(hm) local c = {}; for k, v in pairs(hm) do c[k] = v end; return c end
local function cloneBoard(b) return {{b[1][1],b[1][2],b[1][3],b[1][4],b[1][5],b[1][6],b[1][7],b[1][8]},{b[2][1],b[2][2],b[2][3],b[2][4],b[2][5],b[2][6],b[2][7],b[2][8]},{b[3][1],b[3][2],b[3][3],b[3][4],b[3][5],b[3][6],b[3][7],b[3][8]},{b[4][1],b[4][2],b[4][3],b[4][4],b[4][5],b[4][6],b[4][7],b[4][8]},{b[5][1],b[5][2],b[5][3],b[5][4],b[5][5],b[5][6],b[5][7],b[5][8]},{b[6][1],b[6][2],b[6][3],b[6][4],b[6][5],b[6][6],b[6][7],b[6][8]},{b[7][1],b[7][2],b[7][3],b[7][4],b[7][5],b[7][6],b[7][7],b[7][8]},{b[8][1],b[8][2],b[8][3],b[8][4],b[8][5],b[8][6],b[8][7],b[8][8]}} end
local function getPieceColor(p) if p=="" then return nil end; return (p:upper()==p) and "Black" or "White" end
local function getPieceTextColor(c) return (c=="Black") and Color3.fromRGB(20,20,20) or Color3.fromRGB(255,255,255) end
local function copyBoard(s) local b={}; for r=1,8 do b[r]={}; for c=1,8 do b[r][c]=s[r][c].Text end end; return b end
local function isPathClear(b,sr,sc,er,ec) local dr,dc=math.sign(er-sr),math.sign(ec-sc); local r,c=sr+dr,sc+dc; while r~=er or c~=ec do if b[r] and b[r][c] and b[r][c]~="" then return false end; r,c=r+dr,c+dc end; return true end
local isValidMove; local function isSquareAttacked(b,r,c,ac) for row=1,8 do for col=1,8 do local p=b[row][col]; if getPieceColor(p)==ac then local ot=b[r][c]; b[r][c]=(ac=="White") and "P" or "p"; local ca=isValidMove(b,row,col,r,c,true); b[r][c]=ot; if ca then return true end end end end; return false end
local function findKing(b,c) local kp=(c=="White") and "k" or "K"; for r=1,8 do for col=1,8 do if b[r][col]==kp then return r,col end end end end

isValidMove = function(b,sr,sc,er,ec,isCE) local p=b[sr][sc]; if p=="" then return false end; local pt,pc=p:lower(),getPieceColor(p); local tp,tc=b[er][ec],getPieceColor(b[er][ec]); if tc==pc or (sr==er and sc==ec) then return false end; local dr,dc=math.abs(er-sr),math.abs(ec-sc); if pt=='k' and dr==0 and dc==2 and not isCE then if hasMoved[p] then return false end; local rc=(ec>sc) and 8 or 1; local rp=(pc=="White") and "r" or "R"; if b[sr][rc]~=rp or hasMoved[rp..rc] then return false end; if not isPathClear(b,sr,sc,sr,rc) then return false end; local oc=(pc=="White") and "Black" or "White"; if isSquareAttacked(b,sr,sc,oc) then return false end; local ptc=sc+((ec>sc) and 1 or -1); if isSquareAttacked(b,sr,ptc,oc) then return false end; return true end; if pt=='p' then local d=(pc=="White") and -1 or 1; local sR=(pc=="White") and 7 or 2; if dc==0 and (er-sr)==d then return tp=="" end; if dc==0 and (er-sr)==2*d and sr==sR then return tp=="" and isPathClear(b,sr,sc,er,ec) end; if dr==1 and dc==1 and (er-sr)==d then return tp~="" end; return false elseif pt=='r' then if (dr==0 and dc>0) or (dc==0 and dr>0) then return isPathClear(b,sr,sc,er,ec) end; return false elseif pt=='n' then if (dr==2 and dc==1) or (dr==1 and dc==2) then return true end; return false elseif pt=='b' then if dr==dc and dr>0 then return isPathClear(b,sr,sc,er,ec) end; return false elseif pt=='q' then if (dr==0 and dc>0) or (dc==0 and dr>0) or (dr==dc and dr>0) then return isPathClear(b,sr,sc,er,ec) end; return false elseif pt=='k' then if dr<=1 and dc<=1 and (dr>0 or dc>0) then return true end; return false end; return false end


    isTraining,trainButton.Text=false,"Train"; 
    gamePaused=false; 
    stateVersion = stateVersion + 1 
    isThinking = false
    
    if promotionFrame then promotionFrame:Destroy(); promotionFrame=nil end; 
    local lm=table.remove(moveHistory); 
    local fr,fc,tr,tc=lm.fromR,lm.fromC,lm.toR,lm.toC; 

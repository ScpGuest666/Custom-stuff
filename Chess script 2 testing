-- Auto-detect the player's colour based on camera distance (used only for initial orientation)
local function detectPlayerColorFrom3D()
    local pieces = {}
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj:IsA("Model") and obj ~= player.Character then
            local extents = obj:GetExtentsSize()
            if extents.X < 15 and extents.Y < 20 and extents.Z < 15 then
                local pType = getChessPieceType(obj.Name)
                if pType then
                    local pos = obj:GetPivot().Position
                    local dist = (pos - Camera.CFrame.Position).Magnitude
                    if dist < MAX_DISTANCE then
                        local _, color = getTeamColor3D(obj)
                        table.insert(pieces, {dist = dist, color = color})
                    end
                end
            end
        end
    end
    if #pieces < 2 then return "White" end
    local whiteDist, blackDist, whiteCount, blackCount = 0,0,0,0
    for _, p in ipairs(pieces) do
        if p.color == "White" then
            whiteDist = whiteDist + p.dist
            whiteCount = whiteCount + 1
        else
            blackDist = blackDist + p.dist
            blackCount = blackCount + 1
        end
    end
    if whiteCount == 0 then return "Black" end
    if blackCount == 0 then return "White" end
    local avgWhite = whiteDist / whiteCount
    local avgBlack = blackDist / blackCount
    return (avgWhite < avgBlack) and "White" or "Black"
end

-- Flip board to a specific orientation (true = flipped, false = normal)
local function setBoardFlipped(flipped)
    if not chessBoard then return end
    local size = 25
    for r = 1, 8 do
        for c = 1, 8 do
            local square = squares[r][c]
            local newPos
            if flipped then
                newPos = UDim2.new(0, (8 - c) * size, 0, (8 - r) * size)
            else
                newPos = UDim2.new(0, (c - 1) * size, 0, (r - 1) * size)
            end
            square.Position = newPos
        end
    end
    isBoardFlipped = flipped
end

local function applyMoveToBoard(board, move)
    local nb = cloneBoard(board)
    nb[move.toR][move.toC] = move.piece
    nb[move.fromR][move.fromC] = ""
    if move.piece:lower() == 'k' and math.abs(move.toC - move.fromC) == 2 then
        local rookCol = (move.toC > move.fromC) and 8 or 1
        local newRookCol = (move.toC > move.fromC) and 6 or 4
        nb[move.fromR][newRookCol] = nb[move.fromR][rookCol]
        nb[move.fromR][rookCol] = ""
    end
    if move.piece:lower() == 'p' and move.fromC ~= move.toC and board[move.toR][move.toC] == "" then
        nb[move.fromR][move.toC] = ""
    end
    if move.piece:lower() == 'p' and (move.toR == 1 or move.toR == 8) then
        nb[move.toR][move.toC] = (getPieceColor(move.piece) == "White") and "q" or "Q"
    end
    return nb
end


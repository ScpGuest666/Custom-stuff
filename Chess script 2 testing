        hl.FillTransparency = 0.5
        hl.Parent = model
        currentSuggestion3DHighlight = hl
    else
        clearSuggestion3DHighlight()
    end
end

local function highlightSuggested3DPlatform(row, col)
    if not isMatching or not boardAnchor then return end
    clearSuggestion3DPlatform()
    
    -- Map 2D row/col back to 3D grid coordinates
    local actualR = boardAnchor.flipRow and (9 - row) or row
    local actualC = boardAnchor.flipCol and (9 - col) or col
    
    -- Correctly calculate the center of the target square
    local targetX = boardAnchor.minX + (actualC - 1) * boardAnchor.squareSizeX
    local targetZ = boardAnchor.minZ + (actualR - 1) * boardAnchor.squareSizeZ
    
    local platform = Instance.new("Part")
    platform.Name = "SuggestionPlatform"
    platform.Anchored = true
    platform.CanCollide = false
    platform.CanQuery = false -- Click-through
    platform.Size = Vector3.new(boardAnchor.squareSizeX * 0.9, 0.1, boardAnchor.squareSizeZ * 0.9)
    -- Place it slightly above the lowest point of the pieces (the board surface)
    platform.Position = Vector3.new(targetX, boardAnchor.baseY + 0.05, targetZ)
    platform.Color = Color3.fromRGB(0, 255, 0) -- Green
    platform.Material = Enum.Material.Neon
    platform.Transparency = 0.6
    platform.Parent = workspace
    
    currentSuggestion3DPlatform = platform
end


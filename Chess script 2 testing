                squares[sr][sc].BackgroundColor3 = Color3.fromRGB(255, 255, 0)
                squares[tr][tc].BackgroundColor3 = Color3.fromRGB(0, 150, 255)
                selected=nil
                
                if not checkPromotion(tr,tc) then

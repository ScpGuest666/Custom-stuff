local function generateLegalMoves(b,c) 
	local m={}
	for r=1,8 do 
		for col=1,8 do 
			local p=b[r][col]
			if getPieceColor(p)==c then 
				for er=1,8 do 
					for ec=1,8 do 
						if isValidMove(b,r,col,er,ec) then 
							local tb=cloneBoard(b)
							tb[er][ec]=p
							tb[r][col]=""
							local kr,kc=findKing(tb,c)
							if not isSquareAttacked(tb,kr,kc,(c=="White") and "Black" or "White") then 
								table.insert(m,{fromR=r,fromC=col,toR=er,toC=ec,piece=p,captured=b[er][ec]}) 
							end 
						end 
					end 
				end 
			end 
		end 
	end
	table.sort(m, function(m1, m2)
		local s1 = m1.captured ~= "" and math.abs(PV[m1.captured] or 0) or 0
		local s2 = m2.captured ~= "" and math.abs(PV[m2.captured] or 0) or 0
		return s1 > s2
	end)
	return m 
end

-- --- 3D MATCHING LOGIC (with auto colour detection) ---
local function getChessPieceType(name)
    local lowerName = string.lower(name)
    for _, keyword in ipairs(pieceKeywords) do
        if string.find(lowerName, keyword) then return keyword end
    end
    return nil
end

local function getTeamColor3D(model)
    local part = model:FindFirstChildWhichIsA("BasePart", true)
    if part then
        local color = part.Color
        if (color.r + color.g + color.b) / 3 > 0.5 then
            return Color3.fromRGB(0, 255, 255), "White" 
        else
            return Color3.fromRGB(255, 0, 0), "Black" 
        end
    end
    return Color3.fromRGB(255, 255, 255), "Unknown"
end


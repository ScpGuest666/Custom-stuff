-- Get 3D board state (only pieces on the board) and also build piece map
local function get3DBoardState()
    if not isMatching then return nil, nil end
    local pieces = {}
    
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj:IsA("Model") and obj ~= player.Character then
            local extents = obj:GetExtentsSize()
            if extents.X < 15 and extents.Y < 20 and extents.Z < 15 then
                local pType = getChessPieceType(obj.Name)
                if pType then
                    local pos = obj:GetPivot().Position
                    local distance = (pos - Camera.CFrame.Position).Magnitude
                    if distance < MAX_DISTANCE then
                        local tColor, tName = getTeamColor3D(obj)
                        table.insert(pieces, {obj = obj, pos = pos, type = pType, color = tName, tColor = tColor})
                    end
                end
            end
        end
    end
    
    if #pieces < 4 then return nil, nil end
    
    if not boardAnchor then
        local sumX, sumZ, count = 0, 0, 0
        for _, p in ipairs(pieces) do
            sumX = sumX + p.pos.X
            sumZ = sumZ + p.pos.Z
            count = count + 1
        end
        local centerX, centerZ = sumX / count, sumZ / count
        
        local validPieces = {}
        local validXs, validZs = {}, {}
        local MAX_DEVIATION = 40 
        for _, p in ipairs(pieces) do
            if (p.pos - Vector3.new(centerX, p.pos.Y, centerZ)).Magnitude < MAX_DEVIATION then
                table.insert(validPieces, p)
                table.insert(validXs, p.pos.X)
                table.insert(validZs, p.pos.Z)
            end
        end
        
        if #validPieces < 4 then return nil, nil end
        table.sort(validXs)
        table.sort(validZs)
        
        local minX, maxX = validXs[1], validXs[#validXs]
        local minZ, maxZ = validZs[1], validZs[#validZs]
        
        local squareSizeX = (maxX - minX) / 7
        local squareSizeZ = (maxZ - minZ) / 7
        
        if squareSizeX < 0.1 or squareSizeZ < 0.1 then return nil, nil end
        
        local tempBoard = {}
        for r=1,8 do tempBoard[r] = {} for c=1,8 do tempBoard[r][c] = "" end end
        for _, p in ipairs(validPieces) do
            local c = math.floor(((p.pos.X - minX) / squareSizeX) + 0.5) + 1
            local r = math.floor(((p.pos.Z - minZ) / squareSizeZ) + 0.5) + 1
            c = math.clamp(c, 1, 8)
            r = math.clamp(r, 1, 8)
            
            local char = ""
            if p.type == "pawn" then char = "p"
            elseif p.type == "knight" then char = "n"
            elseif p.type == "bishop" then char = "b"
            elseif p.type == "rook" then char = "r"
            elseif p.type == "queen" then char = "q"
            elseif p.type == "king" then char = "k"
            end
            if p.color == "Black" then char = char:upper() end
            
            if tempBoard[r][c] == "" then tempBoard[r][c] = char end
        end
        
        local flipRow = false
        local flipCol = false
        
        local whiteKingR, whiteKingC, whiteQueenC
        for r=1,8 do for c=1,8 do if tempBoard[r][c] == 'k' then whiteKingR = r; whiteKingC = c end; if tempBoard[r][c] == 'q' then whiteQueenC = c end end end
        
        if whiteKingR and whiteKingR < 5 then
            flipRow = true
            local newBoard = {}
            for r=1,8 do newBoard[r] = tempBoard[9-r] end
            tempBoard = newBoard
        end
        
        whiteKingC = nil; whiteQueenC = nil
        for r=1,8 do for c=1,8 do if tempBoard[r][c] == 'k' then whiteKingC = c end; if tempBoard[r][c] == 'q' then whiteQueenC = c end end end
        
        if whiteKingC and whiteQueenC and whiteQueenC > whiteKingC then
            flipCol = true
        end
        
        boardAnchor = {
            minX = minX, maxX = maxX,
            minZ = minZ, maxZ = maxZ,
            squareSizeX = squareSizeX,
            squareSizeZ = squareSizeZ,
            flipRow = flipRow,
            flipCol = flipCol
        }
    end
    
    local board3D = {}
    for r=1,8 do board3D[r] = {} for c=1,8 do board3D[r][c] = "" end end
    local pieceMap = {}  -- (r,c) -> model
    
    for _, p in ipairs(pieces) do
        local c = math.floor(((p.pos.X - boardAnchor.minX) / boardAnchor.squareSizeX) + 0.5) + 1
        local r = math.floor(((p.pos.Z - boardAnchor.minZ) / boardAnchor.squareSizeZ) + 0.5) + 1
        
        local char = ""
        if p.type == "pawn" then char = "p"
        elseif p.type == "knight" then char = "n"
        elseif p.type == "bishop" then char = "b"
        elseif p.type == "rook" then char = "r"
        elseif p.type == "queen" then char = "q"
        elseif p.type == "king" then char = "k"
        end
        if p.color == "Black" then char = char:upper() end
        
        if c >= 1 and c <= 8 and r >= 1 and r <= 8 then
            if boardAnchor.flipRow then r = 9 - r end
            if boardAnchor.flipCol then c = 9 - c end
            
            if board3D[r][c] == "" then 
                board3D[r][c] = char 
                pieceMap[r..","..c] = p.obj
            else
                -- duplicate piece on same square? ignore
            end
        end
    end
    
    -- Also add the "ID" highlights for visualization (optional, keeps original behavior)
    local scriptCounts = {}
    for r=1,8 do
        for c=1,8 do
            local p = squares[r][c].Text
            if p ~= "" then
                scriptCounts[p] = (scriptCounts[p] or 0) + 1
            end
        end
    end
    
    for _, p in ipairs(pieces) do
        local c = math.floor(((p.pos.X - boardAnchor.minX) / boardAnchor.squareSizeX) + 0.5) + 1
        local r = math.floor(((p.pos.Z - boardAnchor.minZ) / boardAnchor.squareSizeZ) + 0.5) + 1
        local char = ""
        if p.type == "pawn" then char = "p"
        elseif p.type == "knight" then char = "n"
        elseif p.type == "bishop" then char = "b"
        elseif p.type == "rook" then char = "r"
        elseif p.type == "queen" then char = "q"
        elseif p.type == "king" then char = "k"
        end
        if p.color == "Black" then char = char:upper() end
        if c >= 1 and c <= 8 and r >= 1 and r <= 8 then
            local orR, orC = r, c
            if boardAnchor.flipRow then orR = 9 - r end
            if boardAnchor.flipCol then orC = 9 - c end
            local isCaptured = true
            if scriptCounts[char] and scriptCounts[char] > 0 then
                scriptCounts[char] = scriptCounts[char] - 1
                isCaptured = false
            end
            if not isCaptured then
                identifyTarget(p.obj, p.tColor, p.color, p.type)
            end
        end
    end
    
    return board3D, pieceMap
end

-- --- STOCKFISH API INTEGRATION ---
local function getFEN()
    local fen = ""
    for r = 1, 8 do
        local emptyCount = 0
        for c = 1, 8 do
            local p = squares[r][c].Text
            if p == "" then
                emptyCount = emptyCount + 1
            else
                if emptyCount > 0 then
                    fen = fen .. tostring(emptyCount)
                    emptyCount = 0
                end
                local fenPiece = (p:upper() == p) and p:lower() or p:upper()
                fen = fen .. fenPiece
            end
        end
        if emptyCount > 0 then fen = fen .. tostring(emptyCount) end
        if r < 8 then fen = fen .. "/" end
    end
    
    local activeColor = (currentTurn == "White") and "w" or "b"
    local castling = ""
    if not hasMoved["k"] then
        if not hasMoved["r8"] then castling = castling .. "K" end
        if not hasMoved["r1"] then castling = castling .. "Q" end
    end
    if not hasMoved["K"] then
        if not hasMoved["R8"] then castling = castling .. "k" end
        if not hasMoved["R1"] then castling = castling .. "q" end
    end
    if castling == "" then castling = "-" end
    
    fen = fen .. " " .. activeColor .. " " .. castling .. " - 0 1"
    return fen
end

local function uciToMove(uci)
    if not uci or #uci < 4 then return nil end
    local c1 = uci:sub(1,1):byte() - 96
    local r1 = 9 - tonumber(uci:sub(2,2))
    local c2 = uci:sub(3,3):byte() - 96
    local r2 = 9 - tonumber(uci:sub(4,4))
    local promo = uci:sub(5,5)
    return r1, c1, r2, c2, promo
end

local function getBestMoveFromAPI(fen)
    local url = "https://stockfish.online/api/s/v2.php?fen=" .. HttpService:UrlEncode(fen) .. "&depth=10"
    local body = nil
    local completed = false
    
    task.spawn(function()
        if req then
            local success, response = pcall(function() return req({Url = url, Method = "GET"}) end)
            if success and response then body = response.Body end
        elseif type(game.HttpGet) == "function" then
            local success, response = pcall(function() return game:HttpGet(url) end)
            if success then body = response end
        end
        completed = true
    end)
    
    local t = 0
    while not completed and t < 5 do
        t = t + task.wait(0.1)
    end
    
    if not completed then return nil end
    
    if body then
        local success, data = pcall(function() return HttpService:JSONDecode(body) end)
        if success and data and data.success and data.bestmove then
            return data.bestmove:match("bestmove%s+(%S+)")
        end
    end
    return nil
end


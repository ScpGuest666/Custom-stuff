-- --- MATCH 3D LOOP (mirroring only, but user can move any piece on 2D freely) ---
local function matchLoop()
    while isMatching do
        task.wait(0.3)
        if gamePaused then continue end
        
        local board3D, pieceMap = get3DBoardState()
        if not board3D then 
            lastSeenBoard3D = nil
            boardStableCount = 0
            continue 
        end
        currentPieceMap = pieceMap or {}
        
        -- Stability check
        if lastSeenBoard3D then
            local stable = true
            for r=1,8 do
                for c=1,8 do
                    if board3D[r][c] ~= lastSeenBoard3D[r][c] then
                        stable = false
                        break
                    end
                end
            end
            if stable then
                boardStableCount = boardStableCount + 1
            else
                boardStableCount = 0
            end
        else
            boardStableCount = 0
        end
        lastSeenBoard3D = board3D
        
        if boardStableCount < STABLE_FRAMES_REQUIRED then continue end
        
        -- Compare with the last known 2D board (turnStartBoard)
        if not boardsMatch(turnStartBoard, board3D) then
            local legalMoves = generateLegalMoves(turnStartBoard, currentTurn)
            local matchedMove = nil
            for _, move in ipairs(legalMoves) do
                local tempBoard = applyMoveToBoard(turnStartBoard, move)
                if boardsMatch(tempBoard, board3D) then
                    matchedMove = move
                    break
                end
            end
            
            if matchedMove then
                -- Apply the mirrored move to the 2D board
                for r=1,8 do for c=1,8 do 
                    squares[r][c].Text = turnStartBoard[r][c]
                    squares[r][c].TextColor3 = getPieceTextColor(getPieceColor(turnStartBoard[r][c]))
                end end
                executeMove(matchedMove, currentTurn)
                turnStartBoard = copyBoard(squares)
                clearSuggestionHighlight()
                boardStableCount = 0
                -- After mirroring, if it's now the player's turn, suggest a move
                if not isAutoMoveActive and currentTurn == playerColor and not gamePaused then
                    suggestMoveForHuman()
                end
            else
                statusLabel.Text = "Unclear 3D movement – cannot mirror"
            end
        else
            -- Boards match. If it's player's turn and no suggestion active, generate one.
            if not isAutoMoveActive and currentTurn == playerColor and not gamePaused and not currentSuggestion then
                suggestMoveForHuman()
            end
        end
    end
end

local function flipBoard()

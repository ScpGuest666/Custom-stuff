                    clearHighlights()
                    squares[sr][sc].BackgroundColor3 = Color3.fromRGB(255, 255, 0)
                    squares[tr][tc].BackgroundColor3 = Color3.fromRGB(0, 150, 255)
                    selected = nil
                    
                    if not checkPromotion(tr, tc) then
                        currentTurn = (pieceColor == "White") and "Black" or "White"
                        stateVersion = stateVersion + 1
                        turnStartBoard = copyBoard(squares)  -- update mirror reference
                        clearSuggestionHighlight()
                        if not checkGameState() and currentTurn == playerColor then
                            suggestMoveForHuman()
                        end
                    end
                else
                    clearHighlights()
                    if #moveHistory > 0 then
                        local pm = moveHistory[#moveHistory]
                        squares[pm.fromR][pm.fromC].BackgroundColor3 = Color3.fromRGB(255, 255, 0)
                        squares[pm.toR][pm.toC].BackgroundColor3 = Color3.fromRGB(0, 150, 255)
                    end
                    selected = nil
                end
            end
            return
        end
        
        -- Normal mode (non-match): original behavior (only your pieces)
        if gamePaused or isTraining or currentTurn~=playerColor or isThinking then return end

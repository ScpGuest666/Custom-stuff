            statusLabel.Text = "Failed: Missing Kings. Adjust camera closer to pieces."
            isMatching = false
            boardAnchor = nil
            clear3DVisuals()
        end
    else
        isMatching = false
        isAutoMoveActive = false
        moveButton.Text = "Auto Move"
        matchButton.Text = "Match 3D"
        boardAnchor = nil
        clear3DVisuals()
        clearSuggestionHighlight()
        lastSeenBoard3D = nil
        boardStableCount = 0
        currentPieceMap = {}
        persistentModelColors = {}
        detectedPlayerColor = nil
        statusLabel.Text = "Status: Online ("..currentTurn.."'s Turn)"
    end
end)

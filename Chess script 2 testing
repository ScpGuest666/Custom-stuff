    clearHighlights()
    if #moveHistory > 0 then
        local prevMove = moveHistory[#moveHistory]
        squares[prevMove.fromR][prevMove.fromC].BackgroundColor3 = Color3.fromRGB(255, 255, 0)
        squares[prevMove.toR][prevMove.toC].BackgroundColor3 = Color3.fromRGB(0, 150, 255)
    end
    
    if isMatching then
        turnStartBoard = copyBoard(squares)
        clearSuggestionHighlight()
        if currentTurn == playerColor and not gamePaused then
            suggestMoveForHuman()
        end
        -- DO NOT reset boardAnchor here – keep it stable
    end
    
    statusLabel.Text="Status: Online ("..currentTurn.."'s Turn)" 
end

local function setStatusOnline() 
    statusLabel.Text="Status: Online (White's Turn)"; 
    statusLabel.TextColor3=Color3.fromRGB(0,255,0); 
    gameActive=true; 
    backButton.Active=true 
end

local function setStatusOffline() 
    statusLabel.Text="Status: Offline"; 
    statusLabel.TextColor3=Color3.fromRGB(255,0,0); 
    gameActive=false; 
    isTraining=false; 
    trainButton.Text="Train"; 
    backButton.Active=false; 
    if isMatching then
        isMatching = false
        matchButton.Text = "Match 3D"
        boardAnchor = nil
        clear3DVisuals()
        clearSuggestionHighlight()
        lastSeenBoard3D = nil
        boardStableCount = 0
        currentPieceMap = {}
    end
    if chessBoard then chessBoard:Destroy(); chessBoard=nil end
    if promotionFrame then promotionFrame:Destroy(); promotionFrame=nil end
    clearHighlights()
end

local function cleanup() 
    for _,c in ipairs(activeConnections) do 
        if c and c.Disconnect then c:Disconnect() end 
    end 
    activeConnections={}; 
    if chessBoard then chessBoard:Destroy(); chessBoard=nil end; 
    if promotionFrame then promotionFrame:Destroy(); promotionFrame=nil end; 
    if screenGui then screenGui:Destroy(); screenGui=nil end;
    if isMatching then
        isMatching = false
        clear3DVisuals()
    end
end

local function createChessGame()
	if gameActive then return end 
	currentTurn,gamePaused,isTraining,trainButton.Text,playerColor,isBoardFlipped = "White",false,false,"Train","White",false
	stateVersion = 0
	isThinking = false
    boardAnchor = nil
    lastSeenBoard3D = nil
    boardStableCount = 0
    currentPieceMap = {}
	hasMoved = {k=false,K=false,r1=false,r8=false,R1=false,R8=false}
	if chessBoard then chessBoard:Destroy() end
	chessBoard=Instance.new("Frame"); chessBoard.Parent,chessBoard.BackgroundColor3,chessBoard.Size,chessBoard.Position,chessBoard.BorderSizePixel=frame,Color3.fromRGB(200,200,200),UDim2.new(0,200,0,200),UDim2.new(0,20,0,80),0
	local s=25; for r=1,8 do squares[r],originalColors[r]={},{} for c=1,8 do local sq=Instance.new("TextButton"); sq.Parent,sq.Size,sq.Position=chessBoard,UDim2.new(0,s,0,s),UDim2.new(0,(c-1)*s,0,(r-1)*s); local cl=((r+c)%2==0) and Color3.fromRGB(240,217,181) or Color3.fromRGB(181,136,99); sq.BackgroundColor3,originalColors[r][c]=cl,cl; sq.TextScaled,sq.Font,sq.TextColor3,sq.Text=true,Enum.Font.SourceSansBold,Color3.fromRGB(0,0,0),""; squares[r][c]=sq end end
	local l={{"R","N","B","Q","K","B","N","R"},{"P","P","P","P","P","P","P","P"},{"","","","","","","",""},{"","","","","","","",""},{"","","","","","","",""},{"","","","","","","",""},{"p","p","p","p","p","p","p","p"},{"r","n","b","q","k","b","n","r"}}; for r=1,8 do for c=1,8 do local p=l[r][c]; if p~="" then squares[r][c].Text=p; squares[r][c].TextColor3=(r<=2) and Color3.fromRGB(20,20,20) or Color3.fromRGB(255,255,255) end end end
	
	local function handlePromotion(pr,pc,pc_color) gamePaused=true; if promotionFrame then promotionFrame:Destroy() end; promotionFrame=Instance.new("Frame"); promotionFrame.Parent,promotionFrame.BackgroundColor3,promotionFrame.Size,promotionFrame.Position,promotionFrame.BorderSizePixel,promotionFrame.BorderColor3=frame,Color3.fromRGB(60,60,60),UDim2.new(0,200,0,40),UDim2.new(0,20,0,285),1,Color3.fromRGB(255,255,255); local ps,ptc={"Q","R","B","N"},getPieceTextColor(pc_color); for i,pl in ipairs(ps) do local btn=Instance.new("TextButton"); btn.Parent,btn.Size,btn.Position,btn.BackgroundColor3=promotionFrame,UDim2.new(0.25,0,1,0),UDim2.new((i-1)*0.25,0,0,0),Color3.fromRGB(80,80,80); local ft=(pc_color=="White") and pl:lower() or pl:upper(); btn.Text,btn.TextColor3,btn.TextScaled,btn.Font=ft,ptc,true,Enum.Font.SourceSansBold; table.insert(activeConnections,btn.MouseButton1Click:Connect(function() squares[pr][pc].Text,squares[pr][pc].TextColor3=ft,ptc; promotionFrame:Destroy(); promotionFrame,gamePaused=nil,false; currentTurn=(playerColor=="White") and "Black" or "White"; stateVersion = stateVersion + 1; if not checkGameState() then if currentTurn=="Black" then task.spawn(executeAIMoveForBlack) else task.spawn(executeAIMoveForWhite) end end end)) end end
	local function checkPromotion(er,ec) local p=squares[er][ec].Text; if p:lower()=='p' and (er==1 or er==8) then handlePromotion(er,ec,getPieceColor(p)); return true end; return false end
	
	local selected,sr,sc=nil,nil,nil; for r=1,8 do for c=1,8 do local sq=squares[r][c]; table.insert(activeConnections,sq.MouseButton1Click:Connect(function() 
        -- In match mode, allow moving any piece (both colors) freely
        if isMatching then
            if gamePaused or isTraining or isThinking then return end
            if not selected then
                if sq.Text ~= "" then
                    selected,sr,sc = sq,r,c
                    clearHighlights()
                    if #moveHistory > 0 then
                        local pm = moveHistory[#moveHistory]
                        squares[pm.fromR][pm.fromC].BackgroundColor3 = Color3.fromRGB(255, 255, 0)
                        squares[pm.toR][pm.toC].BackgroundColor3 = Color3.fromRGB(0, 150, 255)
                    end
                    sq.BackgroundColor3 = Color3.fromRGB(255,255,0)
                    local pieceColor = getPieceColor(sq.Text)
                    if pieceColor then
                        highlightValidMoves(sr,sc, pieceColor)
                    end
                end
            else
                local tr,tc = r,c
                if selected == sq then
                    clearHighlights()
                    if #moveHistory > 0 then
                        local pm = moveHistory[#moveHistory]
                        squares[pm.fromR][pm.fromC].BackgroundColor3 = Color3.fromRGB(255, 255, 0)
                        squares[pm.toR][pm.toC].BackgroundColor3 = Color3.fromRGB(0, 150, 255)
                    end
                    selected = nil
                    return
                end
                local pieceColor = getPieceColor(selected.Text)
                if not pieceColor then selected = nil; return end
                local lm = generateLegalMoves(copyBoard(squares), pieceColor)
                local isLegal = false
                for _, move in ipairs(lm) do
                    if move.fromR == sr and move.fromC == sc and move.toR == tr and move.toC == tc then
                        isLegal = true
                        break
                    end
                end
                if isLegal then
                    local mp = selected.Text
                    table.insert(moveHistory, {fromR=sr, fromC=sc, toR=tr, toC=tc, movedPiece=mp, capturedPiece=squares[tr][tc].Text, previousHasMoved=copyHasMoved(hasMoved)})
                    
                    if mp:lower() == 'p' and sc ~= tc and squares[tr][tc].Text == "" then
                        squares[sr][tc].Text = ""
                    end
                    
                    sq.Text, sq.TextColor3, selected.Text = mp, selected.TextColor3, ""

        currentSuggestion3DHighlight:Destroy()
    end
    currentSuggestion3DHighlight = nil
end

local function highlightSuggested3DPiece(row, col)
    if not isMatching or not currentPieceMap then return end
    local key = row..","..col
    local model = currentPieceMap[key]
    if model then
        clearSuggestion3DHighlight()
        local hl = Instance.new("Highlight")
        hl.Name = "SuggestionHighlight"
        hl.Adornee = model
        hl.FillColor = Color3.fromRGB(255, 255, 0)  -- yellow

local function suggestMoveForHuman()
    if not gameActive or gamePaused or isTraining or not isMatching then return end
    -- Only suggest if it's the turn of the player's color (detected at match start)
    if currentTurn ~= playerColor then return end
    if isThinking then return end

    isThinking = true
    local myState = stateVersion
    statusLabel.Text = "Generating suggestion..."

    local fen = getFEN()
    local uciMove = getBestMoveFromAPI(fen)
    local suggestion = nil

    if myState == stateVersion and uciMove then
        local fromR, fromC, toR, toC, promo = uciToMove(uciMove)
        if fromR and fromC and toR and toC and squares[fromR] and squares[fromR][fromC] then
            suggestion = {
                fromR = fromR, fromC = fromC,
                toR = toR, toC = toC,
                piece = squares[fromR][fromC].Text,
                captured = squares[toR][toC].Text
            }
        end
    end

    if myState == stateVersion and not suggestion then
        suggestion = findBestMoveFor(currentTurn)
    end

    if myState == stateVersion and suggestion then
        showSuggestion(suggestion)
        statusLabel.Text = "Suggestion: " .. string.char(96+suggestion.fromC) .. (9-suggestion.fromR) .. " → " .. string.char(96+suggestion.toC) .. (9-suggestion.toR)
    else
        statusLabel.Text = "No suggestion available"
    end
    isThinking = false
end

-- --- Game State and Execution ---
local function checkGameState() 
    local b=copyBoard(squares); 
    local lm=generateLegalMoves(b,currentTurn); 
    if #lm==0 then 
        local kr,kc=findKing(b,currentTurn); 
        local oc=(currentTurn=="White") and "Black" or "White"; 
        if isSquareAttacked(b,kr,kc,oc) then 
            statusLabel.Text="Checkmate! "..oc.." wins!" 
        else 
            statusLabel.Text="Stalemate! It's a draw." 
        end; 
        gamePaused=true; 
        return true 
    end; 
    return false 
end

local function executeMove(move, color, promo)
    local fromR,fromC,toR,toC,movedPiece = move.fromR,move.fromC,move.toR,move.toC,move.piece
    local startSq,endSq=squares[fromR][fromC],squares[toR][toC]
    
    clearHighlights() 
    
    table.insert(moveHistory,{fromR=fromR,fromC=fromC,toR=toR,toC=toC,movedPiece=movedPiece,capturedPiece=endSq.Text,previousHasMoved=copyHasMoved(hasMoved)})
    
    if movedPiece:lower() == 'p' and fromC ~= toC and endSq.Text == "" then
        squares[fromR][toC].Text = ""
    end
    
    endSq.Text,endSq.TextColor3,startSq.Text=movedPiece,getPieceTextColor(color),""
    
    if movedPiece:lower()=='k' and math.abs(toC-fromC)==2 then
        local rookCol,newRookCol=(toC>fromC) and 8 or 1,(toC>fromC) and 6 or 4
        local rookPiece=squares[fromR][rookCol].Text
        squares[fromR][newRookCol].Text,squares[fromR][rookCol].Text=rookPiece,""
        squares[fromR][newRookCol].TextColor3=getPieceTextColor(color)
    end
    
    if movedPiece:lower() == 'p' then
        if (color == "White" and toR == 1) or (color == "Black" and toR == 8) then
            local newPiece = promo
            if not newPiece or newPiece == "" then newPiece = "q" end
            newPiece = (color == "White") and newPiece:lower() or newPiece:upper()
            endSq.Text = newPiece
            local lastMove = moveHistory[#moveHistory]
            if lastMove then lastMove.promotedTo = newPiece end
        end
    end
    
    hasMoved[movedPiece]=true
    if movedPiece:lower()=='r' then hasMoved[movedPiece..fromC]=true end
    
    startSq.BackgroundColor3=Color3.fromRGB(255,255,0)
    endSq.BackgroundColor3=Color3.fromRGB(0,150,255)
    
    currentTurn=(color=="White") and "Black" or "White"
    stateVersion = stateVersion + 1 
    statusLabel.Text="Status: ("..currentTurn.."'s Turn)"
    checkGameState()
end

local function executeAIMove(color)
    if currentTurn ~= color or gamePaused or isThinking then return end
    isThinking = true
    local myState = stateVersion
    statusLabel.Text = "Status: AI (" .. color .. ") is thinking..."
    
    task.delay(5, function()
        if stateVersion == myState and isThinking then
            isThinking = false
            warn("AI thinking timed out forcefully.")
            statusLabel.Text = "Status: AI Timeout. Press Move."
        end
    end)
    
    task.wait(0.05) 
    
    local success, err = pcall(function()
        local fen = getFEN()
        local uciMove = getBestMoveFromAPI(fen)
        
        if stateVersion ~= myState then return end 
        
        if uciMove then
            local fromR, fromC, toR, toC, promo = uciToMove(uciMove)
            if fromR and fromC and toR and toC and squares[fromR] and squares[fromR][fromC] then
                local movedPiece = squares[fromR][fromC].Text
                local move = {
                    fromR = fromR, fromC = fromC,
                    toR = toR, toC = toC,
                    piece = movedPiece,
                    captured = squares[toR][toC].Text
                }
                executeMove(move, color, promo)
                isThinking = false
                return
            end
        end
        
        warn("Stockfish API failed or timed out, using local AI fallback.")
        local move = findBestMoveFor(color)
        
        if stateVersion ~= myState then return end 
        
        if move then
            executeMove(move, color)
        else
            checkGameState()
        end
    end)
    
    if not success then
        warn("AI Error: " .. tostring(err))
        statusLabel.Text = "Status: AI Error! Press Move."
    end
    
    isThinking = false
end

local function executeAIMoveForWhite() executeAIMove("White") end
local function executeAIMoveForBlack() executeAIMove("Black") end

local function trainingLoop()
    while isTraining and not gamePaused do
        if not isThinking then

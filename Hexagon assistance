-- Function to handle Platform Spawning
local function togglePlatform()
    local character = player.Character
    local root = character and character:FindFirstChild("HumanoidRootPart")
    
    if not isPlatformOn then
        if root then
            isPlatformOn = true
            -- Rotation set to 270 degrees (Left side front orientation)
            referenceCFrame = root.CFrame * CFrame.new(0, -3.5, 0) * CFrame.Angles(0, math.pi * 1.5, 0)
            
            platformPart = Instance.new("Part")
            platformPart.Name = "RedPlatform"
            platformPart.Size = Vector3.new(15, 1, 15)
            platformPart.CFrame = referenceCFrame
            platformPart.Anchored = true
            platformPart.CanCollide = false
            platformPart.Color = Color3.fromRGB(255, 0, 0)
            platformPart.Material = Enum.Material.Neon
            platformPart.Transparency = 0.5
            platformPart.Parent = workspace
            
            statusLabel.Text = "Status: Online"
            statusLabel.TextColor3 = Color3.fromRGB(0, 255, 0)
        end
    else
        isPlatformOn = false
        if platformPart then
            platformPart:Destroy()
            platformPart = nil
        end
        referenceCFrame = nil
        statusLabel.Text = "Status: Offline"
        statusLabel.TextColor3 = Color3.fromRGB(255, 0, 0)
    end
end

-- TP Button Logic
tpButton.MouseButton1Click:Connect(function()
    local character = player.Character
    local root = character and character:FindFirstChild("HumanoidRootPart")
    local humanoid = character and character:FindFirstChild("Humanoid")
    
    -- CHECK: If character is sitting, do not attempt to TP
    if humanoid and humanoid.Sit then
        statusLabel.Text = "Stand up to TP!"
        task.delay(1, function()
            if isPlatformOn then statusLabel.Text = "Status: Online" end
        end)
        return 
    end
    
    if root and referenceCFrame then
        local offset = RelativeCoords[currentTPIndex]
        local targetWorldPos = referenceCFrame:PointToWorldSpace(offset)
        
        -- TELEPORT: Lowered by 4 studs (Changed from +3 to -1)
        root.CFrame = CFrame.new(targetWorldPos + Vector3.new(0, -1, 0))
        
        -- Update UI and Index
        currentTPIndex = currentTPIndex + 1
        if currentTPIndex > 12 then
            currentTPIndex = 1
        end
        tpButton.Text = "TP (" .. currentTPIndex .. ")"
    else
        statusLabel.Text = "Turn Toggle ON First!"
        task.delay(1, function()
            if not isPlatformOn then statusLabel.Text = "Status: Offline" end
        end)
    end
end)

-- Toggle Button Click
toggleButton.MouseButton1Click:Connect(function()
    togglePlatform()
end)

-- Destroy Logic

local STEP_DURATION = 0.35
local STEP_THRESHOLD = 6
local STRIDE_MULTIPLIER = 1.5
local GRAVITY_FORCE = 60 
local MAX_LEG_STRETCH = 1.4 -- Allows the leg to stretch 40% further than its resting build length


-- Button 2: Toggle Marking Mode
markBtn.MouseButton1Click:Connect(function()
    if not mainSeat then return end
    markingMode = not markingMode
    if markingMode then
        markBtn.Text = "2. Mark Joints: ON"
        markBtn.BackgroundColor3 = Color3.fromRGB(200, 100, 0)
        local humanoid = player.Character:FindFirstChildOfClass("Humanoid")
        if sitConnection then sitConnection:Disconnect() end
        
        sitConnection = humanoid:GetPropertyChangedSignal("SeatPart"):Connect(function()
            if not markingMode then return end
            local seat = humanoid.SeatPart
            if seat and seat ~= mainSeat then
                local existingIndex = table.find(markedPartsList, seat)
                if existingIndex then
                    table.remove(markedPartsList, existingIndex)
                    markedPartsData[seat].Highlight:Destroy()
                    markedPartsData[seat].Gui:Destroy()
                    markedPartsData[seat] = nil
                else
                    if #markedPartsList < 12 then
                        table.insert(markedPartsList, seat)
                        markedPartsData[seat] = {}
                    end
                end
                updateVisuals()
                saveGlobalState()
            end
        end)
    else
        markBtn.Text = "2. Mark Joints: OFF"
        markBtn.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
        if sitConnection then sitConnection:Disconnect() end
    end
end)


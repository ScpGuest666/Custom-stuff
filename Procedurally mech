        mainSeat = _G.MechPuppeteer_Data.MainSeat
        markedPartsList = _G.MechPuppeteer_Data.MarkedParts
        mechParts = getBuildParts(mainSeat)
        for _, part in ipairs(markedPartsList) do markedPartsData[part] = {} end
        updateVisuals()
        statusLabel.Text = "Found Previous Mech!"
        setMainBtn.BackgroundColor3 = Color3.fromRGB(0, 150, 0)
    end
end

local function saveGlobalState()
    _G.MechPuppeteer_Data = {
        MainSeat = mainSeat,
        MarkedParts = markedPartsList,
        Destroy = cleanupEverything
    }
end


-- Helper: Deep Flood Fill
local function getBuildParts(startPart)
    local parts, toCheck, checked = {}, {startPart}, {[startPart] = true}
    local overlapParams = OverlapParams.new()
    while #toCheck > 0 do
        local current = table.remove(toCheck, 1)
        table.insert(parts, current)
        for _, p in ipairs(current:GetConnectedParts()) do
            if not checked[p] and not p:IsDescendantOf(player.Character) then 
                checked[p] = true; table.insert(toCheck, p) 
            end
        end
        local touching = workspace:GetPartBoundsInBox(current.CFrame, current.Size + Vector3.new(4, 4, 4), overlapParams)
        for _, p in ipairs(touching) do
            if p:IsA("BasePart") and not checked[p] and p.Name ~= "Baseplate" and p.Name ~= "Grass" and not p:IsDescendantOf(player.Character) then
                checked[p] = true; table.insert(toCheck, p)
            end
        end
    end
    return parts
end

-- Helper: Update Visuals
local function updateVisuals()
    for i, part in ipairs(markedPartsList) do
        local data = markedPartsData[part]
        local isSwivel = (i >= 4 and i <= 9)
        local color = isSwivel and Color3.fromRGB(255, 255, 0) or Color3.fromRGB(0, 255, 0)
        
        if not data.Gui then
            local hl = Instance.new("SelectionBox", part)
            hl.Adornee = part; hl.Color3 = color; hl.LineThickness = 0.05
            local bg = Instance.new("BillboardGui", part)
            bg.Size = UDim2.new(4, 0, 4, 0); bg.AlwaysOnTop = true
            local txt = Instance.new("TextLabel", bg)
            txt.Size = UDim2.new(1, 0, 1, 0); txt.BackgroundTransparency = 1
            txt.TextScaled = true; txt.TextColor3 = color; txt.Font = Enum.Font.SourceSansBold
            data.Highlight, data.Gui, data.Label = hl, bg, txt
        end
        data.Label.Text = tostring(i)
        data.Label.TextColor3, data.Highlight.Color3 = color, color
    end
    
    statusLabel.Text = "Marked: " .. #markedPartsList .. "/12"
    if #markedPartsList == 12 then
        activateBtn.BackgroundColor3 = Color3.fromRGB(0, 150, 0)
        activateBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    else
        activateBtn.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
        activateBtn.TextColor3 = Color3.fromRGB(100, 100, 100)
    end
end

-- Cleanup function
local function cleanupEverything()
    if runConnection then runConnection:Disconnect() end
    if sitConnection then sitConnection:Disconnect() end
    local folder = workspace:FindFirstChild("MechTargets")
    if folder then folder:Destroy() end
    
    if mainSeat then
        for _, child in ipairs(mainSeat:GetChildren()) do
            if child.Name == "MechPuppeteer_Constraint" then child:Destroy() end
        end
    end
    for _, part in ipairs(markedPartsList) do
        for _, child in ipairs(part:GetChildren()) do
            if child.Name == "MechPuppeteer_Constraint" then child:Destroy() end
        end
    end
    
    for part, state in pairs(originalCollisionStates) do
        if part and part.Parent then part.CanCollide = state end
    end
    table.clear(originalCollisionStates)
    
    for part, data in pairs(markedPartsData) do
        if data.Gui then data.Gui:Destroy() end
        if data.Highlight then data.Highlight:Destroy() end
    end
    screenGui:Destroy()
end

-- AUTO-OWNERSHIP
if _G.MechPuppeteer_Data then
    pcall(function() _G.MechPuppeteer_Data.Destroy() end) 
    

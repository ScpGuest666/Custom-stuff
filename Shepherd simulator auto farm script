-------------------------------------------------------------------------------
-- ADVANCED TEXT DETECTION ENGINE
-------------------------------------------------------------------------------
local function isTrulyVisible(guiObject)
    local current = guiObject
    while current and current:IsA("GuiObject") do
        if not current.Visible then return false end
        if current:IsA("TextLabel") or current:IsA("TextButton") then
            if current.TextTransparency >= 1 then return false end
        end
        current = current.Parent
    end
    return true
end

-- Strips RichText tags, newlines, and extra spaces to make text readable
local function cleanText(str)
    if type(str) ~= "string" then return "" end
    str = string.gsub(str, "<[^>]+>", "") -- Remove rich text tags
    str = string.lower(str) -- Convert to lowercase
    str = string.gsub(str, "%s+", " ") -- Replace newlines/multiple spaces with a single space
    return str
end

-- Finds UI by checking if ALL provided keywords exist in the text (ignores typos/cut-offs)
local function findUIElementByKeywords(keywords)
    local playerGui = player:FindFirstChild("PlayerGui")
    if not playerGui then return nil end

    for _, desc in ipairs(playerGui:GetDescendants()) do
        if desc:IsA("TextLabel") or desc:IsA("TextButton") then
            if desc.Text and desc.Text ~= "" then
                local text = cleanText(desc.Text)
                local allMatch = true
                
                for _, kw in ipairs(keywords) do
                    if not string.find(text, string.lower(kw), 1, true) then
                        allMatch = false
                        break
                    end
                end
                
                if allMatch and isTrulyVisible(desc) then
                    return desc
                end
            end
        end
    end
    return nil
end

-- Finds UI by exact substring, with an optional word to exclude (e.g., find "Graze" but exclude "Stop")
local function findUIElementByText(targetText, excludeText)
    local playerGui = player:FindFirstChild("PlayerGui")
    if not playerGui then return nil end

    targetText = string.lower(targetText)
    excludeText = excludeText and string.lower(excludeText) or nil
    
    for _, desc in ipairs(playerGui:GetDescendants()) do
        if desc:IsA("TextLabel") or desc:IsA("TextButton") then
            if desc.Text and desc.Text ~= "" then
                local text = cleanText(desc.Text)
                
                if string.find(text, targetText, 1, true) then
                    local isExcluded = false
                    if excludeText and string.find(text, excludeText, 1, true) then
                        isExcluded = true
                    end
                    
                    if not isExcluded and isTrulyVisible(desc) then
                        return desc
                    end
                end
            end
        end
    end
    return nil
end

-- Simulates a click on a UI element using specific button offsets
local function clickUIElement(element, buttonName)
    if not element then return false end
    
    local absPos = element.AbsolutePosition
    local absSize = element.AbsoluteSize

    local offsets = buttonOffsets[buttonName] or { offsetX = 50, offsetY = 80 }
    local bOffsetX = offsets.offsetX
    local bOffsetY = offsets.offsetY

    local x = absPos.X + (absSize.X / 2) + bOffsetX
    local y = absPos.Y + (absSize.Y / 2) + bOffsetY

    pointer.Position = UDim2.new(0, x + pointerOffsetX, 0, y + pointerOffsetY)
    pointer.Visible = true

    vim:SendTouchEvent(TOUCH_ID, 0, x, y) -- Began
    task.wait(0.05)
    vim:SendTouchEvent(TOUCH_ID, 1, x, y) -- Moved
    task.wait(0.05)
    vim:SendTouchEvent(TOUCH_ID, 2, x, y) -- Ended
    
    task.wait(0.1)
    pointer.Visible = false
    return true
end

-------------------------------------------------------------------------------
-- MAIN FARMING CYCLE
-------------------------------------------------------------------------------
local function startFarmingCycle()
    local character = player.Character
    local hrp = character and character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    while isFarming do
        local currentFarmDuration = 4 * 60 -- Default to 4 minutes

        ---------------------------------------------------------
        -- PHASE 1: BRING OUT
        ---------------------------------------------------------
        status.Text = "Bringing Out..."
        while isFarming do
            local bringOutBtn = findUIElementByText("bring out")
            if bringOutBtn then
                clickUIElement(bringOutBtn, "Bring out")
                task.wait(1)
                
                -- If it successfully clicked and disappeared, break to next phase
                if not findUIElementByText("bring out") then
                    break
                end
            else
                -- If button is not found, check if they are already out (Bring in or Graze is visible)
                if findUIElementByText("bring in") or findUIElementByText("graze", "stop") then
                    break
                end
                
                -- Teleport to a random sheep to force the UI to appear
                local sheepList = {}
                for _, part in pairs(mySheep) do
                    if part and part.Parent then
                        table.insert(sheepList, part)
                    end
                end
                
                if #sheepList > 0 then
                    local randomSheep = sheepList[math.random(1, #sheepList)]
                    hrp.CFrame = randomSheep.CFrame + Vector3.new(0, 3, 0)
                else
                    hrp.CFrame = originalCFrame
                end
                
                task.wait(0.5)
            end
        end
        if not isFarming then break end

        ---------------------------------------------------------
        -- PHASE 2: TELEPORT TO GRAZE AREA
        ---------------------------------------------------------
        status.Text = "Going to Graze Area..."
        hrp.CFrame = CFrame.new(176.67967224121095, 10.65000057220459, 311.4925231933594)
        task.wait(1.5) -- Wait for UI to load
        if not isFarming then break end

        ---------------------------------------------------------
        -- PHASE 3: START GRAZING
        ---------------------------------------------------------
        status.Text = "Starting Graze..."
        while isFarming do
            local stopBtn = findUIElementByText("stop grazing")
            if stopBtn then break end -- It changed to Stop Grazing, we are good
            
            -- Look for "graze" but make sure it doesn't accidentally click "stop grazing"
            local grazeBtn = findUIElementByText("graze", "stop")
            if grazeBtn then
                clickUIElement(grazeBtn, "Graze")
            end
            task.wait(0.5)
        end
        if not isFarming then break end

        ---------------------------------------------------------
        -- PHASE 4: MAINTAIN GRAZE
        ---------------------------------------------------------
        status.Text = "Grazing..."
        local grazeStartTime = os.time()
        local maxGrazeTime = 1 * 60 -- 1 minute failsafe timer

        while isFarming do
            -- 1. Click Stop Grazing
            local stopBtn = findUIElementByText("stop grazing")
            if stopBtn then clickUIElement(stopBtn, "Stop Grazing") end
            task.wait(0.5)
            
            -- 2. Click Graze
            local grazeBtn = findUIElementByText("graze", "stop")
            if grazeBtn then clickUIElement(grazeBtn, "Graze") end
            
            -- 3. Wait a moment for the game to update the text UI (clears old lingering messages)
            task.wait(1) 

            -- 4. FAILSAFE: If grazing takes longer than 1 minute, assume full/UFO
            if os.time() - grazeStartTime >= maxGrazeTime then
                currentFarmDuration = 1 * 60
                break
            end

            -- 5. INSTANT DETECTION: Triggers the moment "are full" appears on screen
            if findUIElementByText("are full") then
                currentFarmDuration = 4 * 60
                break
            end

            -- 6. KEYWORD DETECTION: Only needs the words "unidentified" and "flying" to exist
            if findUIElementByKeywords({"unidentified", "flying"}) then
                currentFarmDuration = 1 * 60
                break
            end
            
            -- 7. Wait before next cycle
            task.wait(2) 
        end
        if not isFarming then break end

        ---------------------------------------------------------
        -- PHASE 5: FINISH GRAZE & RETURN (DOG LURE WAIT)
        ---------------------------------------------------------
        status.Text = "Returning..."
        -- Loop to handle cases where the "Stop Grazing" button is grayed out or disappears 
        -- We know we have successfully stopped grazing when the "Graze" button reappears.
        while isFarming do
            local grazeBtn = findUIElementByText("graze", "stop")
            if grazeBtn then
                break -- Successfully stopped grazing!
            end
            
            local finalStopBtn = findUIElementByText("stop grazing")
            if finalStopBtn then 
                clickUIElement(finalStopBtn, "Stop Grazing") 
            end
            task.wait(1)
        end
        
        if not isFarming then break end
        
        hrp.CFrame = originalCFrame
        task.wait(1.5) -- Wait for UI to load
        if not isFarming then break end

        ---------------------------------------------------------
        -- PHASE 6: BRING IN
        ---------------------------------------------------------
        status.Text = "Bringing In..."
        while isFarming do
            local bringInBtn = findUIElementByText("bring in")
            if bringInBtn then
                clickUIElement(bringInBtn, "Bring in")
                task.wait(1)
            else
                break -- Button is gone
            end
            task.wait(0.5)
        end
        if not isFarming then break end

        ---------------------------------------------------------
        -- PHASE 7: FARM SHEEP (DYNAMIC DURATION)
        ---------------------------------------------------------
        local endTime = os.time() + currentFarmDuration
        
        while isFarming and os.time() < endTime do
            -- Update Status with Countdown
            local remaining = endTime - os.time()
            local mins = math.floor(remaining / 60)
            local secs = remaining % 60
            status.Text = string.format("%02d:%02d", mins, secs)

            -- Teleport to whitelisted sheep
            local hasTeleported = false
            for sheepModel, targetSheepPart in pairs(mySheep) do
                if not isFarming or os.time() >= endTime then break end
                
                if targetSheepPart and targetSheepPart.Parent then
                    hrp.CFrame = targetSheepPart.CFrame + Vector3.new(0, 3, 0)
                    hasTeleported = true
                    task.wait(0.1) -- INCREASED SPEED: 3x faster (was 0.3)
                else
                    mySheep[sheepModel] = nil -- Remove if deleted
                end
            end
            
            -- If no sheep were found/teleported to, wait a bit to prevent lag
            if not hasTeleported then
                if (hrp.Position - originalCFrame.Position).Magnitude > 5 then
                    hrp.CFrame = originalCFrame
                end
                task.wait(0.5)
            end
        end
    end
end


-- [[ ADJUST MOUSE POSITIONS FOR EACH INDIVIDUAL BUTTON HERE ]] --
local buttonOffsets = {
    ["Bring out"]    = { offsetX = 50, offsetY = 60 },
    ["Graze"]        = { offsetX = 50, offsetY = 80 },
    ["Stop Grazing"] = { offsetX = 50, offsetY = 60 },
    ["Bring in"]     = { offsetX = 50, offsetY = 60 }
}

-- [[ ADJUST POINTER (RED DOT) POSITION RELATIVE TO MOUSE HERE ]] --
local pointerOffsetX = -38 
local pointerOffsetY = 0   

local TOUCH_ID = 8823
local isFarming = false
local originalCFrame = nil
local maxDistance = 40

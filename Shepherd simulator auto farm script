-------------------------------------------------------------------------------
-- ADVANCED TEXT DETECTION ENGINE
-------------------------------------------------------------------------------
local function isTrulyVisible(guiObject)
    local current = guiObject
    while current and current:IsA("GuiObject") do
        if not current.Visible then return false end
        if current:IsA("TextLabel") or current:IsA("TextButton") then
            if current.TextTransparency >= 1 then return false end
        end
        current = current.Parent
    end
    return true
end

local function cleanText(str)
    if type(str) ~= "string" then return "" end
    str = string.gsub(str, "<[^>]+>", "") 
    str = string.lower(str) 
    str = string.gsub(str, "%s+", " ") 
    return str
end

local function findUIElementByKeywords(keywords)
    local playerGui = player:FindFirstChild("PlayerGui")
    if not playerGui then return nil end

    for _, desc in ipairs(playerGui:GetDescendants()) do
        if desc:IsA("TextLabel") or desc:IsA("TextButton") then
            if desc.Text and desc.Text ~= "" then
                local text = cleanText(desc.Text)
                local allMatch = true
                
                for _, kw in ipairs(keywords) do
                    if not string.find(text, string.lower(kw), 1, true) then
                        allMatch = false
                        break
                    end
                end
                
                if allMatch and isTrulyVisible(desc) then
                    return desc
                end
            end
        end
    end
    return nil
end

local function findUIElementByText(targetText, excludeText)
    local playerGui = player:FindFirstChild("PlayerGui")
    if not playerGui then return nil end

    targetText = string.lower(targetText)
    excludeText = excludeText and string.lower(excludeText) or nil
    
    for _, desc in ipairs(playerGui:GetDescendants()) do
        if desc:IsA("TextLabel") or desc:IsA("TextButton") then
            if desc.Text and desc.Text ~= "" then
                local text = cleanText(desc.Text)
                
                if string.find(text, targetText, 1, true) then
                    local isExcluded = false
                    if excludeText and string.find(text, excludeText, 1, true) then
                        isExcluded = true
                    end
                    
                    if not isExcluded and isTrulyVisible(desc) then
                        return desc
                    end
                end
            end
        end
    end
    return nil
end

local function clickUIElement(element, buttonName)
    if not element then return false end
    
    local absPos = element.AbsolutePosition
    local absSize = element.AbsoluteSize

    local offsets = buttonOffsets[buttonName] or { offsetX = 50, offsetY = 80 }
    local bOffsetX = offsets.offsetX
    local bOffsetY = offsets.offsetY

    local x = absPos.X + (absSize.X / 2) + bOffsetX
    local y = absPos.Y + (absSize.Y / 2) + bOffsetY

    pointer.Position = UDim2.new(0, x + pointerOffsetX, 0, y + pointerOffsetY)
    pointer.Visible = true

    vim:SendTouchEvent(TOUCH_ID, 0, x, y) 
    task.wait(0.05)
    vim:SendTouchEvent(TOUCH_ID, 1, x, y) 
    task.wait(0.05)
    vim:SendTouchEvent(TOUCH_ID, 2, x, y) 
    
    task.wait(0.1)
    pointer.Visible = false
    return true
end

-------------------------------------------------------------------------------
-- MAIN FARMING CYCLE
-------------------------------------------------------------------------------
local function startFarmingCycle()
    local character = player.Character
    local hrp = character and character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    while isFarming do
        local currentFarmDuration = 4 * 60 

        ---------------------------------------------------------
        -- PHASE 1: BRING OUT
        ---------------------------------------------------------
        status.Text = "Bringing Out..."
        while isFarming do
            local bringOutBtn = findUIElementByText("bring out")
            if bringOutBtn then
                clickUIElement(bringOutBtn, "Bring out")
                task.wait(1)
                
                if not findUIElementByText("bring out") then
                    break
                end
            else
                if findUIElementByText("bring in") or findUIElementByText("graze", "stop") then
                    break
                end
                
                local sheepList = {}
                for _, part in pairs(mySheep) do
                    if part and part.Parent then
                        table.insert(sheepList, part)
                    end
                end
                
                if #sheepList > 0 then
                    local randomSheep = sheepList[math.random(1, #sheepList)]
                    hrp.CFrame = randomSheep.CFrame + Vector3.new(0, 3, 0)
                else
                    hrp.CFrame = originalCFrame
                end
                
                task.wait(0.5)
            end
        end
        if not isFarming then break end

        ---------------------------------------------------------
        -- PHASE 2: TELEPORT TO GRAZE AREA
        ---------------------------------------------------------
        status.Text = "Going to Graze Area..."
        hrp.CFrame = CFrame.new(176.67967224121095, 10.65000057220459, 311.4925231933594)
        task.wait(1.5) 
        if not isFarming then break end

        ---------------------------------------------------------
        -- PHASE 3: START GRAZING
        ---------------------------------------------------------
        status.Text = "Starting Graze..."
        while isFarming do
            local stopBtn = findUIElementByText("stop grazing")
            if stopBtn then break end 
            
            local grazeBtn = findUIElementByText("graze", "stop")
            if grazeBtn then
                clickUIElement(grazeBtn, "Graze")
            end
            task.wait(0.5)
        end
        if not isFarming then break end

        ---------------------------------------------------------
        -- PHASE 4: MAINTAIN GRAZE
        ---------------------------------------------------------
        status.Text = "Grazing..."
        local grazeStartTime = os.time()
        local maxGrazeTime = 1 * 60 

        while isFarming do
            local stopBtn = findUIElementByText("stop grazing")
            if stopBtn then clickUIElement(stopBtn, "Stop Grazing") end
            task.wait(0.5)
            
            local grazeBtn = findUIElementByText("graze", "stop")
            if grazeBtn then clickUIElement(grazeBtn, "Graze") end
            
            task.wait(1) 

            if os.time() - grazeStartTime >= maxGrazeTime then
                currentFarmDuration = 4 * 60 
                break
            end

            if findUIElementByText("are full") then
                currentFarmDuration = 4 * 60
                break
            end

            if findUIElementByKeywords({"unidentified", "flying"}) then
                currentFarmDuration = 2 * 60 
                break
            end
            
            task.wait(2) 
        end
        if not isFarming then break end

        ---------------------------------------------------------
        -- PHASE 5: FINISH GRAZE & RETURN
        ---------------------------------------------------------
        status.Text = "Returning..."
        while isFarming do
            local grazeBtn = findUIElementByText("graze", "stop")
            if grazeBtn then
                break 
            end
            
            local finalStopBtn = findUIElementByText("stop grazing")
            if finalStopBtn then 
                clickUIElement(finalStopBtn, "Stop Grazing") 
            end
            task.wait(1)
        end
        
        if not isFarming then break end
        
        hrp.CFrame = originalCFrame
        task.wait(1.5) 
        if not isFarming then break end

        ---------------------------------------------------------
        -- PHASE 6: BRING IN
        ---------------------------------------------------------
        status.Text = "Bringing In..."
        while isFarming do
            local bringInBtn = findUIElementByText("bring in")
            if bringInBtn then
                clickUIElement(bringInBtn, "Bring in")
                task.wait(1)
            else
                break 
            end
            task.wait(0.5)
        end
        if not isFarming then break end

        ---------------------------------------------------------
        -- PHASE 7: FARM SHEEP (REMOTE TOUCH / NO TP)
        ---------------------------------------------------------
        local endTime = os.time() + currentFarmDuration
        local toggleWiggle = false
        
        while isFarming and os.time() < endTime do
            -- Update Status with Countdown
            local remaining = endTime - os.time()
            local mins = math.floor(remaining / 60)
            local secs = remaining % 60
            status.Text = string.format("%02d:%02d", mins, secs)

            local char = player.Character
            local currentHrp = char and char:FindFirstChild("HumanoidRootPart")

            if currentHrp then
                -- Wiggle offset forces the physics engine to register continuous touches
                toggleWiggle = not toggleWiggle
                local wiggleOffset = toggleWiggle and Vector3.new(0, 0.1, 0) or Vector3.new(0, -0.1, 0)

                for sheepModel, _ in pairs(mySheep) do
                    if not isFarming or os.time() >= endTime then break end
                    
                    if sheepModel and sheepModel.Parent then
                        
                        -- 1. PROXIMITY PROMPT SUPPORT
                        for _, desc in ipairs(sheepModel:GetDescendants()) do
                            if desc:IsA("ProximityPrompt") then
                                if fireproximityprompt then
                                    fireproximityprompt(desc)
                                else
                                    desc:InputHoldBegin()
                                    task.wait(desc.HoldDuration + 0.05)
                                    desc:InputHoldEnd()
                                end
                            end
                        end

                        -- 2. FIRETOUCHINTEREST ON ALL PARTS
                        for _, desc in ipairs(sheepModel:GetDescendants()) do
                            if desc:IsA("BasePart") then
                                if firetouchinterest then
                                    firetouchinterest(currentHrp, desc, 0)
                                    firetouchinterest(currentHrp, desc, 1)
                                end
                            end
                        end

                        -- 3. FAKE LIMB SIMULATION (PERSISTENT)
                        -- Create the fake limb if it doesn't exist yet (or if player died and it was destroyed)
                        if not activeFakeLimbs[sheepModel] or not activeFakeLimbs[sheepModel].Parent then
                            local fakeLimb = Instance.new("Part")
                            fakeLimb.Name = "Right Arm"
                            fakeLimb.CanCollide = false
                            fakeLimb.Transparency = 1
                            fakeLimb.Massless = true
                            fakeLimb.Parent = char
                            activeFakeLimbs[sheepModel] = fakeLimb
                        end
                        
                        -- Update the fake limb's position to stay on the sheep
                        local sheepCFrame, sheepSize = sheepModel:GetBoundingBox()
                        local limb = activeFakeLimbs[sheepModel]
                        if limb and limb.Parent then
                            limb.Size = sheepSize + Vector3.new(2, 2, 2)
                            limb.CFrame = sheepCFrame + wiggleOffset
                        end

                    else
                        -- Cleanup ONLY if the sheep was completely deleted from the game
                        if activeFakeLimbs[sheepModel] then
                            activeFakeLimbs[sheepModel]:Destroy()
                            activeFakeLimbs[sheepModel] = nil
                        end
                        mySheep[sheepModel] = nil 
                    end
                end
                task.wait(0.5) 
            else
                task.wait(1) -- Wait for character to respawn
            end
        end

        -- =========================================================
        -- TELEPORT BACK TO ORIGINAL SPOT AFTER TIMER ENDS
        -- =========================================================
        if isFarming and originalCFrame then
            local char = player.Character
            local finalHrp = char and char:FindFirstChild("HumanoidRootPart")
            if finalHrp then
                finalHrp.CFrame = originalCFrame
                task.wait(0.5) 
            end
        end
    end
end


-------------------------------------------------------------------------------
-- HELPER FUNCTIONS
-------------------------------------------------------------------------------
local function isTrulyVisible(guiObject)
    local current = guiObject
    while current and current:IsA("GuiObject") do
        if not current.Visible then return false end
        if current:IsA("TextLabel") or current:IsA("TextButton") then
            if current.TextTransparency >= 1 then return false end
        end
        current = current.Parent
    end
    return true
end

-- Scans PlayerGui for specific text
local function findUIElementByText(targetText)
    local playerGui = player:FindFirstChild("PlayerGui")
    if not playerGui then return nil end

    targetText = string.lower(targetText)
    
    for _, desc in ipairs(playerGui:GetDescendants()) do
        if desc:IsA("TextLabel") or desc:IsA("TextButton") then
            if desc.Text then
                local text = string.lower(desc.Text)
                -- Use plain text search to avoid pattern matching errors
                if string.find(text, targetText, 1, true) and isTrulyVisible(desc) then
                    return desc
                end
            end
        end
    end
    return nil
end

-- Simulates a click on a UI element using specific button offsets
local function clickUIElement(element, buttonName)
    if not element then return false end
    
    local absPos = element.AbsolutePosition
    local absSize = element.AbsoluteSize

    -- Fetch the specific offsets for this button, fallback to 50, 80 if not found
    local offsets = buttonOffsets[buttonName] or { offsetX = 50, offsetY = 80 }
    local bOffsetX = offsets.offsetX
    local bOffsetY = offsets.offsetY

    local x = absPos.X + (absSize.X / 2) + bOffsetX
    local y = absPos.Y + (absSize.Y / 2) + bOffsetY

    pointer.Position = UDim2.new(0, x + pointerOffsetX, 0, y + pointerOffsetY)
    pointer.Visible = true

    -- Click sequence
    vim:SendTouchEvent(TOUCH_ID, 0, x, y) -- Began
    task.wait(0.05)
    vim:SendTouchEvent(TOUCH_ID, 1, x, y) -- Moved
    task.wait(0.05)
    vim:SendTouchEvent(TOUCH_ID, 2, x, y) -- Ended
    
    task.wait(0.1)
    pointer.Visible = false
    return true
end

-------------------------------------------------------------------------------
-- MAIN FARMING CYCLE
-------------------------------------------------------------------------------
local function startFarmingCycle()
    local character = player.Character
    local hrp = character and character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    while isFarming do
        ---------------------------------------------------------
        -- PHASE 1: BRING OUT
        ---------------------------------------------------------
        status.Text = "Bringing Out..."
        while isFarming do
            local bringOutBtn = findUIElementByText("Bring out")
            if bringOutBtn then
                clickUIElement(bringOutBtn, "Bring out")
                task.wait(1)
            else
                break -- Button is gone, move to next phase
            end
            task.wait(0.5)
        end
        if not isFarming then break end

        ---------------------------------------------------------
        -- PHASE 2: TELEPORT TO GRAZE AREA
        ---------------------------------------------------------
        status.Text = "Going to Graze Area..."
        hrp.CFrame = CFrame.new(176.67967224121095, 10.65000057220459, 311.4925231933594)
        task.wait(1.5) -- Wait for UI to load
        if not isFarming then break end

        ---------------------------------------------------------
        -- PHASE 3: START GRAZING
        ---------------------------------------------------------
        status.Text = "Starting Graze..."
        while isFarming do
            local stopBtn = findUIElementByText("Stop Grazing")
            if stopBtn then break end -- It changed to Stop Grazing, we are good
            
            local grazeBtn = findUIElementByText("Graze")
            if grazeBtn then
                clickUIElement(grazeBtn, "Graze")
            end
            task.wait(0.5)
        end
        if not isFarming then break end

        ---------------------------------------------------------
        -- PHASE 4: MAINTAIN GRAZE (Every 2 seconds)
        ---------------------------------------------------------
        status.Text = "Grazing..."
        while isFarming do
            -- Check if sheep are full
            if findUIElementByText("Your sheep are full, take them back to the sheepfold!") then
                break
            end
            
            -- Click Stop Grazing
            local stopBtn = findUIElementByText("Stop Grazing")
            if stopBtn then clickUIElement(stopBtn, "Stop Grazing") end
            task.wait(0.5)
            
            -- Click Graze
            local grazeBtn = findUIElementByText("Graze")
            if grazeBtn then clickUIElement(grazeBtn, "Graze") end
            
            -- Wait the remainder of the 2 seconds
            task.wait(3) 
        end
        if not isFarming then break end

        ---------------------------------------------------------
        -- PHASE 5: FINISH GRAZE & RETURN
        ---------------------------------------------------------
        status.Text = "Returning..."
        local finalStopBtn = findUIElementByText("Stop Grazing")
        if finalStopBtn then clickUIElement(finalStopBtn, "Stop Grazing") end
        task.wait(1)
        
        hrp.CFrame = originalCFrame
        task.wait(1.5) -- Wait for UI to load
        if not isFarming then break end

        ---------------------------------------------------------
        -- PHASE 6: BRING IN
        ---------------------------------------------------------
        status.Text = "Bringing In..."
        while isFarming do
            local bringInBtn = findUIElementByText("Bring in")
            if bringInBtn then
                clickUIElement(bringInBtn, "Bring in")
                task.wait(1)
            else
                break -- Button is gone
            end
            task.wait(0.5)
        end
        if not isFarming then break end

        ---------------------------------------------------------
        -- PHASE 7: FARM SHEEP (4 MINUTES)
        ---------------------------------------------------------
        local farmDuration = 4 * 60 -- 4 minutes in seconds
        local endTime = os.time() + farmDuration
        
        while isFarming and os.time() < endTime do
            -- Update Status with Countdown
            local remaining = endTime - os.time()
            local mins = math.floor(remaining / 60)
            local secs = remaining % 60
            status.Text = string.format("%02d:%02d", mins, secs)

            -- Teleport to whitelisted sheep
            local hasTeleported = false
            for sheepModel, targetSheepPart in pairs(mySheep) do
                if not isFarming or os.time() >= endTime then break end
                
                if targetSheepPart and targetSheepPart.Parent then
                    hrp.CFrame = targetSheepPart.CFrame + Vector3.new(0, 3, 0)
                    hasTeleported = true
                    task.wait(0.3)
                else
                    mySheep[sheepModel] = nil -- Remove if deleted
                end
            end
            
            -- If no sheep were found/teleported to, wait a bit to prevent lag
            if not hasTeleported then
                if (hrp.Position - originalCFrame.Position).Magnitude > 5 then
                    hrp.CFrame = originalCFrame
                end
                task.wait(0.5)
            end
        end
    end
end

